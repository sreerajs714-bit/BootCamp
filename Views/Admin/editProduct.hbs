    <nav class="flex-1 overflow-y-auto py-6 px-4 space-y-1">
        <a href="/admin/dashboard" class="sidebar-item flex items-center px-4 py-3 text-[11px] font-bold text-gray-500 uppercase tracking-wide rounded-lg">
            <span class="material-symbols-outlined mr-3.5 text-[19px]">dashboard</span>Dashboard
