                        "surface-container-low": "#f3f3f3",
                        "secondary-fixed-dim": "#acabab",
                        "on-error": "#ffffff",
                        "primary-container": "#3b3b3b",
                        "tertiary-fixed": "#5e5e5e",
                        "primary": "#000000",
                        "primary-fixed": "#5e5e5e",
                        "secondary-container": "#d6d4d3",
                        "on-tertiary-fixed": "#ffffff",
                        "tertiary": "#3b3b3b",
                        "on-tertiary": "#e2e2e2",
                        "surface-container-highest": "#e2e2e2",
                        "primary-fixed-dim": "#474747",
                        "on-primary": "#e2e2e2",
                        "inverse-surface": "#2f3131",
                        "surface-variant": "#e2e2e2",
                        "tertiary-fixed-dim": "#474747",
                        "surface-container-lowest": "#ffffff",
                        "on-primary-fixed": "#ffffff",
                        "outline-variant": "#c6c6c6",
                        "surface-tint": "#5e5e5e",
                        "surface": "#f9f9f9",
                        "tertiary-container": "#747474",
                        "surface-dim": "#dadada",
                        "on-secondary-container": "#1b1c1c",
                        "surface-dim": "#dadada",
                        "surface": "#f9f9f9",
                        "on-surface": "#1a1c1c",
                        "error-container": "#ffdad6",
                        "surface-container-high": "#e8e8e8",
                        "on-primary-fixed-variant": "#e2e2e2",
                        "error": "#ba1a1a",
                        "inverse-on-surface": "#f1f1f1",
                        "on-tertiary-container": "#ffffff",
                        "on-error-container": "#410002",
                        "secondary": "#5f5e5e",
                        "inverse-primary": "#c6c6c6",
                        "surface-container": "#eeeeee",
                        "on-secondary-fixed-variant": "#3b3b3b",
                        "on-secondary": "#ffffff",
                        "background": "#f9f9f9",
                        "on-secondary-fixed": "#1b1c1c",
                        "surface-bright": "#f9f9f9",
                        "secondary-fixed": "#c8c6c6",
                        "on-surface-variant": "#474747",
                        "on-primary-container": "#ffffff",
                        "on-background": "#1a1c1c"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "fontFamily": {
                        "headline": ["Space Grotesk"],
                        "body": ["Inter"],
                        "label": ["Inter"]
                    }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .kinetic-monolith-overlay {
            background: linear-gradient(to top, rgba(0, 0, 0, 0.8) 0%, rgba(0, 0, 0, 0.2) 60%, rgba(0, 0, 0, 0) 100%);
        }

        /* Animations */
        @keyframes slideInFromLeft {
            0% {
                transform: translateX(-150%);
                opacity: 0;
            }

            80% {
                transform: translateX(10%);
                opacity: 1;
            }

            100% {
                transform: translateX(0);
                opacity: 1;
            }
        }

        .subtitle-anim {
            opacity: 0;
            animation: slideInFromLeft 1s cubic-bezier(0.25, 1, 0.5, 1) forwards;
        }

        @keyframes dropInFromTop {
            0% {
                opacity: 0;
                transform: translateY(-80px);
            }

            60% {
                opacity: 1;
                transform: translateY(10px);
            }

            80% {
                transform: translateY(-5px);
            }

            100% {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .letter {
            display: inline-block;
            opacity: 0;
            animation: dropInFromTop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        }
    </style>
</head>

<body class="bg-surface font-body text-on-surface antialiased overflow-hidden">
    <!-- Main Content Shell -->
    <main class="relative h-screen w-full flex flex-col md:flex-row overflow-hidden">
        <!-- Left Side: Visual Anchor -->
        <section class="relative w-full md:w-1/2 h-1/3 md:h-full overflow-hidden flex items-end">
            <div class="absolute inset-0 z-0">
                <img alt="high-quality close-up of a premium professional football boot on a dark background, dramatic side lighting, moody athletic aesthetic, 8k resolution"
                    class="w-full h-full object-cover"
                    src="https://lh3.googleusercontent.com/aida-public/AB6AXuCCWibQefqZyE2luDOWGUOKIWy0hP4ihQ3SufwOfTX8UFeP8lcFo-rE91MskE4OusFA8g0Pk8gMuZaJ4sAwAThnjUFNqbHp46knWiz8kHzE7FStdfoyrwWIJbJ86RSMWOgxyttmsbFruuMYbMdwAAwDeplZGZ3fP36Y4d0YJrEVeP945xfHJs7cBnodcPvUox3QrAgPT6CR2JdAAkNCmX3hfLF3tLOHJoAn2-d_I9V76bSwQUtsb2l3DGQBF-ZJMQFIBqFyzwCLPTk" />
                <div class="absolute inset-0 kinetic-monolith-overlay z-10"></div>
            </div>
            <div class="relative z-20 p-8 md:p-16 mb-8 w-full">
                <h1 id="main-title"
                    class="title-anim font-headline font-black text-5xl md:text-8xl text-on-primary tracking-tighter leading-none uppercase">
                    BOOT CAMP
                </h1>
                <p
                    class="subtitle-anim font-headline font-medium text-lg md:text-xl text-on-primary tracking-[0.2em] mt-4 uppercase">
                    STEP INTO PERFORMANCE
                </p>
            </div>
        </section>
        <!-- Right Side: Login Form -->
        <section
            class="w-full md:w-1/2 bg-surface-container-lowest flex items-center justify-center p-5 md:p-12 lg:p-24 overflow-y-auto max-h-screen">
            <div class="w-full max-w-md my-auto">
                <header class="mb-12">
                    <h2 class="headline-font text-3xl font-bold text-primary tracking-tight mb-2">ADMIN LOGIN</h2>
                    <p class="text-on-surface-variant text-sm">Return to the grind-Your goals are waiting.</p>
                </header>
                <form class="space-y-8" action="/admin/login" method="post">
                    <!-- Email Address Field -->
                    <div class="group">
                        <input
                            class="w-full text-[14px] bg-transparent border-0 border-b-2 border-outline-variant py-0 px-0 text-primary placeholder:text-outline focus:ring-0 focus:border-primary transition-all duration-300 font-body"
                            id="email" name="email" placeholder="EMAIL" type="text">
                        <p id="email-error" class="text-error text-[11px] mt-1 hidden "></p>
                    </div>
                    <!-- Password Field -->
                    <div class="group">
                        <div class="relative">
                            <input
                                class="w-full text-[14px] bg-transparent border-0 border-b-2 border-outline-variant py-0 px-0 text-primary placeholder:text-outline focus:ring-0 focus:border-primary transition-all duration-300 font-body"
                                id="password" name="password" placeholder="PASSWORD" type="password">
                            <button class="absolute right-0 top-1/2 -translate-y-1/2 text-outline hover:text-primary"
                                type="button">
                                <span class="material-symbols-outlined" data-icon="visibility" style="font-size: 20px"
                                    onclick="togglePassword()">visibility</span>
                            </button>
                        </div>
                        <p id="password-error" class="text-error text-[11px] mt-1 hidden "></p>
                        <div class="flex justify-end mt-2">
                            <a href="/users/resetPassword"
                                class="text-[10px] text-outline hover:text-primary font-bold tracking-widest uppercase transition-colors">Forgot
                                Password?</a>
                        </div>
                    </div>
                    <!-- Action Button -->
                    <div class="pt-6">
                        <button
                            class="w-full bg-primary text-on-primary font-headline font-bold text-sm tracking-widest uppercase py-5 px-8 rounded-lg hover:bg-primary-container transition-all active:scale-95"
                            type="submit">
                            Login
                        </button>
                    </div>
                </form>
            </div>
        </section>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="/toast/toast.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const titleElement = document.getElementById('main-title');
            const text = titleElement.textContent.trim();
            titleElement.textContent = ''; // Clear existing text

            let words = text.split(' ');

            const subtitleDuration = 1000;
            const delayBetweenLetters = 100;
            let letterIndex = 0;

            words.forEach((word, wordIdx) => {
                const wordSpan = document.createElement('span');
                wordSpan.style.display = 'inline-block';
                wordSpan.style.whiteSpace = 'nowrap';

                word.split('').forEach(char => {
                    const span = document.createElement('span');
                    span.textContent = char;
                    span.className = 'letter';
                    span.style.animationDelay = `${subtitleDuration + (letterIndex * delayBetweenLetters)}ms`;
                    wordSpan.appendChild(span);
                    letterIndex++;
                });

                titleElement.appendChild(wordSpan);

                if (wordIdx < words.length - 1) {
                    const space = document.createElement('span');
                    space.innerHTML = '&nbsp;';
                    titleElement.appendChild(space);
                }
            });
        });

        function showError(id, message) {
            const errorElement = document.getElementById(`${id}-error`);
            if (errorElement) {
                errorElement.textContent = message;
                errorElement.classList.remove('hidden');
            }
        }

        function clearError(id) {
            const errorElement = document.getElementById(`${id}-error`);
            if (errorElement) {
                errorElement.textContent = '';
                errorElement.classList.add('hidden');
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            const form = document.querySelector("form");
            const emailInput = document.getElementById('email');
            const passwordInput = document.getElementById('password');

            emailInput.addEventListener('input', () => clearError('email'));
            passwordInput.addEventListener('input', () => clearError('password'));

            form.addEventListener("submit", async function (e) {
                e.preventDefault();

                const email = emailInput.value.trim();
                const password = passwordInput.value.trim();

                clearError('email');
                clearError('password');

                let isValid = true;
                if (!email) {
                    showError('email', 'Email is required');
                    isValid = false;
                }
                if (!password) {
                    showError('password', 'Password is required');
                    isValid = false;
                }

                if (!isValid) return;

                const submitBtn = form.querySelector('button[type="submit"]');
                const originalText = submitBtn.textContent;

                try {
                    submitBtn.disabled = true;
                    submitBtn.textContent = 'LOGGING IN...';

                    const response = await axios.post(form.action, { email, password });

                    if (response.data.success) {
                        showToast("success", "Login successful!");
                        setTimeout(() => {
                            window.location.href = "/admin/dashboard";
                        }, 1000);
                    } else {
                        throw new Error(response.data.message || "Login failed");
                    }

                } catch (error) {
                    const message = error.response?.data?.message || error.message || "Invalid email or password";
                    // Show general error on password field for common login issues
                    showToast("error", message);
                } finally {
                    submitBtn.disabled = false;
                    submitBtn.textContent = originalText;
                }
            });
        });

        function togglePassword() {
            const password = document.getElementById("password");
            password.type = password.type === "password" ? "text" : "password";
        }

        window.addEventListener("pageshow", (e) => {
            if (e.persisted || performance.getEntriesByType("navigation")[0]?.type === "back_forward") {
                window.location.reload();
            }
        });
    </script>
</body>

</html>