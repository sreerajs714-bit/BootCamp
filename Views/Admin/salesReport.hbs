    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script>
        let revenueChart;

        document.addEventListener('DOMContentLoaded', () => {
            initRevenueChart();
            loadReportData('month'); // Initial load
        });

        // ─── Data Fetching ───────────────────────────────────────────
       async function loadReportData(period, startDate = null, endDate = null) {
    try {
        const params = { period };
        if (startDate) params.startDate = startDate;
        if (endDate) params.endDate = endDate;

        const response = await axios.get('/admin/salesReportData', { params });
        
        if (response.data.success) {
            renderReport(response.data.data, period);
        }
    } catch (error) {
        console.error('Failed to load sales report data:', error);
    }
}

        // ─── Rendering Logic ─────────────────────────────────────────
        function renderReport(data, period) {
    document.getElementById('current-range-label').innerText = data.dateRangeLabel;
    document.getElementById('selected-period-label').innerText = period.charAt(0).toUpperCase() + period.slice(1);

    document.getElementById('disp-revenue').innerText = `₹ ${data.totalRevenue.toLocaleString('en-IN')}`;
    document.getElementById('disp-revenue-overview').innerText = `₹ ${data.totalRevenue.toLocaleString('en-IN')}`;
    document.getElementById('disp-orders').innerText = data.totalOrders;
    document.getElementById('disp-sold').innerText = data.totalProductsSold;

    revenueChart.data.labels = data.chartLabels;
    revenueChart.data.datasets[0].data = data.chartData;
    revenueChart.update();

    const maxVal = Math.max(data.growthComparison.current, data.growthComparison.previous) || 1;
    document.getElementById('bar-prev').style.height = `${(data.growthComparison.previous / maxVal) * 100}%`;
    document.getElementById('bar-curr').style.height = `${(data.growthComparison.current / maxVal) * 100}%`;

    document.getElementById('growth-analysis-text').innerText = `"${data.analysisResult}"`;

    const couponBody = document.querySelector('#coupon-usage-table tbody');
    couponBody.innerHTML = data.couponUsage.length ? data.couponUsage.map(c => `
        <tr>
            <td class="font-bold">
                <span class="bg-gray-50 px-3 py-1.5 rounded-lg border border-gray-100 uppercase tracking-wider text-[11px]">${c.code}</span>
            </td>
            <td class="text-center font-bold text-gray-400">${c.usageCount}x</td>
            <td class="text-right font-black">₹ ${c.totalDiscount.toLocaleString('en-IN')}</td>
        </tr>
    `).join('') : '<tr><td colspan="3" class="text-center py-8 text-gray-400">No coupon data available</td></tr>';

    const ordersBody = document.querySelector('#recent-orders-table tbody');
    ordersBody.innerHTML = data.recentOrders.length ? data.recentOrders.map(o => `
        <tr>
            <td class="font-black">#${o.orderId}</td>
            <td class="text-gray-500 font-bold">${o.date}</td>
            <td class="font-bold">${o.userName}</td>
            <td class="text-gray-400 font-bold uppercase text-[10px]">${o.method}</td>
            <td class="text-right font-black">₹ ${o.finalAmount.toLocaleString('en-IN')}</td>
        </tr>
    `).join('') : '<tr><td colspan="5" class="text-center py-8 text-gray-400">No recent orders</td></tr>';
}

        // ─── Chart Initialization ────────────────────────────────────
        function initRevenueChart() {
            const ctx = document.getElementById('revenueLineChart').getContext('2d');
            revenueChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: [],
                    datasets: [{
                        label: 'Revenue',
                        data: [],
                        borderColor: '#000',
                        borderWidth: 3,
                        pointRadius: 4,
                        pointBackgroundColor: '#fff',
                        pointBorderColor: '#000',
                        pointBorderWidth: 2,
                        tension: 0.4,
                        fill: false
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: '#f1f1f1', borderDash: [5, 5], drawBorder: false },
                            ticks: { font: { size: 10, weight: '900' }, color: '#9ca3af' }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { font: { size: 9, weight: '800' }, color: '#9ca3af', maxRotation: 45, minRotation: 45 }
                        }
                    }
                }
            });
        }

        // ─── UI Interactions ─────────────────────────────────────────
        function toggleDropdown(id) {
            const el = document.getElementById(id);
            const wasActive = el.classList.contains('dropdown-active');
            document.querySelectorAll('.relative').forEach(c => c.classList.remove('dropdown-active'));
            if (!wasActive) el.classList.add('dropdown-active');
        }

        window.addEventListener('click', (e) => {
            if (!e.target.closest('.relative')) {
                document.querySelectorAll('.relative').forEach(c => c.classList.remove('dropdown-active'));
            }
        });

        async function selectPeriod(period) {
            toggleDropdown('period-dropdown-container');
            loadReportData(period.toLowerCase());
        }

        async function applyCustomRange() {
            const start = document.getElementById('custom-start-date').value;
            const end = document.getElementById('custom-end-date').value;
            if (!start || !end) return; // Add validation toast
            
            toggleDropdown('period-dropdown-container');
            loadReportData('custom', start, end);
        }

        function exportReport(format) {
        const period = document.getElementById('selected-period-label').innerText.toLowerCase();
        const startDate = document.getElementById('custom-start-date').value;
        const endDate = document.getElementById('custom-end-date').value;

        let url = `/admin/salesReport/export/${format}?period=${period}`;
        if (period === 'custom' && startDate && endDate) {
        url += `&startDate=${startDate}&endDate=${endDate}`;
        }
        window.location.href = url;
        toggleDropdown('export-dropdown-container');
        }
    </script>
