<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password | BootCamp</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

    <!-- Toastify -->
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #000;
            overflow: hidden;
        }

        .glass {
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        @keyframes pulse-glow {
            0%, 100% { opacity: 0.75; }
            50% { opacity: 1; }
        }

        .animate-pulse-glow {
            animation: pulse-glow 5s infinite;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .animate-fadeIn {
            animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        /* Video Background */
        .video-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            z-index: -1;
        }

        .video-container::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.4);
        }

        video {
            min-width: 100%;
            min-height: 100%;
            object-fit: cover;
        }

        /* Custom Input focus */
        .custom-input:focus {
            border-color: rgba(147, 51, 234, 0.5);
            outline: none;
        }
    </style>
</head>

<body class="text-white min-h-screen flex items-center justify-center p-4">

    <!-- Video Background -->
   <div class="video-container" style="position:fixed; top:0; left:0; width:100%; height:100%; z-index:0;">
    <img src="/uploads/images/forgot.png" alt="" style="width:100%; height:100%; object-fit:cover;">
    </div>

    <!-- Main Container -->
    <div class="relative z-20 w-full max-w-md animate-fadeIn">
        <div class="p-8 rounded-2xl glass">
            
            <!-- Logo/Header Area -->
            <div class="mb-8 text-center">
                <h2 class="text-3xl font-bold mb-2 relative group inline-block">
                    <span class="absolute -inset-1 bg-gradient-to-r from-purple-600/30 via-pink-500/30 to-blue-500/30 blur-xl opacity-75 group-hover:opacity-100 transition-all duration-500 animate-pulse-glow"></span>
                    <span class="relative inline-block text-3xl font-black tracking-tighter text-white uppercase">
                        BootCamp
                    </span>
                </h2>
                
                <div class="mt-4 flex flex-col items-center space-y-1">
                    <h3 class="text-xl font-bold tracking-tight text-white">RESET PASSWORD</h3>
                    <p class="text-white/60 text-sm max-w-[280px] mx-auto">Enter your email to receive a password reset code.</p>
                </div>
            </div>

            <!-- Reset Form -->
            <form id="reset-form" class="space-y-6" action="/users/resetPassword" method="POST">
                
                <!-- Email Input -->
                <div class="group">
                    <div class="relative">
                        <div class="absolute left-3 top-1/2 -translate-y-1/2 text-white/40 group-focus-within:text-purple-400 transition-colors">
                            <span class="material-symbols-outlined text-[20px]">mail</span>
                        </div>
                        <input type="text" id="email" name="email" placeholder="EMAIL ADDRESS"
                            class="w-full pl-11 pr-4 py-4 bg-white/5 border border-white/10 rounded-xl text-white placeholder-white/20 custom-input transition-all duration-300 font-bold text-[13px] tracking-widest">
                    </div>
                    <p id="email-error" class="text-red-400 text-[10px] mt-2 hidden font-black uppercase tracking-[0.1em]"></p>
                </div>

                <!-- Submit Button -->
                <div class="pt-2">
                    <button type="submit" id="submit-btn"
                        class="w-full py-4 bg-purple-600 hover:bg-purple-700 text-white font-black uppercase tracking-widest text-[11px] rounded-xl transition-all duration-300 transform hover:-translate-y-1 shadow-lg shadow-purple-500/20 hover:shadow-purple-500/40 flex items-center justify-center gap-2">
                        <span id="button-text">SEND CODE</span>
                        <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                    </button>
                    
                    <div class="mt-6 flex justify-center">
                        <a href="/users/login" class="text-[10px] font-black uppercase tracking-[0.2em] text-white/40 hover:text-white transition-colors border-b border-transparent hover:border-white/20 pb-1">
                            Back to Login
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Page Footer -->
    <footer class="absolute bottom-6 left-0 right-0 text-center text-white/20 text-[10px] font-black uppercase tracking-[0.3em] z-20">
        © 2026 Boot Camp Protocol
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="/toast/toast.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Form Logic
        const form = document.getElementById('reset-form');
        const submitBtn = document.getElementById('submit-btn');
        const buttonText = document.getElementById('button-text');
        const emailInput = document.getElementById('email');
        const emailError = document.getElementById('email-error');

        function showError(msg) {
            emailError.textContent = msg;
            emailError.classList.remove('hidden');
        }

        function clearError() {
            emailError.classList.add('hidden');
        }

        emailInput.addEventListener('input', clearError);

        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const email = emailInput.value.trim();
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

            if (!email) {
                showError('Email is required');
                return;
            } else if (!emailRegex.test(email)) {
                showError('Invalid email address');
                return;
            }

            submitBtn.disabled = true;
            const originalText = buttonText.textContent;
            buttonText.textContent = 'SENDING...';

            try {
                const response = await axios.post(form.action, { email });

                if (response.data.success || response.status === 200) {
                    showToast("success", "A reset code has been sent to your email.");
                    
                    if (response.data.redirect) {
                        setTimeout(() => {
                            window.location.href = response.data.redirect;
                        }, 1500);
                    }
                } else {
                    throw new Error(response.data.message || "Code request failed");
                }
            } catch (err) {
                submitBtn.disabled = false;
                buttonText.textContent = originalText;
                const msg = err.response?.data?.message || err.message || "Neural link failure";
                showToast("error", msg);
            }
        });

        // Toast Helper
        function showToast(type, msg) {
            Toastify({
                text: msg,
                duration: 3000,
                gravity: "top",
                position: "right",
                style: {
                    background: type === "success" ? "rgba(16, 185, 129, 0.9)" : "rgba(239, 68, 68, 0.9)",
                    backdropFilter: "blur(10px)",
                    borderRadius: "12px",
                    fontSize: "12px",
                    fontWeight: "900",
                    textTransform: "uppercase",
                    letterSpacing: "0.1em",
                    border: "1px solid rgba(255,255,255,0.1)"
                }
            }).showToast();
        }
    </script>
</body>

</html>
