<!DOCTYPE html>
<html class="light" lang="en">

<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <link
        href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Inter:wght@300;400;500;600;700&amp;display=swap"
        rel="stylesheet">
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet">
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-primary-fixed-variant": "#e2e2e2",
                        "surface-container-highest": "#e2e2e2",
                        "surface": "#f9f9f9",
                        "secondary": "#5f5e5e",
                        "on-primary-fixed": "#ffffff",
                        "surface-container-low": "#f3f3f3",
                        "surface-container": "#eeeeee",
                        "outline-variant": "#c6c6c6",
                        "on-tertiary-fixed-variant": "#e2e2e2",
                        "surface-container-lowest": "#ffffff",
                        "surface-container-high": "#e8e8e8",
                        "inverse-on-surface": "#f1f1f1",
                        "on-secondary-fixed": "#1b1c1c",
                        "on-primary": "#e2e2e2",
                        "on-tertiary": "#e2e2e2",
                        "on-secondary": "#ffffff",
                        "secondary-fixed": "#c8c6c6",
                        "inverse-primary": "#c6c6c6",
                        "surface-tint": "#5e5e5e",
                        "primary-container": "#3b3b3b",
                        "tertiary": "#3b3b3b",
                        "tertiary-container": "#747474",
                        "surface-variant": "#e2e2e2",
                        "on-error": "#ffffff",
                        "on-tertiary-container": "#ffffff",
                        "surface-bright": "#f9f9f9",
                        "primary-fixed": "#5e5e5e",
                        "inverse-surface": "#2f3131",
                        "on-secondary-fixed-variant": "#3b3b3b",
                        "background": "#f9f9f9",
                        "on-primary-container": "#ffffff",
                        "on-error-container": "#410002",
                        "primary": "#000000",
                        "tertiary-fixed": "#5e5e5e",
                        "on-surface-variant": "#474747",
                        "on-secondary-container": "#1b1c1c",
                        "surface-dim": "#dadada",
                        "secondary-fixed-dim": "#acabab",
                        "outline": "#777777",
                        "on-tertiary-fixed": "#ffffff",
                        "error": "#ba1a1a",
                        "tertiary-fixed-dim": "#474747",
                        "on-surface": "#1a1c1c",
                        "error-container": "#ffdad6",
                        "primary-fixed-dim": "#474747",
                        "secondary-container": "#d6d4d3",
                        "on-background": "#1a1c1c"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "fontFamily": {
                        "headline": ["Space Grotesk"],
                        "body": ["Inter"],
                        "label": ["Inter"]
                    }
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .split-screen-container {
            height: 100vh;
            display: flex;
        }

        .hero-panel {
            flex: 1;
            position: relative;
            background-size: cover;
            background-position: center;
            overflow: hidden;
        }

        .form-panel {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 3rem;
        }

        /* Entrance Animations */
        @keyframes slideInFromLeft {
            0% {
                transform: translateX(-150%);
                opacity: 0;
            }

            80% {
                transform: translateX(10%);
                opacity: 1;
            }

            100% {
                transform: translateX(0);
                opacity: 1;
            }
        }

        .subtitle-anim {
            opacity: 0;
            animation: slideInFromLeft 1s cubic-bezier(0.25, 1, 0.5, 1) forwards;
        }

        @keyframes dropInFromTop {
            0% {
                opacity: 0;
                transform: translateY(-80px);
            }

            60% {
                opacity: 1;
                transform: translateY(10px);
            }

            80% {
                transform: translateY(-5px);
            }

            100% {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .letter {
            display: inline-block;
            opacity: 0;
            animation: dropInFromTop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        }

        @media (max-width: 768px) {
            .split-screen-container {
                flex-direction: column;
            }

            .hero-panel {
                height: 40vh;
                flex: none;
            }

            .form-panel {
                height: 60vh;
                flex: none;
            }
        }
    </style>
</head>

<body class="bg-surface font-body text-on-surface antialiased">
    <!-- Main Content Shell -->
    <main class="split-screen-container">
        <!-- Left Side: Hero Panel -->
        <section class="hero-panel"
            data-alt="close-up profile of a high-performance carbon fiber football boot on a dark stadium pitch under dramatic spotlighting with moody atmosphere">
            <!-- Animated Background Layer -->
            <div class="absolute inset-0 bg-cover bg-center z-0"
                style="background-image: url(&quot;https://lh3.googleusercontent.com/aida-public/AB6AXuBiB4pVEKofBWKSInCzZvKQCvEePNTLbsW4gkHHcWby4D-IdH6LzVr3OdPDzMdXp6tj4TVhIYA57eqHgMhKrrGFZ-jQmNqYR3TLqqTCqW54z62nBZ9HeJ05gl9sV0E5hE0fZNwWQ2YoWJzr1YFN8OdanP9bTaQieDJ5ISR29hSaWzDmwaMZAMGUP7pUg1aFqqmn3LYnUCwcru_DRmIsuQ27CNGd7KaZROhwj_DTJ4XOnDcvQILVh3gSIAxZnNGJICVC-tQDnl46ttg&quot;);">
            </div>

            <!-- Dark Gradient Overlay -->
            <div
                class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/40 to-transparent flex flex-col justify-center px-12 md:px-24 z-10">
                <div class="space-y-2">
                    <h1 class="font-headline font-black text-6xl md:text-8xl text-white tracking-tighter uppercase leading-none"
                        style="">
                        <span class="letter">B</span><span class="letter">O</span><span class="letter">O</span><span
                            class="letter">T</span>&nbsp;<span class="letter">C</span><span class="letter">A</span><span
                            class="letter">M</span><span class="letter">P</span>
                    </h1>
                    <p class="subtitle-anim font-headline font-bold text-xl tracking-[0.4em] text-on-primary uppercase"
                        style="">
                        STEP INTO PERFORMANCE
                    </p>
                </div>
            </div>
            <!-- Branding Anchor for Mobile consistency -->
            <div class="absolute bottom-8 left-12 block md:hidden z-10">
                <div class="h-1 w-12 bg-white mb-4"></div>
            </div>
        </section>
        <!-- Right Side: Form Panel -->
        <section class="form-panel bg-surface-container-lowest">
            <div class="w-full max-w-md space-y-12">
                <div class="space-y-4">
                    <h2 class="font-headline font-bold text-4xl text-primary tracking-tighter uppercase" style="">
                        RESET PASSWORD
                    </h2>
                    <p class="text-on-surface-variant font-body text-sm leading-relaxed max-w-xs" style="">
                        Enter your email to receive a password reset code.
                    </p>
                </div>
                <form class="space-y-8" action="/users/resetPassword" method="post">
                    <div class="group">
                        <input
                            class="w-full text-[14px] bg-transparent border-0 border-b-2 border-outline-variant py-0 px-0 text-primary placeholder:text-outline focus:ring-0 focus:border-primary transition-all duration-300 font-body"
                            id="email" name="email" placeholder="EMAIL" type="text">
                        <p id="email-error" class="text-error text-[11px] mt-1 hidden"></p>
                    </div>
                    <div class="pt-4 space-y-6">
                        <button
                            class="w-full bg-primary text-on-primary py-5 px-8 font-label text-xs font-bold tracking-[2px] uppercase rounded-md hover:bg-primary-container active:scale-[0.98] transition-all duration-300 flex items-center justify-center gap-3"
                            type="submit" style="">
                            <span id="button-text">SEND CODE</span>
                            <span class="material-symbols-outlined text-sm" style="">arrow_forward</span>
                        </button>
                        <div class="flex flex-col items-center gap-4">
                            <a class="font-label text-[11px] font-semibold tracking-widest text-primary hover:text-secondary transition-colors uppercase border-b border-transparent hover:border-primary pb-1"
                                href="/users/login" style="">
                                Back to Login
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </section>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="/toast/toast.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Entrance Animation Logic
        document.addEventListener("DOMContentLoaded", () => {
            const letters = document.querySelectorAll('.letter');
            const subtitleDuration = 1000;
            const delayBetweenLetters = 100;
            letters.forEach((span, index) => {
                span.style.animationDelay = `${subtitleDuration + (index * delayBetweenLetters)}ms`;
            });
        });

        // Error Handling Helper Functions
        function showError(id, message) {
            const errorElement = document.getElementById(`${id}-error`);
            if (errorElement) {
                errorElement.textContent = message;
                errorElement.classList.remove('hidden');
            }
        }

        function clearError(id) {
            const errorElement = document.getElementById(`${id}-error`);
            if (errorElement) {
                errorElement.textContent = '';
                errorElement.classList.add('hidden');
            }
        }

        // Form Submission Logic
        document.addEventListener("DOMContentLoaded", () => {
            const form = document.querySelector("form");
            const emailInput = document.getElementById('email');

            emailInput.addEventListener('input', () => clearError('email'));

            form.addEventListener("submit", async function (e) {
                e.preventDefault();

                const email = emailInput.value.trim();
                const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

                clearError('email');

                if (!email) {
                    showError('email', 'Email is required');
                    return;
                } else if (!emailRegex.test(email)) {
                    showError('email', 'Invalid email address');
                    return;
                }

                const submitBtn = form.querySelector('button[type="submit"]');
                const buttonText = document.getElementById('button-text');
                const originalText = buttonText.textContent;

                try {
                    submitBtn.disabled = true;
                    buttonText.textContent = 'SENDING...';

                    const response = await axios.post(form.action, { email });

                    if (response.data.success || response.status === 200) {
                        showToast('success', 'A reset code has been sent to your email.');
                        // Redirect to OTP page (if backend provides URL) or refresh
                        if (response.data.redirect) {
                            setTimeout(() => {
                                window.location.href = response.data.redirect;
                            }, 1000);
                        }
                    } else {
                        throw new Error(response.data.message || 'Error sending code');
                    }

                } catch (error) {
                    const message = error.response?.data?.message || error.message || 'Something went wrong.';
                    showToast('error', message);
                } finally {
                    submitBtn.disabled = false;
                    buttonText.textContent = originalText;
                }
            });
        });
    </script>
</body>

</html>