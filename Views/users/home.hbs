                    </button>
                </div>
                <h3 class="text-xs font-bold uppercase tracking-tight mb-2">PHANTOM LUNA II ELITE</h3>
                <div class="flex justify-between items-center">
                    <p class="text-xs text-gray-500">$250.00</p>
                    <span class="material-symbols-outlined text-sm text-gray-300">favorite</span>
                </div>
            </div>
            <!-- Product 2 -->
            <div class="group cursor-pointer">
                <div class="bg-black aspect-square flex items-center justify-center mb-6 relative overflow-hidden">
                    <img src="images/boot_arrival_1.png" alt="Product"
                        class="w-48 h-48 object-contain filter hue-rotate-[60deg] transition-transform group-hover:scale-110">
                    <button
                        class="absolute bottom-4 right-4 bg-white text-black p-2 opacity-0 group-hover:opacity-100 transition-opacity">
                        <span class="material-symbols-outlined text-sm">add</span>
                    </button>
                </div>
                <h2 class="text-xs font-bold uppercase tracking-tight mb-2">MERCURIAL SUPERFLY 9</h2>
                <div class="flex justify-between items-center">
                    <p class="text-xs text-gray-500">$275.00</p>
                    <span class="material-symbols-outlined text-sm text-gray-300">favorite</span>
                </div>
            </div>
            <!-- Product 3 -->
            <div class="group cursor-pointer">
                <div class="bg-black aspect-square flex items-center justify-center mb-6 relative overflow-hidden">
                    <img src="images/boot_arrival_1.png" alt="Product"
                        class="w-48 h-48 object-contain filter hue-rotate-[120deg] transition-transform group-hover:scale-110">
                    <button
                        class="absolute bottom-4 right-4 bg-white text-black p-2 opacity-0 group-hover:opacity-100 transition-opacity">
                        <span class="material-symbols-outlined text-sm">add</span>
                    </button>
                </div>
                <h3 class="text-xs font-bold uppercase tracking-tight mb-2">PREDATOR ELITE FT</h3>
                <div class="flex justify-between items-center">
                    <p class="text-xs text-gray-500">$260.00</p>
                    <span class="material-symbols-outlined text-sm text-gray-300">favorite</span>
                </div>
            </div>
            <!-- Product 4 -->
            <div class="group cursor-pointer">
                <div class="bg-black aspect-square flex items-center justify-center mb-6 relative overflow-hidden">
                    <img src="images/boot_arrival_1.png" alt="Product"
                        class="w-48 h-48 object-contain filter hue-rotate-[240deg] transition-transform group-hover:scale-110">
                    <button
                        class="absolute bottom-4 right-4 bg-white text-black p-2 opacity-0 group-hover:opacity-100 transition-opacity">
                        <span class="material-symbols-outlined text-sm">add</span>
                    </button>
                </div>
                <h3 class="text-xs font-bold uppercase tracking-tight mb-2">X CRAZYFAST.1 FG</h3>
                <div class="flex justify-between items-center">
                    <p class="text-xs text-gray-500">$240.00</p>
                    <span class="material-symbols-outlined text-sm text-gray-300">favorite</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Best Sellers -->
    <section class="py-24 px-6 md:px-12 max-w-[1800px] mx-auto overflow-hidden">
        <div class="flex justify-between items-end mb-12">
            <h2 class="font-sans font-black text-4xl uppercase tracking-tighter">Best Sellers</h2>
            <a href="#"
                class="text-[10px] font-bold tracking-[0.2em] uppercase border-b border-black pb-1 hover:text-gray-500 hover:border-gray-500 transition-colors">View
                All</a>
        </div>

        <div class="flex flex-col lg:flex-row gap-8">
            <!-- Large Featured Card -->
            <div class="lg:w-1/3 bg-black text-white p-12 flex flex-col justify-between aspect-[4/5] scroll-reveal">
                <div class="h-1 bg-white w-24 mb-12"></div>
                <div>
                    <h3 class="font-sans font-black text-4xl uppercase tracking-tighter leading-none mb-4">MASTERY FG
                        <br> GOLD EDITION
                    </h3>
                    <p class="text-gray-400 text-xs mb-8">The pinnacle of performance gear, handcrafted for champions
                        globally.</p>
                    <button
                        class="bg-white text-black px-8 py-3 text-[10px] font-bold tracking-[0.2em] uppercase hover:bg-gray-200 transition-colors">Shop
                        Now</button>
                </div>
            </div>

            <!-- Grid Scroll -->
            <div class="lg:w-2/3 grid grid-cols-2 md:grid-cols-3 gap-6">
                <!-- Product 1 -->
                <div
                    class="bg-[#f6f6f6] p-8 flex flex-col justify-between group cursor-pointer hover:bg-gray-100 transition-colors">
                    <div class="flex-grow flex items-center justify-center">
                        <img src="images/boot_arrival_1.png" alt="Boot"
                            class="w-40 h-40 object-contain group-hover:scale-110 transition-transform">
                    </div>
                    <div>
                        <h4 class="text-[10px] font-bold uppercase mb-1">LEGEND 10 ELITE</h4>
                        <p class="text-[10px] text-gray-500">$290.00</p>
                    </div>
                </div>
                <!-- Product 2 -->
                <div
                    class="bg-[#f6f6f6] p-8 flex flex-col justify-between group cursor-pointer hover:bg-gray-100 transition-colors">
                    <div class="flex-grow flex items-center justify-center">
                        <img src="images/hero_boot.png" alt="Boot"
                            class="w-40 h-40 object-contain filter brightness-[0.8] grayscale group-hover:scale-110 transition-transform">
                    </div>
                    <div>
                        <h4 class="text-[10px] font-bold uppercase mb-1">COPA PURE 2 ELITE</h4>
                        <p class="text-[10px] text-gray-500">$280.00</p>
                    </div>
                </div>
                <!-- Product 3 -->
                <div
                    class="bg-[#f6f6f6] p-8 flex flex-col justify-between group cursor-pointer hover:bg-gray-100 transition-colors">
                    <div class="flex-grow flex items-center justify-center">
                        <img src="images/boot_arrival_1.png" alt="Boot"
