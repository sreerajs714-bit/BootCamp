<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BOOT CAMP | Dominate The Game</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;600;800;900&display=swap"
        rel="stylesheet">
    <!-- Material Symbols -->
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20,300,0,0" />

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        display: ['Outfit', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            50: '#f9f9f9',
                            100: '#f2f2f2',
                            500: '#666666',
                            800: '#333333',
                            900: '#1a1a1a',
                            950: '#000000',
                        }
                    },
                    animation: {
                        'reveal': 'reveal 1.2s cubic-bezier(0.77, 0, 0.175, 1) forwards',
                        'reveal-up': 'revealUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards',
                    },
                    keyframes: {
                        reveal: {
                            '0%': { transform: 'scale(1.1)', opacity: '0' },
                            '100%': { transform: 'scale(1)', opacity: '1' },
                        },
                        revealUp: {
                            '0%': { transform: 'translateY(40px)', opacity: '0' },
                            '100%': { transform: 'translateY(0)', opacity: '1' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        @layer base {
            body {
                @apply bg-white text-black font-sans antialiased overflow-x-hidden;
            }
        }

        .nav-item {
            @apply relative text-[11px] font-bold tracking-[0.2em] uppercase transition-colors duration-300 hover:text-gray-500;
        }

        /* ── Navbar colour states ───────────────────────────── */
        #main-navbar.nav-transparent {
            background-color: transparent;
            border-color: transparent;
            box-shadow: none;
        }

        #main-navbar.nav-transparent .nav-logo,
        #main-navbar.nav-transparent nav a,
        #main-navbar.nav-transparent .icon-btn .material-symbols-outlined {
            color: #ffffff;
        }

        #main-navbar.nav-transparent .nav-login-btn {
            background-color: #ffffff;
            color: #000000;
        }

        #main-navbar.nav-scrolled {
            background-color: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid #e5e5e5;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        #main-navbar.nav-scrolled .nav-logo,
        #main-navbar.nav-scrolled nav a,
        #main-navbar.nav-scrolled .icon-btn .material-symbols-outlined {
            color: #000000;
        }

        #main-navbar.nav-scrolled .nav-login-btn {
            background-color: #000000;
            color: #ffffff;
        }

        /* Search Bar Glass Effect & Animation */
        #search-container {
            backdrop-filter: blur(12px);
            background-color: rgba(255, 255, 255, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.1);
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        #main-navbar.nav-scrolled #search-container {
            background-color: rgba(0, 0, 0, 0.05);
            border: 1px solid rgba(0, 0, 0, 0.1);
        }

        #search-container.search-active {
            width: 380px;
            opacity: 1;
            padding-left: 1.25rem;
            padding-right: 0.75rem;
            margin-right: -4px;
        }

        /* Hide trigger icon when search is open */
        .search-open-state #search-trigger {
            display: none;
        }

        .badge {
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .hero-title {
            @apply font-display font-black text-6xl md:text-7xl lg:text-8xl leading-[0.9] tracking-tighter uppercase;
        }

        .section-title {
            @apply font-display font-black text-2xl md:text-3xl tracking-tighter uppercase mb-8;
        }

        .collection-card {
            @apply relative aspect-[4/5] overflow-hidden group cursor-pointer;
        }

        .collection-img {
            @apply w-full h-full object-cover transition-transform duration-700 group-hover:scale-110;
        }

        .product-card {
            @apply group cursor-pointer;
        }

        .product-img-container {
            @apply aspect-square bg-[#f6f6f6] flex items-center justify-center mb-4 transition-all duration-500 group-hover:bg-[#efefef];
        }

        .brand-logo {
            @apply grayscale opacity-30 transition-all duration-300 hover:grayscale-0 hover:opacity-100;
        }

        .scroll-reveal {
            opacity: 0;
            transform: translateY(20px);
            transition: all 1s ease-out;
        }

        .scroll-reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: #f1f1f1;
        }

        ::-webkit-scrollbar-thumb {
            background: #ccc;
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #999;
        }
    </style>
</head>

<body>

    <!-- Navigation -->
