<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BOOT CAMP | Dominate The Game</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;600;800;900&display=swap"
        rel="stylesheet">
    <!-- Material Symbols -->
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20,300,0,0" />

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        display: ['Outfit', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            50: '#f9f9f9',
                            100: '#f2f2f2',
                            500: '#666666',
                            800: '#333333',
                            900: '#1a1a1a',
                            950: '#000000',
                        }
                    },
                    animation: {
                        'reveal': 'reveal 1.2s cubic-bezier(0.77, 0, 0.175, 1) forwards',
                        'reveal-up': 'revealUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards',
                    },
                    keyframes: {
                        reveal: {
                            '0%': { transform: 'scale(1.1)', opacity: '0' },
                            '100%': { transform: 'scale(1)', opacity: '1' },
                        },
                        revealUp: {
                            '0%': { transform: 'translateY(40px)', opacity: '0' },
                            '100%': { transform: 'translateY(0)', opacity: '1' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        @layer base {
            body {
                @apply bg-white text-black font-sans antialiased overflow-x-hidden;
            }
        }

        .nav-item {
            @apply relative text-[11px] font-bold tracking-[0.2em] uppercase transition-colors duration-300 hover:text-gray-500;
        }

        /* ── Navbar colour states ───────────────────────────── */
        /* Transparent (at top) → white text & icons */
        #main-navbar.nav-transparent .nav-logo,
        #main-navbar.nav-transparent .nav-link,
        #main-navbar.nav-transparent .nav-icons,
        #main-navbar.nav-transparent .nav-icons .material-symbols-outlined {
            color: #ffffff;
        }
        #main-navbar.nav-transparent .nav-login {
            background: #ffffff;
            color: #000000;
        }
        #main-navbar.nav-transparent .nav-login:hover {
            background: #e5e5e5;
        }
        /* Cart badge border matches background */
        #main-navbar.nav-transparent .cart-badge {
            border-color: transparent;
        }

        /* Scrolled (white bg) → black text & icons */
        #main-navbar.nav-scrolled .nav-logo,
        #main-navbar.nav-scrolled .nav-link,
        #main-navbar.nav-scrolled .nav-icons,
        #main-navbar.nav-scrolled .nav-icons .material-symbols-outlined {
            color: #000000;
        }
        #main-navbar.nav-scrolled .nav-login {
            background: #000000;
            color: #ffffff;
        }
        #main-navbar.nav-scrolled .nav-login:hover {
            background: #333333;
        }

        .hero-title {
            @apply font-display font-black text-6xl md:text-7xl lg:text-8xl leading-[0.9] tracking-tighter uppercase;
        }

        .section-title {
            @apply font-display font-black text-2xl md:text-3xl tracking-tighter uppercase mb-8;
        }

        .collection-card {
            @apply relative aspect-[4/5] overflow-hidden group cursor-pointer;
        }

        .collection-img {
            @apply w-full h-full object-cover transition-transform duration-700 group-hover:scale-110;
        }

        .product-card {
            @apply group cursor-pointer;
        }

        .product-img-container {
            @apply aspect-square bg-[#f6f6f6] flex items-center justify-center mb-4 transition-all duration-500 group-hover:bg-[#efefef];
        }

        .brand-logo {
            @apply grayscale opacity-30 transition-all duration-300 hover:grayscale-0 hover:opacity-100;
        }

        .scroll-reveal {
            opacity: 0;
            transform: translateY(20px);
            transition: all 1s ease-out;
        }

        .scroll-reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: #f1f1f1;
        }

        ::-webkit-scrollbar-thumb {
            background: #ccc;
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #999;
        }
    </style>
</head>

<body>

    <!-- Navigation -->
    <header id="main-navbar"
        class="nav-transparent w-full bg-transparent fixed top-0 z-50 border-b border-transparent transition-all duration-300">
        <div class="max-w-7xl mx-auto px-6 h-24 flex items-center justify-between">

            <!-- Logo -->
            <div class="flex-shrink-0 cursor-pointer group">
                <h1 class="nav-logo font-display font-black text-3xl tracking-tighter uppercase transition-all duration-300 group-hover:scale-105">
                    BOOT<span class="font-light">CAMP</span>
                </h1>
            </div>

            <!-- Menu Items (Desktop) -->
            <nav class="hidden lg:flex items-center space-x-12 font-medium text-[15px] tracking-wide">
                <a href="#" class="nav-link font-semibold transition-colors duration-300">Home</a>
                <a href="/users/mens" class="nav-link transition-colors duration-300">Men</a>
                <a href="#" class="nav-link transition-colors duration-300">Women</a>
            </nav>

            <!-- Icons -->
            <div class="nav-icons flex items-center space-x-7 transition-colors duration-300">
                <button class="icon-btn" aria-label="Search">
                    <span class="material-symbols-outlined font-light text-[28px] transition-colors duration-300">search</span>
                </button>
                <button class="icon-btn" aria-label="Wishlist">
                    <span class="material-symbols-outlined font-light text-[28px] transition-colors duration-300">favorite</span>
                </button>
                <button class="icon-btn relative" aria-label="Cart">
                    <span class="material-symbols-outlined font-light text-[28px] transition-colors duration-300">shopping_bag</span>
                    <!-- Cart Badge -->
                    <span class="cart-badge absolute -top-1 -right-1 bg-black text-white text-[10px] font-bold w-4.5 h-4.5 p-1 rounded-full flex items-center justify-center border-2 border-white box-content">2</span>
                </button>
                {{#if user}}
                <button class="icon-btn" aria-label="Profile">
                    <a href="/users/profile">
                        <span class="material-symbols-outlined font-light text-[28px] transition-colors duration-300">person</span>
                    </a>
                </button>
                {{else}}
                <a href="/users/login"
                    class="nav-login px-6 py-2.5 text-[15px] font-medium rounded-full transition-all duration-300">
                    Login
                </a>
                {{/if}}
            </div>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="relative pt-16 min-h-[100vh] bg-black text-white overflow-hidden flex items-center justify-center">
        <!-- Background Image overlay -->
        <div class="absolute inset-0 z-0 overflow-hidden">
            <video autoplay muted loop playsinline class="w-full h-full object-cover opacity-30">
                <source src="/uploads/video/shoes.mp4" type="video/mp4">
            </video>
        </div>

        <div class="relative z-10 text-center px-6 max-w-3xl">
            <h1
                class="font-sans font-black text-6xl md:text-8xl leading-none tracking-tighter uppercase mb-6 animate-reveal-up">
                DOMINATE <br> THE GAME</h1>
            <p class="text-gray-300 text-sm md:text-base font-medium tracking-wide mb-10 max-w-xl mx-auto animate-reveal-up"
                style="animation-delay: 0.2s;">
                Premium Football Boots Collection engineered for ultimate speed and precision.
            </p>
        </div>
    </section>

    <!-- Collections / Shop By Category -->
    <section class="py-24 px-6 md:px-12 max-w-4xl mx-auto text-center">
        <p class="text-[10px] text-gray-400 font-bold tracking-[0.4em] uppercase mb-4">CURATED COLLECTION</p>
        <h2 class="font-sans font-black text-3xl md:text-4xl text-center uppercase tracking-tighter mb-16">Shop By
            Category</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 lg:gap-16">
            <!-- Men Category -->
            <div
                class="group relative flex items-center justify-center aspect-square bg-[#f5f5f5]  overflow-hidden cursor-pointer transition-all duration-500">
                <img src="https://i.pinimg.com/736x/33/e8/8b/33e88b8a41302cc44adba3b6023a3843.jpg"
                    alt="Men's Collection"
                    class="w-[75%] h-[75%] object-contain transition-all duration-700 group-hover:scale-110 group-hover:blur-[4px]">
                <div
                    class="absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition-all duration-500 flex items-center justify-center backdrop-blur-[2px]">
                    <span
                        class="text-white font-sans font-black text-3xl lg:text-4xl tracking-[0.2em] uppercase drop-shadow-2xl">MEN</span>
                </div>
            </div>

            <!-- Women Category -->
            <div
                class="group relative flex items-center justify-center aspect-square bg-[#f5f5f5]  overflow-hidden cursor-pointer transition-all duration-500">
                <img src="https://i.pinimg.com/1200x/df/b0/f1/dfb0f1cf2d6ca98cb481b96093227546.jpg"
                    alt="Women's Collection"
                    class="w-[75%] h-[75%] object-contain transition-all duration-700 group-hover:scale-110 group-hover:blur-[4px]">
                <div
                    class="absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition-all duration-500 flex items-center justify-center backdrop-blur-[2px]">
                    <span
                        class="text-white font-sans font-black text-3xl lg:text-4xl tracking-[0.2em] uppercase drop-shadow-2xl">WOMEN</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Shop By Brand -->
    <section class="py-18 bg-white text-center">
        <div class="max-w-7xl mx-auto px-6">
            <p class="text-[10px] text-gray-400 font-bold tracking-[0.4em] uppercase mb-4">ENGINEERED ALLIANCES</p>
            <h2 class="font-sans font-black text-4xl uppercase tracking-tighter mb-16">Shop By Brand</h2>

            <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-8">
