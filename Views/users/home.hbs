                    </div>
                </div>

                <!-- Categories -->
                <div>
                    <h4 class="text-[11px] font-bold tracking-[0.2em] uppercase mb-8">CATEGORIES</h4>
                    <ul class="space-y-4">
                        <li><a href="#"
                                class="text-[13px] text-gray-400 hover:text-black transition-colors underline decoration-gray-300 underline-offset-4">Men</a>
                        </li>
                        <li><a href="#"
                                class="text-[13px] text-gray-400 hover:text-black transition-colors underline decoration-gray-300 underline-offset-4">Women</a>
                        </li>
                        <li><a href="#"
                                class="text-[13px] text-gray-400 hover:text-black transition-colors underline decoration-gray-300 underline-offset-4">Limited
                                Edition</a></li>
                        <li><a href="#"
                                class="text-[13px] text-gray-400 hover:text-black transition-colors underline decoration-gray-300 underline-offset-4">Brands</a>
                        </li>
                    </ul>
                </div>

                <!-- Support -->
                <div>
                    <h4 class="text-[11px] font-bold tracking-[0.2em] uppercase mb-8">SUPPORT</h4>
                    <ul class="space-y-4">
                        <li><a href="#" class="text-[13px] text-gray-400 hover:text-black transition-colors">Shipping
                                Info</a></li>
                        <li><a href="#" class="text-[13px] text-gray-400 hover:text-black transition-colors">Returns &
                                Exchanges</a></li>
                        <li><a href="#" class="text-[13px] text-gray-400 hover:text-black transition-colors">Size
                                Guide</a></li>
                        <li><a href="#" class="text-[13px] text-gray-400 hover:text-black transition-colors">Track
                                Order</a></li>
                    </ul>
                </div>

                <!-- Social -->
