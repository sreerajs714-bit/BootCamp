<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BOOT CAMP | Premium Football Gear</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;600;800;900&display=swap" rel="stylesheet">
    <!-- Material Symbols -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,300,0,0" />
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        display: ['Outfit', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            50: '#f6f6f6',
                            100: '#e7e7e7',
                            200: '#d1d1d1',
                            300: '#b0b0b0',
                            400: '#888888',
                            500: '#6d6d6d',
                            600: '#5d5d5d',
                            700: '#4f4f4f',
                            800: '#454545',
                            900: '#3d3d3d',
                            950: '#000000',
                        }
                    },
                    animation: {
                        'fade-in-up': 'fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards',
                        'fade-in': 'fadeIn 1.5s ease-out forwards',
                        'float': 'float 8s ease-in-out infinite',
                    },
                    keyframes: {
                        fadeInUp: {
                            '0%': { opacity: '0', transform: 'translateY(30px)' },
                            '100%': { opacity: '1', transform: 'translateY(0)' },
                        },
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' },
                        },
                        float: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-15px)' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #ffffff;
            color: #000000;
            overflow-x: hidden;
        }
        
        /* Custom underline hover for nav items */
        .nav-link {
            position: relative;
            padding-bottom: 4px;
            transition: color 0.3s ease;
        }
        
        .nav-link::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: 0;
            left: 50%;
            background-color: #000000;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            transform: translateX(-50%);
        }
        
        .nav-link:hover::after {
            width: 100%;
        }

        .icon-btn {
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), color 0.2s ease;
        }
        
        .icon-btn:hover {
            transform: scale(1.15);
            color: #5d5d5d;
        }
        
        .hero-bg {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 100%;
            max-width: 1000px;
            opacity: 0.04; /* Extremely subtle premium effect */
            z-index: -1;
            pointer-events: none;
            mix-blend-mode: multiply;
            filter: grayscale(100%);
        }
        
        /* Staggered animation delays */
        .stagger-1 { animation-delay: 0.1s; opacity: 0; }
        .stagger-2 { animation-delay: 0.25s; opacity: 0; }
        .stagger-3 { animation-delay: 0.4s; opacity: 0; }
        .stagger-4 { animation-delay: 0.55s; opacity: 0; }
        
        /* Stylish Logout Button Hover */
        .btn-logout {
            position: relative;
            overflow: hidden;
            z-index: 1;
        }
        .btn-logout::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background-color: #f3f4f6; /* Tailwind gray-100 */
            z-index: -1;
            transform: scaleX(0);
            transform-origin: right;
            transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .btn-logout:hover::before {
            transform: scaleX(1);
            transform-origin: left;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col font-sans selection:bg-brand-950 selection:text-white">

    <!-- Navigation -->
    <header class="w-full bg-white/90 backdrop-blur-md sticky top-0 z-50 border-b border-gray-100 animate-fade-in transition-all duration-300">
        <div class="max-w-7xl mx-auto px-6 h-24 flex items-center justify-between">
            
            <!-- Logo -->
            <div class="flex-shrink-0 cursor-pointer group">
                <h1 class="font-display font-black text-3xl tracking-tighter uppercase transition-transform duration-500 group-hover:scale-105">
                    BOOT<span class="text-brand-400 font-light">CAMP</span>
                </h1>
            </div>

            <!-- Menu Items (Desktop) -->
            <nav class="hidden lg:flex items-center space-x-12 font-medium text-[15px] text-brand-500 tracking-wide">
                <a href="#" class="nav-link text-black font-semibold">Home</a>
                <a href="#" class="nav-link hover:text-black">Categories</a>
                <a href="#" class="nav-link hover:text-black">Brand</a>
                <a href="#" class="nav-link hover:text-black">New Arrivals</a>
                <a href="#" class="nav-link text-red-600 hover:text-red-700">Limited Edition</a>
            </nav>

            <!-- Icons -->
            <div class="flex items-center space-x-7 text-brand-900">
                <button class="icon-btn" aria-label="Search">
                    <span class="material-symbols-outlined font-light text-[28px]">search</span>
                </button>
                <button class="icon-btn" aria-label="Wishlist">
                    <span class="material-symbols-outlined font-light text-[28px]">favorite</span>
                </button>
                <button class="icon-btn relative" aria-label="Cart">
                    <span class="material-symbols-outlined font-light text-[28px]">shopping_bag</span>
                    <!-- Cart Badge -->
                    <span class="absolute -top-1 -right-1 bg-black text-white text-[10px] font-bold w-4.5 h-4.5 p-1 rounded-full flex items-center justify-center border-2 border-white box-content">2</span>
                </button>
                {{#if user}}
                <button class="icon-btn" aria-label="Profile">
                    <a href="/users/profile">
                    <span class="material-symbols-outlined font-light text-[28px]">person</span>
                    </a>
                </button>
                {{else}}
                <a href="/users/login" class="px-6 py-2.5 text-[15px] font-medium text-white bg-black rounded-full hover:bg-brand-800 transition-all duration-300">
                   Login
                </a>
             {{/if}}
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow flex items-center justify-center relative px-6 py-24 sm:py-32 overflow-hidden">
        
        <!-- Faded Background Image (Generated) -->
        <img src="images/boot_bg.png" alt="" class="hero-bg animate-float" onerror="this.style.display='none'">

        <div class="text-center max-w-4xl mx-auto z-10 w-full">
            <!-- Username Heading -->
            {{#if user}}
            <h2 class="font-display font-extrabold text-6xl sm:text-7xl md:text-8xl lg:text-9xl tracking-tighter mb-8 animate-fade-in-up stagger-1 leading-tight text-brand-950">
                Welcome <br class="md:hidden"><span class="text-transparent bg-clip-text bg-gradient-to-r from-gray-900 via-gray-600 to-gray-400">{{user.username}}</span>
            </h2>
            {{else}}
            <h2 class="font-display font-extrabold text-6xl sm:text-7xl md:text-8xl lg:text-9xl tracking-tighter mb-8 animate-fade-in-up stagger-1 leading-tight text-brand-950">
                Welcome 
            </h2>
            {{/if}}

            <!-- Subtext -->
            <div class="space-y-4 mb-16">
                <p class="text-xl sm:text-2xl md:text-3xl text-brand-800 font-light tracking-wide animate-fade-in-up stagger-2">
                    Welcome back to BOOT CAMP
                </p>
                <p class="text-lg sm:text-xl text-brand-400 font-light animate-fade-in-up stagger-3">
                    Ready to explore premium football gear?
                </p>
            </div>
        </div>
    </main>

</body>
</html>
