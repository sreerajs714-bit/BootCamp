        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-[#f9f9f9] pt-24 pb-12 px-6 md:px-12 border-t border-gray-100">
        <div class="max-w-[1800px] mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-24">
                <!-- Brand Info -->
                <div class="md:col-span-1">
                    <h3 class="font-sans font-black text-2xl tracking-tighter uppercase mb-8">BOOT CAMP</h3>
                    <div class="space-y-1">
                        <p class="text-[11px] text-gray-400 font-medium tracking-widest uppercase">© 2026 BOOT CAMP.</p>
                        <p class="text-[11px] text-gray-400 font-medium tracking-widest uppercase">ENGINEERED FOR
