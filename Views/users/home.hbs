    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const navbar = document.getElementById("main-navbar");

            function updateNavbar() {
                if (window.scrollY > 50) {
                    navbar.classList.remove("nav-transparent");
                    navbar.classList.add("nav-scrolled");
                } else {
                    navbar.classList.remove("nav-scrolled");
                    navbar.classList.add("nav-transparent");
                }
            }
            window.addEventListener("scroll", updateNavbar);
            updateNavbar();

            window.toggleSearch = function () {
                const container = document.getElementById('search-container');
                const header = document.getElementById('main-navbar');
                const input = document.getElementById('search-input');
                container.classList.toggle('search-active');
                header.classList.toggle('search-open-state');
                if (container.classList.contains('search-active')) {
                    setTimeout(() => input.focus(), 300);
                } else {
                    input.value = '';
                }
            }

            // Scroll reveal
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('active'); });
            }, { threshold: 0.1 });
            document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));

            // ── Image carousel for product cards ──────────────────
            window.startCarousel = function (card) {
                const imgs = card.querySelectorAll('.home-carousel-img');
                if (imgs.length <= 1) return;
                let idx = 0;
                card._carouselInterval = setInterval(() => {
                    imgs[idx].classList.remove('active');
                    imgs[idx].classList.add('inactive');
                    idx = (idx + 1) % imgs.length;
                    imgs[idx].classList.remove('inactive');
                    imgs[idx].classList.add('active');
                }, 900);
            };

            window.stopCarousel = function (card) {
                clearInterval(card._carouselInterval);
                const imgs = card.querySelectorAll('.home-carousel-img');
                imgs.forEach((img, i) => {
                    img.classList.toggle('active', i === 0);
                    img.classList.toggle('inactive', i !== 0);
                });
            };

            // ── Wishlist toggle (Axios) ───────────────────────
            window.toggleWishlist = async function (e, productId, btn) {
                e.preventDefault();
                e.stopPropagation();
                e.stopImmediatePropagation();
                const icon = btn.querySelector('.material-symbols-outlined');
                const isWishlisted = icon.classList.contains('icon-fill');

                try {
                    const url = isWishlisted ? '/users/removeFromWishlist' : '/users/toggleWishlist';
                    const res = await axios.post(url, { productId }, { withCredentials: true });

                    if (res.data.success) {
                        icon.classList.toggle('icon-fill');
                        icon.classList.toggle('text-red-500');
                    }
                } catch (err) { console.error('Wishlist error:', err); }
            };

            // ── Add to Cart (Axios) ───────────────────────────
            window.addToCart = async function (e, productId) {
                e.preventDefault();
                e.stopPropagation();
                e.stopImmediatePropagation();
                try {
                    const res = await axios.post('/users/addCart',
                        { productId, quantity: 1 },
                        { withCredentials: true }
                    );

                    if (res.data.success) {
                        const badge = document.getElementById('cart-badge');
                        if (badge) {
                            badge.textContent = (parseInt(badge.textContent) || 0) + 1;
                            badge.classList.remove('opacity-0', 'scale-0');
                        }
                        // Optional: show some feedback
                    }
                } catch (err) { console.error('Cart error:', err); }
            };

            // ── Buy Now ──────────────────────────────
            window.buyNow = function (e, productId) {
                e.preventDefault();
                e.stopPropagation();
                e.stopImmediatePropagation();
                window.location.href = '/users/productDetail/' + productId;
            };
        });
    </script>
