<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BOOT CAMP | Dominate The Game</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;600;800;900&display=swap"
        rel="stylesheet">
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20,300,0,0" />
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        display: ['Outfit', 'sans-serif'],
                    },
                    animation: {
                        'reveal-up': 'revealUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards',
                    },
                    keyframes: {
                        revealUp: {
                            '0%': { transform: 'translateY(40px)', opacity: '0' },
                            '100%': { transform: 'translateY(0)', opacity: '1' },
                        }
                    }
                }
            }
        }
    </script>

    <style>
        @layer base {
            body {
                @apply bg-white text-black font-sans antialiased overflow-x-hidden;
            }
        }

        /* ── Navbar ── */
        #main-navbar.nav-transparent {
            background-color: transparent;
            border-color: transparent;
            box-shadow: none;
        }

        #main-navbar.nav-transparent .nav-logo,
        #main-navbar.nav-transparent nav a,
        #main-navbar.nav-transparent .icon-btn .material-symbols-outlined {
            color: #ffffff;
        }

        #main-navbar.nav-transparent .nav-login-btn {
            background-color: #ffffff;
            color: #000000;
        }

        #main-navbar.nav-scrolled {
            background-color: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid #e5e5e5;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        #main-navbar.nav-scrolled .nav-logo,
        #main-navbar.nav-scrolled nav a,
        #main-navbar.nav-scrolled .icon-btn .material-symbols-outlined {
            color: #000000;
        }

        #main-navbar.nav-scrolled .nav-login-btn {
            background-color: #000000;
            color: #ffffff;
        }

        /* ── Search ── */
        #search-container {
            backdrop-filter: blur(12px);
            background-color: rgba(255, 255, 255, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.1);
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        #main-navbar.nav-scrolled #search-container {
            background-color: rgba(0, 0, 0, 0.05);
            border: 1px solid rgba(0, 0, 0, 0.1);
        }

        #search-container.search-active {
            width: 380px;
            opacity: 1;
            padding-left: 1.25rem;
            padding-right: 0.75rem;
            margin-right: -4px;
        }

        .search-open-state #search-trigger {
            display: none;
        }

        .badge {
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .icon-fill {
            font-variation-settings: 'FILL' 1;
        }

        /* ── Home Product Card ── */
        .home-card {
            display: flex;
            flex-direction: column;
            background: #ffffff;
            border: 1px solid #f0f0f0;
            border-radius: 24px;
            padding: 14px;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            text-decoration: none;
            color: inherit;
        }

        .home-card:hover {
            box-shadow: 0 20px 48px rgba(0, 0, 0, 0.09);
            transform: translateY(-4px);
            border-color: #e0e0e0;
        }

        .home-card-img-box {
            position: relative;
            background: #f4f4f4;
            border-radius: 16px;
            aspect-ratio: 1/1;
            overflow: hidden;
            margin-bottom: 14px;
        }

        /* Carousel images */
        .home-carousel-img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: contain;
            transition: opacity 0.5s ease;
        }

        .home-carousel-img.active {
            opacity: 1;
        }

        .home-carousel-img.inactive {
            opacity: 0;
        }

        /* Wishlist btn */
        .home-wish-btn {
            position: absolute;
            top: 10px;
            right: 10px;
            z-index: 20;
            background: white;
            width: 34px;
            height: 34px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
            border: none;
            cursor: pointer;
            opacity: 0;
            transition: opacity 0.25s ease;
        }

        .home-card:hover .home-wish-btn {
            opacity: 1;
        }

        .home-wish-btn:hover {
            background: #f9f9f9;
        }

        /* In-stock badge */
        .home-stock-badge {
            position: absolute;
            bottom: 10px;
            left: 10px;
            z-index: 20;
            background: rgba(255, 255, 255, 0.96);
            backdrop-filter: blur(6px);
            padding: 4px 10px;
            border-radius: 999px;
            display: flex;
            align-items: center;
            gap: 5px;
            box-shadow: 0 1px 6px rgba(0, 0, 0, 0.08);
            border: 1px solid rgba(0, 0, 0, 0.04);
        }

        /* Card action buttons */
        .home-card-actions {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-top: auto;
            padding-top: 10px;
        }

        .home-btn-primary {
            width: 100%;
            background: #000;
            color: #fff;
            border: none;
            padding: 11px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            transition: background 0.2s;
        }

        .home-btn-primary:hover {
            background: #222;
        }

        .home-btn-secondary {
            width: 100%;
            background: #f1f3f5;
            color: #000;
            border: none;
            padding: 11px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            cursor: pointer;
            transition: background 0.2s;
        }

        .home-btn-secondary:hover {
            background: #e5e7eb;
        }

        /* Dark card variant for Limited Edition */
        .home-card-dark {
            display: flex;
            flex-direction: column;
            background: rgba(255, 255, 255, 0.09);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 24px;
            padding: 14px;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .home-card-dark:hover {
            background: rgba(255, 255, 255, 0.15);
            transform: translateY(-4px);
            box-shadow: 0 24px 48px rgba(0, 0, 0, 0.35);
        }

        .home-card-dark .home-card-img-box {
            background: rgba(255, 255, 255, 0.1);
        }

        .home-card-dark .home-wish-btn {
            background: rgba(255, 255, 255, 0.2);
        }

        .home-card-dark .home-wish-btn:hover {
            background: rgba(255, 255, 255, 0.35);
        }

        .home-card-dark .home-stock-badge {
            background: rgba(255, 255, 255, 0.18);
            border-color: rgba(255, 255, 255, 0.2);
        }

        .home-card-dark .home-btn-primary {
            background: #fff;
            color: #000;
        }

        .home-card-dark .home-btn-primary:hover {
            background: #e9e9e9;
        }

        .home-card-dark .home-btn-secondary {
            background: rgba(255, 255, 255, 0.12);
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .home-card-dark .home-btn-secondary:hover {
            background: rgba(255, 255, 255, 0.22);
        }

        /* ── Scroll reveal ── */
        .scroll-reveal {
            opacity: 0;
            transform: translateY(20px);
            transition: all 1s ease-out;
        }

        .scroll-reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        /* ── Interactive Image Accordion ── */
        .accordion-container {
            display: flex;
            width: 100%;
            height: 500px;
            gap: 1rem;
        }

        .accordion-item {
            position: relative;
            flex: 1;
            overflow: hidden;
            border-radius: 1.5rem;
            cursor: pointer;
            transition: all 0.7s cubic-bezier(0.23, 1, 0.32, 1);
        }

        .accordion-item.expanded {
            flex: 4.5;
        }

        .accordion-item img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.7s ease;
        }

        .accordion-item:hover img {
            transform: scale(1.05);
        }

        .accordion-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, rgba(0, 0, 0, 0.1), rgba(0, 0, 0, 0.7));
            transition: opacity 0.5s ease;
        }

        .accordion-content {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

        .accordion-title-vertical {
            color: rgba(255, 255, 255, 0.7);
            font-size: 0.75rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.4em;
            writing-mode: vertical-rl;
            transform: rotate(180deg);
            transition: all 0.5s ease;
            white-space: nowrap;
        }

        .expanded .accordion-title-vertical {
            opacity: 0;
            transform: rotate(180deg) translateY(20px);
        }

        .accordion-title-horizontal {
            position: absolute;
            bottom: 2rem;
            left: 50%;
            transform: translateX(-50%) translateY(20px);
            color: white;
            font-size: 1.5rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            opacity: 0;
            transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
            white-space: nowrap;
            text-align: center;
        }

        .expanded .accordion-title-horizontal {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
        }

        /* Mobile Adjustments */
        @media (max-width: 768px) {
            .accordion-container {
                flex-direction: row;
                height: 400px;
                overflow-x: auto;
                padding-bottom: 1rem;
                scroll-snap-type: x mandatory;
            }

            .accordion-item {
                min-width: 280px;
                flex: none;
                scroll-snap-align: start;
            }

            .accordion-item.expanded {
                flex: none;
            }

            .accordion-title-vertical {
                display: none;
            }

            .accordion-title-horizontal {
                opacity: 1;
                transform: translateX(-50%) translateY(0);
                font-size: 1.1rem;
            }
        }

        /* ── Premium Product Card (Light) ── */
        .premium-card {
            display: flex;
            flex-direction: column;
            background: #ffffff;
            border-radius: 32px;
            border: 1px solid #f0f0f0;
            padding: 20px;
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            height: 100%;
        }

        .premium-card:hover {
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.08);
            transform: translateY(-6px);
        }

        .premium-img-container {
            position: relative;
            aspect-ratio: 1/1;
            background: #f3f4f6;
            border-radius: 24px;
            overflow: hidden;
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .premium-img {
            width: 85%;
            height: 85%;
            object-fit: contain;
            transition: transform 0.7s ease;
        }

        .premium-card:hover .premium-img {
            transform: scale(1.08);
        }

        .heart-overlay {
            position: absolute;
            top: 14px;
            right: 14px;
            width: 40px;
            height: 40px;
            background: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            opacity: 0;
            transition: all 0.3s ease;
            cursor: pointer;
            border: none;
        }

        .premium-card:hover .heart-overlay {
            opacity: 1;
        }

        .heart-overlay:hover {
            background: #f9f9f9;
        }

        .stock-badge {
            position: absolute;
            bottom: 14px;
            left: 14px;
            background: white;
            padding: 6px 12px;
            border-radius: 999px;
            display: flex;
            align-items: center;
            gap: 6px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            border: 1px solid rgba(0, 0, 0, 0.04);
        }

        .stock-dot {
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: #10b981;
            border: 2px solid white;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .luxury-badge {
            position: absolute;
            top: 14px;
            left: 14px;
            background: #000;
            color: #fff;
            font-size: 9px;
            font-weight: 900;
            letter-spacing: 0.15em;
            padding: 4px 12px;
            border-radius: 999px;
            text-transform: uppercase;
            z-index: 10;
        }

        .card-pill-btn {
            width: 100%;
            height: 52px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            cursor: pointer;
            border: none;
        }

        .pill-primary {
            background: #000;
            color: #fff;
        }

        .pill-primary:hover {
            background: #222;
        }

        .pill-secondary {
            background: #f1f3f5;
            color: #000;
            margin-top: 10px;
        }

        .pill-secondary:hover {
            background: #e5e7eb;
        }

        /* ── Premium Card Dark (Limited Edition) ── */
        .premium-card-dark {
            display: flex;
            flex-direction: column;
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-radius: 32px;
            border: 1px solid rgba(255, 255, 255, 0.15);
            padding: 20px;
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            height: 100%;
        }

        .premium-card-dark:hover {
            background: rgba(255, 255, 255, 0.14);
            transform: translateY(-6px);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.4);
        }

        .premium-img-container-dark {
            position: relative;
            aspect-ratio: 1/1;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            overflow: hidden;
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .premium-img-dark {
            width: 85%;
            height: 85%;
            object-fit: contain;
            transition: transform 0.7s ease;
        }

        .premium-card-dark:hover .premium-img-dark {
            transform: scale(1.08);
        }

        .heart-overlay-dark {
            position: absolute;
            top: 14px;
            right: 14px;
            width: 40px;
            height: 40px;
            background: rgba(255, 255, 255, 0.15);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: all 0.3s ease;
            cursor: pointer;
            border: none;
        }

        .premium-card-dark:hover .heart-overlay-dark {
            opacity: 1;
        }

        .heart-overlay-dark:hover {
            background: rgba(255, 255, 255, 0.25);
        }

        .stock-badge-dark {
            position: absolute;
            bottom: 14px;
            left: 14px;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(8px);
            padding: 6px 12px;
            border-radius: 999px;
            display: flex;
            align-items: center;
            gap: 6px;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .pill-primary-dark {
            background: #fff;
            color: #000;
        }

        .pill-primary-dark:hover {
            background: #e5e7eb;
        }

        .pill-secondary-dark {
            background: rgba(255, 255, 255, 0.1);
            color: #fff;
            margin-top: 10px;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .pill-secondary-dark:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        /* scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: #f1f1f1;
        }

        ::-webkit-scrollbar-thumb {
            background: #ccc;
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #999;
        }

        /* ── Final Feature Section Design (White BG + Liquid Shader) ── */
        .features-section {
            background-color: #ffffff;
            color: #111111;
        }

        .feature-card {
            position: relative;
            height: 340px;
            background: #000000;
            color: #ffffff;
            padding: 2.25rem;
            border-radius: 1.5rem;
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            text-align: left;
            overflow: hidden;
        }

        .feature-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.2);
            border-color: rgba(255, 255, 255, 0.15);
        }

        /* Swirly Liquid Shader Background */
        .liquid-shader {
            position: absolute;
            inset: 0;
            opacity: 0.35;
            filter: blur(45px) contrast(1.1);
            z-index: 1;
            pointer-events: none;
            transition: opacity 0.5s ease;
        }

        .feature-card:hover .liquid-shader {
            opacity: 0.55;
        }

        .shader-1 {
            background: #000000
        }

        .shader-2 {
            background: #000000
        }

        .shader-3 {
            background: #000000
        }

        .shader-4 {
            background: #000000
        }

        .liquid-shader::before {
            content: '';
            position: absolute;
            width: 160%;
            height: 160%;
            top: -30%;
            left: -30%;
            background: inherit;
            animation: rotate-liquid 18s linear infinite;
        }

        @keyframes rotate-liquid {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }

        .feature-icon-box {
            position: relative;
            z-index: 10;
            margin-bottom: 2rem;
            opacity: 0.85;
            transition: all 0.3s ease;
        }

        .feature-card:hover .feature-icon-box {
            opacity: 1;
            transform: scale(1.1);
        }

        .feature-card h3 {
            position: relative;
            z-index: 10;
            font-size: 1.35rem;
            font-weight: 800;
            margin-bottom: 0.75rem;
            letter-spacing: -0.02em;
        }

        .feature-card p {
            position: relative;
            z-index: 10;
            font-size: 0.875rem;
            line-height: 1.6;
            color: rgba(255, 255, 255, 0.45);
            margin-bottom: auto;
        }

        .learn-more-link {
            position: relative;
            z-index: 10;
            color: #ffffff;
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            margin-top: 1.5rem;
            transition: gap 0.3s ease;
        }

        .feature-card:hover .learn-more-link {
            gap: 0.6rem;
        }
    </style>
</head>

<body>

    <!-- Navigation -->
    <header id="main-navbar" class="w-full bg-white fixed top-0 z-50 transition-all duration-300">
        <div class="w-full px-8 md:px-12 lg:px-16 h-20 flex items-center justify-between">
            <a href="/" class="flex-shrink-0 group">
                <h1
                    class="nav-logo font-display font-black text-2xl tracking-tighter uppercase transition-all duration-300 group-hover:scale-105">
                    BOOT<span class="font-light">CAMP</span>
                </h1>
            </a>
            <nav class="hidden lg:flex items-center space-x-10 font-bold text-[11px] tracking-[0.4em] uppercase">
                <a href="/" class="transition-colors duration-300">Home</a>
                <a href="/users/allProduct" class="transition-colors duration-300">Explore</a>
            </nav>
            <div class="flex items-center space-x-6">
                <div id="search-container"
                    class="flex items-center overflow-hidden w-0 opacity-0 rounded-full h-10 px-0">
                    <input type="text" id="search-input" placeholder="SEARCH PRODUCT..."
                        class="bg-transparent border-none outline-none text-[10px] font-black tracking-widest pl-2 w-72 placeholder:text-gray-400">
                    <button onclick="toggleSearch()" class="pr-1 text-gray-400 hover:text-black transition-colors">
                        <span class="material-symbols-outlined text-[18px]">close</span>
                    </button>
                </div>
                <button id="search-trigger" onclick="toggleSearch()" class="icon-btn group" aria-label="Search">
                    <span
                        class="material-symbols-outlined font-light text-[22px] group-hover:text-gray-500 transition-colors duration-300">search</span>
                </button>
                <a href="/users/wishlist" class="icon-btn relative group" aria-label="Wishlist">
                    <span
                        class="material-symbols-outlined font-light text-[22px] group-hover:text-gray-500 transition-colors duration-300">favorite</span>
                    <span id="wishlist-badge"
                        class="badge absolute -top-1 -right-1 bg-red-500 text-white text-[8px] font-black w-3.5 h-3.5 rounded-full flex items-center justify-center transition-all {{#unless wishlistCount}}opacity-0 scale-0{{/unless}}">
                        {{wishlistCount}}
                    </span>
                </a>
                <a href="/users/cart" class="icon-btn relative group" aria-label="Cart">
                    <span
                        class="material-symbols-outlined font-light text-[22px] group-hover:text-gray-500 transition-colors duration-300">shopping_bag</span>
                    <span id="cart-badge"
                        class="badge absolute -top-1 -right-1 bg-black text-white text-[8px] font-black w-3.5 h-3.5 rounded-full flex items-center justify-center transition-all {{#unless cartCount}}opacity-0 scale-0{{/unless}}">
                        {{cartCount}}
                    </span>
