                    </div>
                </div>
                <!-- Puma -->
                <div
                    class="group relative flex items-center justify-center aspect-square bg-[#f5f5f5]  overflow-hidden cursor-pointer transition-all duration-500">
                    <img src="https://i.pinimg.com/736x/f9/4b/5b/f94b5bd712f3c3590f0dd52bf1c39840.jpg" alt="Puma Boot"
                        class="w-[75%] h-[75%] object-contain filter hue-rotate-[180deg] transition-all duration-700 group-hover:scale-110 group-hover:blur-[4px]">
                    <div
                        class="absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition-all duration-500 flex items-center justify-center backdrop-blur-[2px]">
                        <span
                            class="text-white font-sans font-black text-2xl lg:text-3xl tracking-[0.2em] uppercase drop-shadow-[0_4px_4px_rgba(0,0,0,0.8)]">PUMA</span>
                    </div>
                </div>
                <!-- NB -->
                <div
                    class="group relative flex items-center justify-center aspect-square bg-[#f5f5f5]  overflow-hidden cursor-pointer transition-all duration-500">
                    <img src="https://i.pinimg.com/736x/85/59/cb/8559cbec29cae2e8d7267a07cbc6f366.jpg" alt="NB Boot"
                        class="w-[75%] h-[75%] object-contain filter hue-rotate-[270deg] transition-all duration-700 group-hover:scale-110 group-hover:blur-[4px]">
                    <div
                        class="absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition-all duration-500 flex items-center justify-center backdrop-blur-[2px]">
                        <span
                            class="text-white font-sans font-black text-2xl lg:text-3xl tracking-[0.2em] uppercase drop-shadow-[0_4px_4px_rgba(0,0,0,0.8)]">NEW
                            BALANCE</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- New Arrivals -->
    <section class="py-24 px-6 md:px-12 max-w-[1800px] mx-auto">
        <div class="flex justify-between items-end mb-12">
            <div>
                <p class="text-[10px] text-gray-400 font-bold tracking-[0.4em] uppercase mb-4">THE LATEST DROP</p>
                <h2 class="font-sans font-black text-4xl uppercase tracking-tighter">New Arrivals</h2>
            </div>
            <a href="#"
                class="text-[10px] font-bold tracking-[0.2em] uppercase border-b border-black pb-1 hover:text-gray-500 hover:border-gray-500 transition-colors">View
                All</a>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            <!-- Product 1 -->
            <div class="group cursor-pointer">
                <div class="bg-black aspect-square flex items-center justify-center mb-6 relative overflow-hidden">
                    <img src="images/boot_arrival_1.png" alt="Product"
                        class="w-48 h-48 object-contain transition-transform group-hover:scale-110">
                    <button
                        class="absolute bottom-4 right-4 bg-white text-black p-2 opacity-0 group-hover:opacity-100 transition-opacity">
