                    <span
                        class="material-symbols-outlined font-light text-[22px] group-hover:text-gray-500 transition-colors duration-300">person</span>
                </a>
                {{else}}
                <a href="/users/login" id="login-btn"
                    class="nav-login-btn px-5 py-2 text-[11px] font-black tracking-widest uppercase rounded-full bg-black text-white hover:bg-gray-800 transition-all duration-300">
                    Login
                </a>
                {{/if}}

            </div>
        </div>
    </header>

