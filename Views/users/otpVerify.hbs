<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify OTP | BootCamp</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

    <!-- Toastify -->
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #000;
            overflow: hidden;
        }

        .glass {
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        @keyframes pulse-glow {
            0%, 100% { opacity: 0.75; }
            50% { opacity: 1; }
        }

        .animate-pulse-glow {
            animation: pulse-glow 5s infinite;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .animate-fadeIn {
            animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        /* Video Background */
        .video-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            z-index: -1;
        }

        .video-container::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.4);
        }

        video {
            min-width: 100%;
            min-height: 100%;
            object-fit: cover;
        }

        /* OTP Input Styling */
        .otp-box {
            width: 3.5rem;
            height: 4.5rem;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 0.75rem;
            text-align: center;
            font-size: 1.875rem;
            font-weight: 700;
            color: white;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .otp-box:focus {
            outline: none;
            border-color: rgba(147, 51, 234, 0.5);
            background: rgba(255, 255, 255, 0.1);
            transform: translateY(-4px);
            box-shadow: 0 10px 20px -10px rgba(147, 51, 234, 0.3);
        }

        .otp-box.filled {
            border-color: rgba(255, 255, 255, 0.3);
        }

        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            20% { transform: translateX(-8px); }
            40% { transform: translateX(8px); }
            60% { transform: translateX(-4px); }
            80% { transform: translateX(4px); }
        }

        .shake {
            animation: shake 0.4s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
        }

        @keyframes success-pop {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); border-color: #10b981; }
            100% { transform: scale(1); }
        }

        .success-animation {
            animation: success-pop 0.4s ease-out forwards;
        }

        /* Success Message Overlay */
        .success-overlay {
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
        }
    </style>
</head>

<body class="text-white min-h-screen flex items-center justify-center p-4">

    <!-- Video Background -->
    <div class="video-container" style="position:fixed; top:0; left:0; width:100%; height:100%; z-index:0;">
    <img src="/uploads/images/otp.png" alt="" style="width:100%; height:100%; object-fit:cover;">
    </div>

    <!-- Main Container -->
    <div class="relative z-20 w-full max-w-lg animate-fadeIn">
        <div class="p-10 rounded-2xl glass">
            
            <div id="auth-content">
                <!-- Logo/Header Area -->
                <div class="mb-10 text-center">
                    <h2 class="text-3xl font-bold mb-2 relative group inline-block">
                        <span class="absolute -inset-1 bg-gradient-to-r from-purple-600/30 via-pink-500/30 to-blue-500/30 blur-xl opacity-75 group-hover:opacity-100 transition-all duration-500 animate-pulse-glow"></span>
                        <span class="relative inline-block text-3xl font-black tracking-tighter text-white uppercase">
                            BootCamp
                        </span>
                    </h2>
                    
                    <div class="mt-4 flex flex-col items-center space-y-2">
                        <h3 class="text-xl font-bold tracking-tight text-white uppercase">Verify Identity</h3>
                        <p class="text-white/60 text-sm max-w-[320px]">
                            We've sent a 6-digit code to <br>
                            <span class="text-white font-bold italic">{{email}}</span>
                        </p>
                    </div>
                </div>

                <!-- Hidden Context -->
                <input type="hidden" id="hidden-email" value="{{email}}">
                <input type="hidden" id="hidden-purpose" value="{{purpose}}">

                <!-- OTP Input Grid -->
                <div id="otp-container" class="flex justify-center gap-3 mb-10">
                    <input type="text" maxlength="1" class="otp-box" inputmode="numeric" autocomplete="one-time-code">
                    <input type="text" maxlength="1" class="otp-box" inputmode="numeric">
                    <input type="text" maxlength="1" class="otp-box" inputmode="numeric">
                    <input type="text" maxlength="1" class="otp-box" inputmode="numeric">
                    <input type="text" maxlength="1" class="otp-box" inputmode="numeric">
                    <input type="text" maxlength="1" class="otp-box" inputmode="numeric">
                </div>
                <p id="otp-error" class="hidden text-center mt-[-24px] mb-2 text-[11px] font-bold text-red-400 tracking-wide"></p>

                <!-- Timer & Resend -->
                <div class="flex flex-col items-center gap-6">
                    <div class="flex items-center gap-2 text-[11px] font-black tracking-[0.2em] text-white/30 uppercase">
                        <span class="material-symbols-outlined text-[16px]">schedule</span>
                        <span>Resend in <span id="timer" class="text-white">01:00</span></span>
                    </div>

                    <button id="submit-btn"
                        class="w-full py-5 bg-purple-600 hover:bg-purple-700 text-white font-black uppercase tracking-widest text-[11px] rounded-xl transition-all duration-300 transform hover:-translate-y-1 shadow-lg shadow-purple-500/20 hover:shadow-purple-500/40 flex items-center justify-center gap-2">
                        <span id="btn-text">VERIFY CODE</span>
                        <span class="material-symbols-outlined text-[18px]">lock_open</span>
                    </button>

                    <button id="resend-btn" disabled
                        class="text-[10px] font-black uppercase tracking-[0.2em] text-white/40 hover:text-white transition-colors disabled:opacity-20 disabled:cursor-not-allowed">
                        Resend Verification Code
                    </button>
                    
                    <a href="/users/signup" class="text-[10px] font-black uppercase tracking-[0.2em] text-white/20 hover:text-white transition-colors border-b border-transparent hover:border-white/10 pb-1 mt-4">
                        Change Email Address
                    </a>
                </div>
            </div>

            <!-- Success State (Hidden initially) -->
            <div id="success-content" class="success-overlay py-10">
                <div class="w-20 h-20 bg-green-500 rounded-full flex items-center justify-center mb-6 shadow-lg shadow-green-500/40">
                    <span class="material-symbols-outlined text-white text-[40px] font-bold">check</span>
                </div>
                <h3 class="text-2xl font-black tracking-tight text-white uppercase mb-2">Access Granted</h3>
                <p class="text-white/60 text-sm uppercase tracking-widest font-bold">Identity Verified successfully</p>
                <p class="mt-8 text-[10px] text-white/20 uppercase tracking-[0.3em] animate-pulse">Redirecting to home...</p>
            </div>
        </div>
    </div>

    <!-- Page Footer -->
    <footer class="absolute bottom-6 left-0 right-0 text-center text-white/20 text-[10px] font-black uppercase tracking-[0.3em] z-20">
        © 2026 Boot Camp Protocol
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="/toast/toast.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const otpInputs = document.querySelectorAll('.otp-box');
        const otpContainer = document.getElementById('otp-container');
        const submitBtn = document.getElementById('submit-btn');
        const btnText = document.getElementById('btn-text');
        const timerEl = document.getElementById('timer');
        const resendBtn = document.getElementById('resend-btn');
        const authContent = document.getElementById('auth-content');
        const successContent = document.getElementById('success-content');

        // OTP Input Logic
        otpInputs.forEach((input, index) => {
            input.addEventListener('input', (e) => {
                 e.target.value = e.target.value.replace(/[^0-9]/g, '');
                clearOtpError();
                if (e.target.value) {
                    input.classList.add('filled');
                    if (index < otpInputs.length - 1) {
                        otpInputs[index + 1].focus();
                    }
                } else {
                    input.classList.remove('filled');
                }
                checkComplete();
            });

            input.addEventListener('keydown', (e) => {
                if (
                    !/^[0-9]$/.test(e.key) &&
                    !['Backspace', 'ArrowLeft', 'ArrowRight', 'Tab', 'Delete'].includes(e.key) &&
                    !(e.ctrlKey || e.metaKey)
                    ) {
                        e.preventDefault();
                    }
                if (e.key === 'Backspace' && !input.value && index > 0) {
                    otpInputs[index - 1].focus();
                }
                if (e.key === 'ArrowLeft' && index > 0) {
                    otpInputs[index - 1].focus();
                }
                if (e.key === 'ArrowRight' && index < otpInputs.length - 1) {
                    otpInputs[index + 1].focus();
                }
            });

            input.addEventListener('paste', (e) => {
                e.preventDefault();
                const pastedData = e.clipboardData.getData('text').slice(0, 6).split('');
                pastedData.forEach((char, i) => {
                    if (otpInputs[i]) {
                        otpInputs[i].value = char;
                        otpInputs[i].classList.add('filled');
                    }
                });
                const nextFocus = Math.min(pastedData.length, 5);
                otpInputs[nextFocus].focus();
                checkComplete();
            });
        });

        function checkComplete() {
            const code = Array.from(otpInputs).map(i => i.value).join('');
            if (code.length === 6) {
                // Auto-submit could go here, but let's keep the button for intentionality
            }
        }

        // Timer Logic
        let timeLeft = 60;
        function startTimer() {
            const interval = setInterval(() => {
                timeLeft--;
                const minutes = Math.floor(timeLeft / 60);
                const seconds = timeLeft % 60;
                timerEl.textContent = `${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;

                if (timeLeft <= 0) {
                    clearInterval(interval);
                    resendBtn.disabled = false;
                    resendBtn.classList.remove('text-white/40');
                    resendBtn.classList.add('text-purple-400', 'hover:text-purple-300');
                }
            }, 1000);
        }
        startTimer();

        // Submit Logic
        submitBtn.addEventListener('click', async () => {
            const code = Array.from(otpInputs).map(i => i.value).join('');
            if (code.length < 6) {
                showError("Please enter all 6 digits");
                return;
            }

            const email = document.getElementById('hidden-email').value;
            const purpose = document.getElementById('hidden-purpose').value;

            submitBtn.disabled = true;
            btnText.textContent = 'VERIFYING...';

            try {
                const response = await axios.post("/users/otpVerify", { otp: code, email, purpose });
                
                if (response.data.success || response.status === 200) {
                    showSuccess();
                    setTimeout(() => {
                        window.location.href = response.data.redirectUrl || "/";
                    }, 2000);
                } else {
                    throw new Error(response.data.message || "Invalid Code");
                }
            } catch (err) {
                submitBtn.disabled = false;
                btnText.textContent = 'VERIFY CODE';
                showError(err.response?.data?.message || err.message || "Verification Failed");
            }
        });

        // Resend Logic
        resendBtn.addEventListener('click', async () => {
            resendBtn.disabled = true;
            timeLeft = 60;
            startTimer();
            try {
                await axios.post("/users/resendOtp");
                showToast("success", "New code dispatched to your email");
            } catch (err) {
                showToast("error", "Dispatch failed. Try again later.");
            }
        });

       function showError(msg) {
    otpInputs.forEach(input => {
        input.classList.add('shake', 'border-red-500');
        setTimeout(() => {
            input.classList.remove('shake', 'border-red-500');
        }, 500);
    });

    const errorEl = document.getElementById('otp-error');
    errorEl.textContent = msg;
    errorEl.classList.remove('hidden');
    }

    function clearOtpError() {
    const errorEl = document.getElementById('otp-error');
    errorEl.textContent = '';
    errorEl.classList.add('hidden');
    }

        function showSuccess() {
            authContent.style.display = 'none';
            successContent.style.display = 'flex';
            successContent.classList.add('animate-fadeIn');
        }

    </script>
</body>

</html>
