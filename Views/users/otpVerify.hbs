</script>
<style>
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }
  body {
    font-family: 'Inter', sans-serif;
    background-color: #f9f9f9;
  }
  .headline-font { font-family: 'Space Grotesk', sans-serif; }

  @keyframes slideInFromLeft {
    0%   { transform: translateX(-150%); opacity: 0; }
    80%  { transform: translateX(10%);   opacity: 1; }
    100% { transform: translateX(0);     opacity: 1; }
  }
  .subtitle-anim {
    opacity: 0;
    animation: slideInFromLeft 1s cubic-bezier(0.25, 1, 0.5, 1) forwards;
  }

  @keyframes dropInFromTop {
    0%   { opacity: 0; transform: translateY(-80px); }
    60%  { opacity: 1; transform: translateY(10px);  }
    80%  { transform: translateY(-5px); }
    100% { transform: translateY(0);    opacity: 1;  }
  }
  .letter {
    display: inline-block;
    opacity: 0;
    animation: dropInFromTop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  /* OTP box active state */
  .otp-input.active {
    border-bottom-color: #000;
    background-color: #eeeeee;
  }
  .otp-input.filled {
    border-bottom-color: #000;
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    20%       { transform: translateX(-8px); }
    40%       { transform: translateX(8px); }
    60%       { transform: translateX(-5px); }
    80%       { transform: translateX(5px); }
  }
  .shake { animation: shake 0.4s ease; }

  @keyframes pulse-success {
    0%   { transform: scale(1); }
    50%  { transform: scale(1.08); }
    100% { transform: scale(1); }
  }
  .pulse-success { animation: pulse-success 0.3s ease; }

  #error-msg { min-height: 20px; }
</style>
</head>
<body class="antialiased text-on-background selection:bg-primary selection:text-on-primary">

<main class="min-h-screen flex flex-col md:flex-row overflow-hidden">

  <!-- Left Side: Split-Screen Visual -->
  <section class="relative w-full md:w-1/2 h-64 md:h-screen flex items-center justify-start px-8 md:px-20 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img alt="Premium football boot"
           class="w-full h-full object-cover"
           src="https://lh3.googleusercontent.com/aida-public/AB6AXuCjAmnbJ5vyd8qnsA8nS8BhJ7iBwLM6gaNt-RcBiYaMswmHMz9fIbiQcrEfNuBYrMYibwBhQZ-LA8xT73OmPQ_lDBveV8Qm8ExxEY3Wvk8GbZt0VxyuYeILAHv_3mIohW7EDBSFr2ZJaZ13yCyOSco9jyvOj06IufUrjLPBPOJ-gSZHRnBgXHVxrRNbN1aOil2GmlrzDkp5D2lnHhskQ-crepplTixsLp2uNWmrysBgU77ZzFZLkjYF95K3JdKrBkR0HUIjvZAZ7ro">
      <div class="absolute inset-0 bg-gradient-to-r from-black via-black/60 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-lg">
      <h1 class="headline-font text-6xl md:text-8xl font-black text-white tracking-tighter leading-none mb-4">
        <span class="letter">B</span><span class="letter">O</span><span class="letter">O</span><span class="letter">T</span>&nbsp;<span class="letter">C</span><span class="letter">A</span><span class="letter">M</span><span class="letter">P</span>
      </h1>
      <p class="subtitle-anim font-headline font-bold text-xl tracking-[0.4em] text-on-primary uppercase">
        STEP INTO PERFORMANCE
      </p>
    </div>
  </section>

  <!-- Right Side: OTP Form -->
  <div class="w-full lg:w-1/2 bg-surface-container-lowest flex items-center justify-center p-8 md:p-16 lg:p-24">
    <div class="max-w-sm w-full">

      <!-- Mobile Logo -->
      <div class="lg:hidden font-headline font-black tracking-tighter text-2xl mb-12">BOOT CAMP</div>

      <header class="mb-12">
        <h1 class="font-headline font-bold text-4xl tracking-tighter text-primary uppercase mb-4">VERIFY EMAIL</h1>
        <p class="text-on-surface-variant text-sm leading-relaxed">
          We've sent a 6-digit code to
          <span class="text-primary font-semibold italic">{{email}}</span>.
          Please enter it below to verify your account.
        </p>
      </header>

      <!-- Hidden fields -->
      <input type="hidden" id="hidden-email"   value="{{email}}">
      <input type="hidden" id="hidden-purpose" value="{{purpose}}">

      <div class="space-y-12">

        <!-- OTP Boxes -->
        <div>
          <div id="otp-container" aria-label="6-digit verification code" class="flex justify-between gap-3">
            <input class="otp-input w-12 h-16 text-center text-2xl font-headline font-bold bg-surface-container-low border-b-2 border-outline-variant focus:outline-none transition-all duration-200 rounded-sm" maxlength="1" inputmode="numeric" type="text" autocomplete="one-time-code">
            <input class="otp-input w-12 h-16 text-center text-2xl font-headline font-bold bg-surface-container-low border-b-2 border-outline-variant focus:outline-none transition-all duration-200 rounded-sm" maxlength="1" inputmode="numeric" type="text">
            <input class="otp-input w-12 h-16 text-center text-2xl font-headline font-bold bg-surface-container-low border-b-2 border-outline-variant focus:outline-none transition-all duration-200 rounded-sm" maxlength="1" inputmode="numeric" type="text">
            <input class="otp-input w-12 h-16 text-center text-2xl font-headline font-bold bg-surface-container-low border-b-2 border-outline-variant focus:outline-none transition-all duration-200 rounded-sm" maxlength="1" inputmode="numeric" type="text">
            <input class="otp-input w-12 h-16 text-center text-2xl font-headline font-bold bg-surface-container-low border-b-2 border-outline-variant focus:outline-none transition-all duration-200 rounded-sm" maxlength="1" inputmode="numeric" type="text">
            <input class="otp-input w-12 h-16 text-center text-2xl font-headline font-bold bg-surface-container-low border-b-2 border-outline-variant focus:outline-none transition-all duration-200 rounded-sm" maxlength="1" inputmode="numeric" type="text">
          </div>

          <!-- Timer -->
          <div class="flex justify-end mt-3">
            <span class="text-xs font-bold text-outline font-body flex items-center gap-1">
              <span class="material-symbols-outlined text-[14px]">schedule</span>
              <span id="countdown-timer">01:00</span>
            </span>
          </div>

          <!-- Error message -->
          <p id="error-msg" class="text-error text-xs font-medium mt-2 text-center"></p>
        </div>

        <div class="space-y-6">
          <button id="submit-btn"
            class="w-full bg-primary text-on-primary h-14 font-headline font-bold tracking-[0.15em] text-sm flex items-center justify-center gap-2 hover:bg-primary-container active:scale-[0.98] transition-all rounded-md disabled:opacity-50 disabled:cursor-not-allowed">
            <span id="btn-text">VERIFY &amp; CONTINUE</span>
            <span class="material-symbols-outlined text-sm" id="btn-icon">arrow_forward</span>
          </button>

          <div class="text-center">
            <p class="text-on-surface-variant text-xs font-medium">
              Didn't receive a code?
              <a id="resendBtn"
                 class="text-outline font-bold border-b border-outline pb-0.5 ml-1 opacity-50 pointer-events-none transition-opacity"
                 href="#">Resend</a>
            </p>
          </div>
        </div>
      </div>

      <div class="mt-24 pt-8 border-t border-surface-container-high">
        <a href="/users/signup" class="flex items-center gap-1 group cursor-pointer w-fit">
          <span class="material-symbols-outlined text-outline group-hover:text-primary transition-colors">keyboard_backspace</span>
          <span class="text-[10px] font-bold tracking-widest uppercase text-outline group-hover:text-primary transition-colors">Change email</span>
        </a>
      </div>

    </div>
  </div>
</main>

<script>
document.addEventListener("DOMContentLoaded", () => {

  /* =======================
     🎬 TEXT ANIMATION
  ======================== */
  const letters = document.querySelectorAll('.letter');
  letters.forEach((span, i) => {
    span.style.animationDelay = `${1000 + i * 100}ms`;
  });

  /* =======================
     🔢 OTP INPUT LOGIC
  ======================== */
  const otpInputs   = Array.from(document.querySelectorAll('.otp-input'));
  const errorMsg    = document.getElementById('error-msg');
  const submitBtn   = document.getElementById('submit-btn');
  const btnText     = document.getElementById('btn-text');
  const btnIcon     = document.getElementById('btn-icon');

  // Focus first box on load
  otpInputs[0].focus();

  function setActive(index) {
    otpInputs.forEach((inp, i) => {
      inp.classList.remove('active');
      if (inp.value) inp.classList.add('filled');
      else inp.classList.remove('filled');
    });
    if (index >= 0 && index < otpInputs.length) {
      otpInputs[index].classList.add('active');
    }
  }

  function getOTP() {
    return otpInputs.map(i => i.value).join('');
  }

  function showError(msg) {
    errorMsg.textContent = msg;
    document.getElementById('otp-container').classList.add('shake');
    setTimeout(() => document.getElementById('otp-container').classList.remove('shake'), 400);
  }

  function clearError() {
    errorMsg.textContent = '';
  }

  otpInputs.forEach((input, index) => {

    input.addEventListener('focus', () => setActive(index));

    input.addEventListener('keydown', (e) => {
      clearError();

      if (e.key === 'Backspace') {
        e.preventDefault();
        if (input.value) {
          // Clear current box
          input.value = '';
          setActive(index);
        } else if (index > 0) {
          // Move to previous and clear it
          otpInputs[index - 1].value = '';
          otpInputs[index - 1].focus();
          setActive(index - 1);
        }
        return;
      }

      if (e.key === 'ArrowLeft' && index > 0) {
        e.preventDefault();
        otpInputs[index - 1].focus();
        return;
      }

      if (e.key === 'ArrowRight' && index < otpInputs.length - 1) {
        e.preventDefault();
        otpInputs[index + 1].focus();
        return;
      }

      // Allow only digits
      if (!/^\d$/.test(e.key) && !['Tab', 'Enter'].includes(e.key)) {
        e.preventDefault();
      }
    });

    input.addEventListener('input', (e) => {
      const val = e.target.value.replace(/\D/g, '');

      if (val.length === 0) {
        input.value = '';
        setActive(index);
        return;
      }

      // Handle paste into a single box (browser fills it as multi-char)
      if (val.length > 1) {
        // distribute across boxes
        val.split('').forEach((ch, i) => {
          if (otpInputs[index + i]) otpInputs[index + i].value = ch;
        });
        const next = Math.min(index + val.length, otpInputs.length - 1);
        otpInputs[next].focus();
        setActive(next);
        return;
      }

      input.value = val;

      // Auto-advance to next box
      if (index < otpInputs.length - 1) {
        otpInputs[index + 1].focus();
        setActive(index + 1);
      } else {
        setActive(index); // stay on last
      }
    });

    input.addEventListener('paste', (e) => {
      e.preventDefault();
      const pasted = e.clipboardData.getData('text').replace(/\D/g, '').slice(0, 6);
      pasted.split('').forEach((ch, i) => {
        if (otpInputs[i]) otpInputs[i].value = ch;
      });
      const focusIdx = Math.min(pasted.length, otpInputs.length - 1);
      otpInputs[focusIdx].focus();
      setActive(focusIdx);
    });
  });

  setActive(0);

  /* =======================
     🚀 SUBMIT
  ======================== */
  submitBtn.addEventListener('click', async () => {
    const otp     = getOTP();
    const email   = document.getElementById('hidden-email').value;
    const purpose = document.getElementById('hidden-purpose').value;

    if (otp.length < 6) {
      showError('Please enter the complete 6-digit code.');
      return;
    }

    // Loading state
    submitBtn.disabled = true;
    btnText.textContent = 'VERIFYING...';
    btnIcon.textContent = 'hourglass_empty';

    try {
      const res  = await fetch("/users/otpVerify", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ otp, email, purpose })
      });

      const data = await res.json();

      if (data.success) {
        btnText.textContent = 'SUCCESS!';
        btnIcon.textContent = 'check_circle';
        submitBtn.classList.add('pulse-success');
        setTimeout(() => { window.location.href = data.redirectUrl; }, 300);
      } else {
        showError(data.message || 'Incorrect OTP. Please try again.');
        // Reset boxes
        otpInputs.forEach(i => i.value = '');
        otpInputs[0].focus();
        setActive(0);
        // Reset button
        submitBtn.disabled = false;
        btnText.textContent = 'VERIFY & CONTINUE';
        btnIcon.textContent = 'arrow_forward';
      }

    } catch (err) {
      console.error("OTP verify error:", err);
      showError('Something went wrong. Please try again.');
      submitBtn.disabled = false;
      btnText.textContent = 'VERIFY & CONTINUE';
      btnIcon.textContent = 'arrow_forward';
    }
  });

  /* =======================
     ⏱️ TIMER + RESEND
  ======================== */
  let timeLeft = 60;
  const timerEl  = document.getElementById('countdown-timer');
  const resendBtn = document.getElementById('resendBtn');
  let timerInterval;

  function startTimer() {
    clearInterval(timerInterval);
    timerInterval = setInterval(() => {
      timeLeft--;
      if (timeLeft <= 0) {
        clearInterval(timerInterval);
        timerEl.textContent = '00:00';
        // Enable resend
        resendBtn.classList.remove('opacity-50', 'pointer-events-none', 'text-outline');
        resendBtn.classList.add('text-primary', 'border-primary');
        return;
      }
      const m = Math.floor(timeLeft / 60);
      const s = timeLeft % 60;
      timerEl.textContent = `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
    }, 1000);
  }

  startTimer();

  resendBtn.addEventListener('click', async (e) => {
    e.preventDefault();
    if (timeLeft > 0) return;

    resendBtn.classList.add('opacity-50', 'pointer-events-none', 'text-outline');
    resendBtn.classList.remove('text-primary', 'border-primary');
    timeLeft = 60;
    startTimer();
    clearError();

    try {
      const res  = await fetch("/resendOtp", { method: "POST" });
      const data = await res.json();
      if (!data.success) showError(data.message || 'Failed to resend OTP');
    } catch (err) {
      showError('Failed to resend OTP');
    }
  });

});

</script>
{{#if message}}
<script>
  document.addEventListener("DOMContentLoaded", function () {
    Swal.fire({
      text: "{{message}}",
      confirmButtonColor: "#000000"
    });
  });
</script>
{{/if}}
</body>
</html>
