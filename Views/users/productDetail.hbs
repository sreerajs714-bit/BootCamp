<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{product.productName}} - BOOT CAMP</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    
    <!-- Toastify -->
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet">

    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #ffffff;
            color: #000000;
        }

        /* Material Icons filled trick */
        .icon-fill {
            font-variation-settings: 'FILL' 1;
        }

        /* Zoom specific styles */
        .zoom-container {
            position: relative;
            overflow: hidden;
            background-color: #f4f4f5;
            border-radius: 0.75rem;
            cursor: zoom-in;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            height: 500px;
        }

        #main-image {
            transition: transform 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            transform-origin: center center;
            user-select: none;
            pointer-events: none;
        }

        .thumbnail {
            transition: all 0.2s ease;
        }

        .thumbnail.active {
            border-color: #000000;
            opacity: 1;
        }

        .thumbnail:not(.active) {
            border-color: transparent;
            opacity: 0.6;
        }

        .thumbnail:hover:not(.active) {
            opacity: 0.9;
            border-color: #d1d5db;
        }

        /* Similar Product Card Animations */
        .product-card-similar {
            transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        }
        .product-card-similar:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px -12px rgba(0,0,0,0.08);
            border-color: #f4f4f5;
        }

        /* Button styles */
        .btn-action {
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            font-weight: 700;
            letter-spacing: 0.05em;
        }

        .btn-action:active {
            transform: scale(0.98);
        }
    </style>
</head>

<body>

    {{>navbar}}
    {{>breadCrumbs}}

    <main class="max-w-[1500px] mx-auto px-6 py-8 lg:py-8">

        <!-- PRODUCT GRID -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">

            <!-- IMAGES -->
            <div class="lg:col-span-5 flex flex-col-reverse lg:flex-row gap-6 pt-12">

                <!-- THUMBNAILS -->
                <div id="thumbnail-container" class="flex lg:flex-col gap-4 overflow-x-auto lg:overflow-visible pb-2 lg:pb-0">
                    {{#each product.images}}
                    <button type="button" class="thumbnail {{#if @first}}active{{/if}} w-20 h-24 border-2 rounded-lg overflow-hidden flex-shrink-0"
                        onclick="changeImage({{@index}}, this)">
                        <img src="{{this}}" class="w-full h-full object-contain mix-blend-multiply">
                    </button>
                    {{/each}}
                </div>

                <!-- MAIN IMAGE -->
                <div class="flex-1 zoom-container group" onmousemove="zoomImage(event)" onmouseleave="resetZoom(event)">
                    <img id="main-image" src="{{product.images.[0]}}" class="max-h-full object-contain mix-blend-multiply filter drop-shadow-2xl">
                </div>
            </div>

            <!-- DETAILS -->
            <div class="lg:col-span-7 flex flex-col justify-center">

                <h1 id="product-name" class="text-4xl lg:text-3xl font-black uppercase tracking-tighter mb-4 leading-tight">
                    {{product.productName}}
                </h1>

                <div class="flex items-baseline gap-3 mb-6">
                    <span id="product-price" class="text-2xl font-black">₹{{product.price}}</span>
                    {{#if product.oldPrice}}
                    <span class="text-sm text-gray-400 line-through">₹{{product.oldPrice}}</span>
                    {{/if}}
                </div>

                <div class="inline-flex bg-gray-100 px-3 py-1 rounded text-[10px] font-bold uppercase tracking-widest mb-8 self-start">
                    {{product.badge}}
                </div>

                <!-- COLORS -->
                <div class="mb-8">
                    <p class="text-[10px] font-black uppercase tracking-widest mb-3 text-gray-500">Select Color</p>
                    <div id="color-container" class="flex gap-2.5">
                        {{#each product.variants}}
                        <button 
                            data-variant-id="{{this.id}}"
                            class="variant-clr-btn w-7 h-7 rounded-full border-2 border-white ring-2 {{#if @first}}ring-black{{else}}{{#if this.isDefault}}ring-black{{else}}ring-transparent{{/if}}{{/if}} hover:ring-gray-300 transition-all focus:ring-black outline-none" 
                            style="background-color: {{this.color}};"
                            title="{{this.color}}"
                            onclick="selectVariant('{{this.id}}', this)">
                        </button>
                        {{/each}}
                    </div>
                </div>

                <!-- SIZE -->
                <div class="mb-10">
                    <div class="flex justify-between items-center mb-3">
                        <p class="text-[10px] font-black uppercase tracking-widest text-gray-500">Select Size</p>
                    </div>

                    <!-- REPLACE THIS -->
                       <div id="size-container" class="flex flex-wrap gap-2">
                            {{#each product.sizes}}
                                <button onclick="selectSize(this)"  class="size-btn w-12 h-10 border border-gray-200 rounded-lg text-[11px] font-bold hover:border-black transition-all flex items-center justify-center">
                             {{this}}
                                 </button>
                             {{/each}}
                        </div>
                        <!-- EMPTY — JS will populate this -->
                       <div id="size-container" class="flex flex-wrap gap-2"></div>
                </div>

                <!-- ACTIONS -->
                <div class="flex flex-col gap-3 max-w-md">
                    <button onclick="addToCart('{{product.id}}')"
                        class="btn-action w-full bg-black text-white py-4 rounded-2xl text-[13px] hover:bg-gray-800 shadow-lg shadow-black/10">
                        Add to Cart
                    </button>

                    <button onclick="buyNow('{{product.id}}')" 
                        class="btn-action w-full bg-[#f4f4f5] text-black py-4 rounded-2xl text-[13px] hover:bg-gray-200">
                        Buy Now
                    </button>

                    <button onclick="toggleWishlist('{{product.id}}', this)"
                        class="btn-action w-full mt-2 flex items-center justify-center gap-2 text-gray-500 hover:text-red-500 transition-colors">
                        <span class="material-symbols-outlined text-[20px] {{#if product.isWishlisted}}icon-fill text-red-500{{/if}}">favorite</span>
                        <span class="text-[10px] font-bold uppercase tracking-widest">Add to Wishlist</span>
                    </button>
                </div>

                <p id="product-description" class="mt-8 text-[13px] text-gray-500 leading-relaxed font-medium">
                    {{product.description}}
                </p>

            </div>

        </div>

        <!-- SIMILAR PRODUCTS SECTION -->
        <section class="mt-32 pt-20 border-t border-gray-100">
            <div class="flex justify-between items-end mb-12">
                <div>
                    <h2 class="text-[28px] font-black uppercase tracking-tighter mb-2">Similar Products</h2>
                    <p class="text-gray-400 text-xs font-bold uppercase tracking-widest">Recommended for you</p>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                {{#each similarProducts}}
                <a href="/users/productdetail/{{this.id}}" class="product-card-similar block group flex flex-col bg-white rounded-3xl p-3 border border-gray-50 transition-all cursor-pointer hover:no-underline text-inherit">
                    
                    <!-- Card Top (Image + Icons) -->
                    <div class="relative aspect-square bg-[#f8f8f8] rounded-2xl overflow-hidden mb-5">
                        
                        <button onclick="event.preventDefault(); event.stopPropagation(); toggleWishlist('{{this.id}}', this)" 
                            class="absolute top-3 right-3 z-20 w-8 h-8 bg-white/80 backdrop-blur rounded-full flex items-center justify-center text-gray-400 hover:text-red-500 transition-all shadow-sm">
                            <span class="material-symbols-outlined text-[18px] {{#if this.isWishlisted}}icon-fill text-red-500{{/if}}">favorite</span>
                        </button>

                        <div class="carousel-container relative w-full h-full flex items-center justify-center p-6">
                            {{#each this.images}}
                            <img src="{{this}}" 
                                class="carousel-img absolute max-w-[85%] max-h-[85%] object-contain mix-blend-multiply transition-opacity duration-500 {{#if @first}}opacity-100{{else}}opacity-0{{/if}}">
                            {{/each}}
                        </div>

                        <div class="absolute bottom-3 left-3 z-20 bg-white px-2 py-1 rounded-lg shadow-sm border border-gray-100 flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-[14px] text-gray-400">check_circle</span>
                            <span class="text-[9px] font-black uppercase tracking-tighter text-gray-700">In Stock</span>
                        </div>
                    </div>

                    <!-- Card Info -->
                    <div class="px-1 flex-1 flex flex-col pt-1">
                        <div class="text-[9px] font-black text-gray-400 uppercase tracking-widest mb-1">{{this.badge}}</div>
                        <h3 class="text-[15px] font-black text-gray-900 mb-1">{{this.productName}}</h3>
                        <div class="text-lg font-black text-gray-900 mb-6">₹{{this.price}}</div>

                        <div class="mt-auto flex flex-col gap-2">
                            <button onclick="event.preventDefault(); event.stopPropagation(); addToCart('{{this.id}}', true)" 
                                class="w-full bg-black text-white py-3 rounded-xl text-[11px] font-bold uppercase tracking-widest hover:bg-gray-800 transition-all shadow-sm">
                                Add to Cart
                            </button>
                            <button onclick="event.preventDefault(); event.stopPropagation(); buyNow('{{this.id}}')" 
                                class="w-full bg-[#f4f4f5] text-black py-3 rounded-xl text-[11px] font-bold uppercase tracking-widest hover:bg-gray-200 transition-all">
                                Buy Now
                            </button>
                        </div>
                    </div>
                </a>
                {{/each}}
            </div>
        </section>

    </main>

    {{>footer}}

    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="/toast/toast.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        const productVariants = {{{ json product.variants }}};
        const initialImages = {{{ json product.images }}};
        
        // State Management
        let currentImages = initialImages;
        let selectedVariantId = (productVariants.find(v => v.isDefault) || productVariants[0] || {}).id;
        let selectedSize = null;
        const isLoggedIn = {{#if user}}true{{else}}false{{/if}};

        // Sync initial visual state
        document.addEventListener('DOMContentLoaded', () => {
            const initialBtn = document.querySelector(`[data-variant-id="${selectedVariantId}"]`);
            if (initialBtn) {
                document.querySelectorAll('#color-container button').forEach(b => {
                    b.classList.remove('ring-black');
                    b.classList.add('ring-transparent');
                });
                initialBtn.classList.add('ring-black');
                initialBtn.classList.remove('ring-transparent');
            }
        });

        // Dynamic Badge Updates
        function updateBadges() {
            axios.get('/user/nav-counts').then(response => {
                if(response.data.success) {
                    const cartBadge = document.getElementById('cart-badge');
                    const wishlistBadge = document.getElementById('wishlist-badge');
                    
                    if(cartBadge) {
                        cartBadge.innerText = response.data.cartCount;
                        const isEmpty = response.data.cartCount === 0;
                        cartBadge.classList.toggle('opacity-0', isEmpty);
                        cartBadge.classList.toggle('scale-0', isEmpty);
                    }
                    if(wishlistBadge) {
                        wishlistBadge.innerText = response.data.wishlistCount;
                        const isEmpty = response.data.wishlistCount === 0;
                        wishlistBadge.classList.toggle('opacity-0', isEmpty);
                        wishlistBadge.classList.toggle('scale-0', isEmpty);
                    }
                }
            }).catch(err => console.error("Error updating badges:", err));
        }

        // Initialize badges on load
        document.addEventListener('DOMContentLoaded', updateBadges);


        // Hover Carousel for Similar Products
        document.addEventListener('DOMContentLoaded', () => {
            const cards = document.querySelectorAll('.product-card-similar');
            cards.forEach(card => {
                const images = card.querySelectorAll('.carousel-img');
                if (images.length <= 1) return;

                let intervalId;
                let currentIndex = 0;

                card.addEventListener('mouseenter', () => {
                    intervalId = setInterval(() => {
                        images[currentIndex].classList.remove('opacity-100');
                        images[currentIndex].classList.add('opacity-0');
                        currentIndex = (currentIndex + 1) % images.length;
                        images[currentIndex].classList.remove('opacity-0');
                        images[currentIndex].classList.add('opacity-100');
                    }, 1200);
                });

                card.addEventListener('mouseleave', () => {
                    clearInterval(intervalId);
                    images.forEach((img, idx) => {
                        img.classList.replace('opacity-100', 'opacity-0');
                        if (idx === 0) img.classList.replace('opacity-0', 'opacity-100');
                    });
                    currentIndex = 0;
                });
            });
        });


        document.addEventListener('DOMContentLoaded', () => {
    // find default variant button and trigger selectVariant
    const defaultVariant = productVariants.find(v => v.isDefault) || productVariants[0];
    if (defaultVariant) {
        const defaultBtn = document.querySelector(`[data-variant-id="${defaultVariant.id}"]`);
        if (defaultBtn) selectVariant(defaultVariant.id, defaultBtn);
    }
});

        function changeImage(index, el) {
            const mainImg = document.getElementById('main-image');
            mainImg.style.opacity = '0.4';
            
            setTimeout(() => {
                mainImg.src = currentImages[index];
                mainImg.style.opacity = '1';
                document.querySelectorAll('.thumbnail').forEach(t => t.classList.remove('active'));
                el.classList.add('active');
            }, 150);
        }

        function selectVariant(id, el) {
            const variant = productVariants.find(v => v.id === id);
            if (!variant) return;

            selectedVariantId = id;
            selectedSize = null; // Reset size on variant change

            // Visual feedback for color
            document.querySelectorAll('#color-container button').forEach(btn => {
                btn.classList.remove('ring-black');
                btn.classList.add('ring-transparent');
            });
            el.classList.add('ring-black');
            el.classList.remove('ring-transparent');

            // PRICE
            document.getElementById('product-price').innerText = `₹${variant.price}`;

            // SIZES
            const sizeContainer = document.getElementById('size-container');
            sizeContainer.innerHTML = variant.sizes.map(size => `
                <button onclick="selectSize(this)" 
                    class="size-btn w-12 h-10 border border-gray-200 rounded-lg text-[11px] font-bold hover:border-black transition-all flex items-center justify-center">
                    ${size}
                </button>
            `).join('');

            // IMAGES
            currentImages = variant.images;
            const mainImg = document.getElementById('main-image');
            if (variant.images.length > 0) {
                mainImg.src = variant.images[0];
            }

            // THUMBNAILS
            const thumbnailContainer = document.getElementById('thumbnail-container');
            if (thumbnailContainer) {
                thumbnailContainer.innerHTML = variant.images.map((img, index) => `
                    <button type="button" class="thumbnail ${index === 0 ? 'active' : ''} w-20 h-24 border-2 rounded-lg overflow-hidden flex-shrink-0"
                        onclick="changeImage(${index}, this)">
                        <img src="${img}" class="w-full h-full object-contain mix-blend-multiply">
                    </button>
                `).join('');
            }
        }

        function selectSize(el) {
            selectedSize = el.innerText.trim();
            document.querySelectorAll('.size-btn').forEach(btn => {
                btn.classList.remove('bg-black', 'text-white', 'border-black');
                btn.classList.add('bg-white', 'text-black', 'border-gray-200');
            });
            el.classList.add('bg-black', 'text-white', 'border-black');
            el.classList.remove('bg-white', 'text-black', 'border-gray-200');
        }

        // ZOOM
        function zoomImage(event) {
            const container = event.currentTarget;
            const img = document.getElementById('main-image');
            const rect = container.getBoundingClientRect();
            let x = event.clientX - rect.left;
            let y = event.clientY - rect.top;
            const xPercent = (x / rect.width) * 100;
            const yPercent = (y / rect.height) * 100;
            img.style.transformOrigin = `${xPercent}% ${yPercent}%`;
            img.style.transform = 'scale(2.4)';
        }

        function resetZoom() {
            const img = document.getElementById('main-image');
            img.style.transform = 'scale(1)';
            img.style.transformOrigin = 'center center';
        }

        // API OPERATIONS
        async function addToCart(productId, isSimilar = false) {
            if (!isLoggedIn) {
                showToast("error","Please login to continue");
                return;
            }

            try {
                let data = { productId };
                
                if (!isSimilar) {
                    if (!selectedSize) {
                        showToast("error","Please select a size first");
                        return;
                    }
                    data.variantId = selectedVariantId;
                    data.size = selectedSize;
                }

                const response = await axios.post('/users/addCart', data);
                if (response.data.success) {
                    showToast("success","Added to Cart Successfully");
                    fetchCartCount();
                    updateBadges();
                }else if(response.data.alreadyInCart){
                    showToast("error", "Already in cart!"); 
                }  else if (response.data.outOfStock) {
                    showToast("error", "Sorry, this item is out of stock!");
                }else {
                    showToast(response.data.message || "error","Failed to add to cart");
                }
           } catch (error) {
               console.error("Cart Error:", error);
               const data = error.response?.data;
               if (data?.outOfStock) {
                     showToast("error", "Sorry, this item is out of stock!");
                } else if (data?.alreadyInCart) {
                     showToast("error", "Already in cart!");
                } else {
                      showToast("error", data?.message || "Something went wrong");
                }
            }
        }

        async function toggleWishlist(productId, btn) {
            if (!isLoggedIn) {
                showToast("error","Please login to continue");
                return;
            }

            try {
                const response = await axios.post('/users/toggleWishlist', { productId });
                if (response.data.success) {
                    const icon = btn.querySelector('.material-symbols-outlined');
                    if (response.data.isWishlisted) {
                        icon.classList.add('icon-fill', 'text-red-500');
                        showToast("success","Added to Wishlist");
                    } else {
                        icon.classList.remove('icon-fill', 'text-red-500');
                        showToast("success","Removed from Wishlist");
                    }
                    updateBadges();
                }
            } catch (error) {
                console.error("Wishlist Error:", error);
                showToast("error","Failed to update wishlist");
            }
        }

        async function buyNow(productId) {
            if (!isLoggedIn) {
                showToast("error","Please login to continue");
                return;
            }

            if (!selectedSize) {
                showToast("error","Please select a size first");
                return;
            }
            await addToCart(productId);
            window.location.href = '/users/cart';
        }
    </script>

</body>

</html>