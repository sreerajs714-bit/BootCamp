    <!-- Interaction Script -->
    <script>
        const imageSources = [
            'https://images.unsplash.com/photo-1542291026-7eec264c27ff?q=80&w=1200&auto=format&fit=crop',
            'https://images.unsplash.com/photo-1608231387042-66d1773070a5?q=80&w=1200&auto=format&fit=crop',
            'https://images.unsplash.com/photo-1551107696-a4b0c5a0d9a2?q=80&w=1200&auto=format&fit=crop'
        ];

        // Changing the main image from thumbnail
        function changeImage(index, element) {
            const mainImg = document.getElementById('main-image');

            // Fade out
            mainImg.style.opacity = '0.3';

            setTimeout(() => {
                mainImg.src = imageSources[index];
                // Fade back in
                requestAnimationFrame(() => {
                    mainImg.style.opacity = '1';
                });
            }, 200); // 200ms matches approx transition

            // Update active state on thumbnails
            document.querySelectorAll('.thumbnail').forEach(th => {
                th.classList.remove('active');
            });
            element.classList.add('active');
        }

        // Image Zoom Logic
        function zoomImage(event) {
            const container = event.currentTarget;
            const img = document.getElementById('main-image');

            // Get boundaries of the container
            const rect = container.getBoundingClientRect();

            // Calculate mouse position relative to container
            let x = event.clientX - rect.left;
            let y = event.clientY - rect.top;

            // Cap the values to stay safely inside bounds
            x = Math.max(0, Math.min(x, rect.width));
            y = Math.max(0, Math.min(y, rect.height));

            // Convert to percentage
            const xPercent = (x / rect.width) * 100;
            const yPercent = (y / rect.height) * 100;

            // Move origin dynamically as user moves mouse
            img.style.transformOrigin = `${xPercent}% ${yPercent}%`;

            // Scale up if not already scaled
            if (!container.dataset.zooming) {
                img.style.transform = 'scale(2.4)';
                container.dataset.zooming = "true";
            }
        }

        function resetZoom(event) {
            const container = event.currentTarget;
            const img = document.getElementById('main-image');

            // Revert scale
            img.style.transform = 'scale(1)';
            container.dataset.zooming = "";

            // Reset origin smoothly after scale finishes
            setTimeout(() => {
                if (!container.dataset.zooming) {
                    img.style.transformOrigin = 'center center';
                }
            }, 300);
        }

        // Color selector logic
        function selectColor(btn) {
            document.querySelectorAll('.color-selector-btn').forEach(b => {
                b.classList.remove('ring-black');
                b.classList.add('ring-transparent');
            });
            btn.classList.add('ring-black');
            btn.classList.remove('ring-transparent', 'hover:ring-gray-300');
        }

        // Product Carousel logic
        document.addEventListener('DOMContentLoaded', () => {
            const cards = document.querySelectorAll('.product-grid-card');

            cards.forEach(card => {
                const images = card.querySelectorAll('.carousel-img');
                if (images.length <= 1) return;

                let intervalId;
                let currentIndex = 0;

                card.addEventListener('mouseenter', () => {
                    intervalId = setInterval(() => {
                        images[currentIndex].classList.remove('opacity-100');
                        images[currentIndex].classList.add('opacity-0');
                        currentIndex = (currentIndex + 1) % images.length;
                        images[currentIndex].classList.remove('opacity-0');
                        images[currentIndex].classList.add('opacity-100');
                    }, 1000);
                });

                card.addEventListener('mouseleave', () => {
                    clearInterval(intervalId);
                    images.forEach((img, idx) => {
                        if (idx === 0) {
                            img.classList.remove('opacity-0');
                            img.classList.add('opacity-100');
                        } else {
                            img.classList.remove('opacity-100');
                            img.classList.add('opacity-0');
                        }
                    });
                    currentIndex = 0;
                });
            });
        });
    </script>
</body>

</html>