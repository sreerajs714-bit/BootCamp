<body class="bg-surface font-body text-on-surface selection:bg-primary-container selection:text-white">
<!-- Auth Layout Wrapper: Split Screen 1292x1024 Logic -->
<main class="min-h-screen grid grid-cols-1 md:grid-cols-2 overflow-hidden">
<!-- Left Side: The Monolith Visual -->
<section class="relative hidden md:flex items-center justify-center bg-primary overflow-hidden">
<div class="absolute inset-0 z-0">
<img alt="Elite football boot" class="w-full h-full object-cover opacity-60" data-alt="Close-up of a high-end black aerodynamic football boot with intricate textures, positioned dramatically against a dark, moody studio background with rim lighting" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAVieDVWn4TtfGIovxJhhS8np8vTyYa0N8TH0p8zXfifPb7pKQcOCz675n3zHUIZ1Sl59JZFkBZ2p0IKDwcERA-jWnfRDP7c-KN9B7v8937880xLCFqYvNQ_hZ2yEiH32sMCgtwUadzoXmWkTRNQbsdXtgtvojZUWgSb1o87ZwwKqu2Gk9QFP1xONfouroUasLxyQME2ZrNzv_KOMWa-QF7oOuw_7SjNShQuCd63fnyQ9cMwvJi_Ej6L7G45UwaFGcZRnTUXOlr-To" style="">
<div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-black/40"></div>
</div>
<div class="relative z-10 flex flex-col items-center text-center px-12">
<h1 class="font-headline font-black text-7xl lg:text-8xl tracking-tighter text-white mb-4" style="">
    <span class="letter">B</span><span class="letter">O</span><span class="letter">O</span><span class="letter">T</span>&nbsp;<span class="letter">C</span><span class="letter">A</span><span class="letter">M</span><span class="letter">P</span>
</h1>
<p class="subtitle-anim font-headline font-bold text-xl tracking-[0.4em] text-on-primary uppercase" style="">
                    STEP INTO PERFORMANCE
                </p>
</div>
</section>
<!-- Right Side: The Canvas (Form) -->
<section class="bg-surface-container-lowest flex flex-col justify-center items-center px-8 md:px-24 py-12 relative">
<!-- Mobile Logo (Suppress on desktop as per Shell visibility rules for linear journeys) -->
<div class="md:hidden absolute top-12 left-8">
<span class="font-headline font-black text-2xl tracking-tighter" style="">
    <span class="letter">B</span><span class="letter">O</span><span class="letter">O</span><span class="letter">T</span>&nbsp;<span class="letter">C</span><span class="letter">A</span><span class="letter">M</span><span class="letter">P</span>
</span>
</div>
<div class="w-full max-w-md">
<!-- Header Block -->
<header class="mb-12">
<h2 class="font-headline font-black text-4xl lg:text-5xl tracking-tighter text-primary uppercase leading-none mb-4" style="">
                        SET NEW PASSWORD
                    </h2>
<p class="text-on-surface-variant font-medium leading-relaxed max-w-xs" style="">
                        Choose a secure password to protect your performance data.
                    </p>
</header>
<!-- Form -->
<form id="resetForm" class="space-y-10" action="/users/setNew" method="post">
<input type="hidden" name="email" value="{{email}}">
<!-- Field 1: New Password -->
<div class="group">
<div class="relative">
<input id="password" name="password" class="w-full text-[14px] bg-transparent border-0 border-b-2 border-outline-variant py-0 px-0 focus:ring-0 focus:border-primary transition-all placeholder:text-outline-variant" placeholder="NEW PASSWORD" type="password">
<button onclick="togglePassword()" class="absolute right-0 top-1/2 -translate-y-1/2 text-outline hover:text-primary" type="button" style="">
<span class="material-symbols-outlined" data-icon="visibility" style="font-size: 20px">visibility</span>
</button>
</div>
</div>
<!-- Field 2: Confirm Password -->
<div class="group">
<div class="relative">
<input id="cfmpassword" name="cfmpassword" class="w-full text-[14px] bg-transparent border-0 border-b-2 border-outline-variant py-0 px-0 focus:ring-0 focus:border-primary transition-all placeholder:text-outline-variant" placeholder="CONFIRM PASSWORD" type="password">
<button onclick="toggle_cfmPassword()" class="absolute right-0 top-1/2 -translate-y-1/2 text-outline hover:text-primary" type="button" style="">
<span class="material-symbols-outlined" data-icon="visibility" style="font-size: 20px;">visibility</span>
</button>
</div>
</div>
<!-- CTA Block -->
<div class="pt-6">
<button class="group w-full bg-primary text-on-primary py-5 px-8 flex items-center justify-between font-headline font-bold text-sm tracking-widest uppercase transition-all hover:bg-primary-container active:scale-[0.98]" style="">
<span class="" style="">RESET PASSWORD</span>
<span class="material-symbols-outlined transition-transform group-hover:translate-x-1" data-icon="arrow_forward" style="">arrow_forward</span>
</button>
</div>
</form>
<!-- Footer Navigation -->
<footer class="mt-16 pt-8 border-t border-surface-container">
<a class="inline-flex items-center gap-2 font-headline font-bold text-xs tracking-widest text-outline hover:text-primary uppercase transition-colors group" href="/users/login" style="">
<span class="material-symbols-outlined text-sm" data-icon="arrow_back" style="">arrow_back</span>
<span class="" style="">Back to Login</span>
</a>
</footer>
</div>
<!-- Subtle Brand Anchor -->
<div class="absolute bottom-12 right-12 hidden md:block">
<p class="font-headline font-black text-primary/5 text-6xl select-none leading-none" style=""><br></p>
</div>
</section>
</main>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    document.addEventListener("DOMContentLoaded", () => {
        const subtitleDuration = 1000; // 1s
        const delayBetweenLetters = 100; // 0.1s

        const allLetters = document.querySelectorAll('.letter');
        allLetters.forEach((span, index) => {
            // Modulo by 8 assuming the word 'BOOT CAMP' has 8 animated letters. 
            // This ensures both mobile and desktop instances animate in sync and stagger correctly.
            span.style.animationDelay = `${subtitleDuration + ((index % 8) * delayBetweenLetters)}ms`;
        });
    });

document.addEventListener("DOMContentLoaded", function () {

    const form = document.getElementById("resetForm");

    form.addEventListener("submit", function (e) {
        e.preventDefault();

        const password = document.getElementById("password").value
        const cfmpassword = document.getElementById("cfmpassword").value

        if (password === "" || cfmpassword === "") {
            Swal.fire({
                icon: "warning",
                text: "Fill All The Fields"
            });
            return;
        }

        if (password !== cfmpassword) {
            Swal.fire({
                icon: "error",
                text: "Password Must Match"
            });
            return;
        }

        if (password.length < 4) {
            Swal.fire({
                icon: "warning",
                title: "Oops...",
                text: "Password must be at least 4 characters"
            });
            return;
        }

        // ✅ ONLY submit if everything is valid
        form.submit();
    });

});  

function togglePassword(){

const password = document.getElementById("password");

if(password.type === "password"){
password.type = "text";
}else{
password.type = "password";
}

}

function toggle_cfmPassword(){

const password = document.getElementById("cfmpassword");

if(password.type === "password"){
password.type = "text";
}else{
password.type = "password";
}

}
</script>

{{#if message}}
<script>
  document.addEventListener("DOMContentLoaded", function () {
    Swal.fire({
      text: "{{message}}",
      confirmButtonColor: "#000000"
    });
  });
</script>
{{/if}}
</body></html>
