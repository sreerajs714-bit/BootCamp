<!DOCTYPE html>
<html class="light" lang="en">

<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <title>BOOT CAMP | Set New Password</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800;900&amp;family=Inter:wght@300;400;500;600;700&amp;display=swap"
        rel="stylesheet">
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "surface-container-high": "#e8e8e8",
                        "primary-container": "#3b3b3b",
                        "on-error-container": "#410002",
                        "surface-container-highest": "#e2e2e2",
                        "on-secondary-fixed": "#1b1c1c",
                        "on-primary": "#e2e2e2",
                        "secondary-fixed-dim": "#acabab",
                        "outline": "#777777",
                        "on-secondary-container": "#1b1c1c",
                        "tertiary-fixed": "#5e5e5e",
                        "outline-variant": "#c6c6c6",
                        "error": "#ba1a1a",
                        "tertiary": "#3b3b3b",
                        "on-primary-container": "#ffffff",
                        "inverse-primary": "#c6c6c6",
                        "surface": "#f9f9f9",
                        "tertiary-fixed-dim": "#474747",
                        "primary": "#000000",
                        "on-background": "#1a1c1c",
                        "secondary": "#5f5e5e",
                        "surface-container": "#eeeeee",
                        "inverse-on-surface": "#f1f1f1",
                        "error-container": "#ffdad6",
                        "on-secondary-fixed-variant": "#3b3b3b",
                        "surface-container-lowest": "#ffffff",
                        "on-tertiary-fixed-variant": "#e2e2e2",
                        "primary-fixed": "#5e5e5e",
                        "surface-bright": "#f9f9f9",
                        "primary-fixed-dim": "#474747",
                        "tertiary-container": "#747474",
                        "on-tertiary-fixed": "#ffffff",
                        "surface-dim": "#dadada",
                        "secondary-container": "#d6d4d3",
                        "background": "#f9f9f9",
                        "on-error": "#ffffff",
                        "on-surface-variant": "#474747",
                        "on-surface": "#1a1c1c",
                        "surface-variant": "#e2e2e2",
                        "on-primary-fixed": "#ffffff",
                        "inverse-surface": "#2f3131",
                        "on-tertiary": "#e2e2e2",
                        "on-tertiary-container": "#ffffff",
                        "on-secondary": "#ffffff",
                        "on-primary-fixed-variant": "#e2e2e2",
                        "surface-tint": "#5e5e5e",
                        "surface-container-low": "#f3f3f3",
                        "secondary-fixed": "#c8c6c6"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "fontFamily": {
                        "headline": ["Space Grotesk"],
                        "body": ["Inter"],
                        "label": ["Inter"]
                    }
                },
            }
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .text-vertical {
            writing-mode: vertical-rl;
            text-orientation: mixed;
        }

        /* Entrance Animations */
        @keyframes slideInFromLeft {
            0% {
                transform: translateX(-150%);
                opacity: 0;
            }

            80% {
                transform: translateX(10%);
                opacity: 1;
            }

            100% {
                transform: translateX(0);
                opacity: 1;
            }
        }

        .subtitle-anim {
            opacity: 0;
            animation: slideInFromLeft 1s cubic-bezier(0.25, 1, 0.5, 1) forwards;
        }

        @keyframes dropInFromTop {
            0% {
                opacity: 0;
                transform: translateY(-80px);
            }

            60% {
                opacity: 1;
                transform: translateY(10px);
            }

            80% {
                transform: translateY(-5px);
            }

            100% {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .letter {
            display: inline-block;
            opacity: 0;
            animation: dropInFromTop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        }
    </style>
</head>

<body class="bg-surface font-body text-on-surface selection:bg-primary-container selection:text-white">
    <!-- Auth Layout Wrapper: Split Screen 1292x1024 Logic -->
    <main class="min-h-screen grid grid-cols-1 md:grid-cols-2 overflow-hidden">
        <!-- Left Side: The Monolith Visual -->
        <section class="relative hidden md:flex items-center justify-center bg-primary overflow-hidden">
            <div class="absolute inset-0 z-0">
                <img alt="Elite football boot" class="w-full h-full object-cover opacity-60"
                    data-alt="Close-up of a high-end black aerodynamic football boot with intricate textures, positioned dramatically against a dark, moody studio background with rim lighting"
                    src="https://lh3.googleusercontent.com/aida-public/AB6AXuAVieDVWn4TtfGIovxJhhS8np8vTyYa0N8TH0p8zXfifPb7pKQcOCz675n3zHUIZ1Sl59JZFkBZ2p0IKDwcERA-jWnfRDP7c-KN9B7v8937880xLCFqYvNQ_hZ2yEiH32sMCgtwUadzoXmWkTRNQbsdXtgtvojZUWgSb1o87ZwwKqu2Gk9QFP1xONfouroUasLxyQME2ZrNzv_KOMWa-QF7oOuw_7SjNShQuCd63fnyQ9cMwvJi_Ej6L7G45UwaFGcZRnTUXOlr-To"
                    style="">
                <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-black/40"></div>
            </div>
            <div class="relative z-10 flex flex-col items-center text-center px-12">
                <h1 class="font-headline font-black text-7xl lg:text-8xl tracking-tighter text-white mb-4" style="">
                    <span class="letter">B</span><span class="letter">O</span><span class="letter">O</span><span
                        class="letter">T</span>&nbsp;<span class="letter">C</span><span class="letter">A</span><span
                        class="letter">M</span><span class="letter">P</span>
                </h1>
                <p class="subtitle-anim font-headline font-bold text-xl tracking-[0.4em] text-on-primary uppercase"
                    style="">
                    STEP INTO PERFORMANCE
                </p>
            </div>
        </section>
        <!-- Right Side: The Canvas (Form) -->
        <section
            class="bg-surface-container-lowest flex flex-col justify-center items-center px-8 md:px-24 py-12 relative">
            <!-- Mobile Logo (Suppress on desktop as per Shell visibility rules for linear journeys) -->
            <div class="md:hidden absolute top-12 left-8">
                <span class="font-headline font-black text-2xl tracking-tighter" style="">
                    <span class="letter">B</span><span class="letter">O</span><span class="letter">O</span><span
                        class="letter">T</span>&nbsp;<span class="letter">C</span><span class="letter">A</span><span
                        class="letter">M</span><span class="letter">P</span>
                </span>
            </div>
            <div class="w-full max-w-md">
                <!-- Header Block -->
                <header class="mb-12">
                    <h2 class="font-headline font-black text-4xl lg:text-5xl tracking-tighter text-primary uppercase leading-none mb-4"
                        style="">
                        SET NEW PASSWORD
                    </h2>
                    <p class="text-on-surface-variant font-medium leading-relaxed max-w-xs" style="">
                        Choose a secure password to protect your performance data.
                    </p>
                </header>
                <!-- Form -->
                <form id="resetForm" class="space-y-10" action="/users/setNew" method="post">
                    <input type="hidden" name="email" value="{{email}}">
                    <!-- Field 1: New Password -->
                    <div class="group">
                        <div class="relative">
                            <input id="password" name="password"
                                class="w-full text-[14px] bg-transparent border-0 border-b-2 border-outline-variant py-0 px-0 focus:ring-0 focus:border-primary transition-all placeholder:text-outline-variant"
                                placeholder="NEW PASSWORD" type="password">
                            <button onclick="togglePassword()"
                                class="absolute right-0 top-1/2 -translate-y-1/2 text-outline hover:text-primary"
                                type="button" style="">
                                <span class="material-symbols-outlined" data-icon="visibility"
                                    style="font-size: 20px">visibility</span>
                            </button>
                        </div>
                        <p id="password-error" class="text-[11px] mt-1 hidden" style="color: #ba1a1a;"></p>
                        <!-- Password Strength Indicator -->
                        <div id="password-requirements" class="hidden mt-3 space-y-2 text-[10px] font-bold tracking-wider uppercase text-outline">
                            <div class="flex items-center gap-2 requirement" data-req="length">
                                <span class="material-symbols-outlined text-[14px]">circle</span> 8+ Characters
                            </div>
                            <div class="flex items-center gap-2 requirement" data-req="uppercase">
                                <span class="material-symbols-outlined text-[14px]">circle</span> Uppercase Letter
                            </div>
                            <div class="flex items-center gap-2 requirement" data-req="lowercase">
                                <span class="material-symbols-outlined text-[14px]">circle</span> Lowercase Letter
                            </div>
                            <div class="flex items-center gap-2 requirement" data-req="number">
                                <span class="material-symbols-outlined text-[14px]">circle</span> One Number
                            </div>
                            <div class="flex items-center gap-2 requirement" data-req="special">
                                <span class="material-symbols-outlined text-[14px]">circle</span> Special Character
                            </div>
                        </div>
                    </div>
                    <!-- Field 2: Confirm Password -->
                    <div class="group">
                        <div class="relative">
                            <input id="cfmpassword" name="cfmpassword"
                                class="w-full text-[14px] bg-transparent border-0 border-b-2 border-outline-variant py-0 px-0 focus:ring-0 focus:border-primary transition-all placeholder:text-outline-variant"
                                placeholder="CONFIRM PASSWORD" type="password">
                            <button onclick="toggle_cfmPassword()"
                                class="absolute right-0 top-1/2 -translate-y-1/2 text-outline hover:text-primary"
                                type="button" style="">
                                <span class="material-symbols-outlined" data-icon="visibility"
                                    style="font-size: 20px;">visibility</span>
                            </button>
                        </div>
                        <p id="cfmpassword-error" class="text-[11px] mt-1 hidden " style="color: #ba1a1a;"></p>
                    </div>
                    <!-- CTA Block -->
                    <div class="pt-6">
                        <button type="submit" 
                            class="group w-full bg-primary text-on-primary py-5 px-8 flex items-center justify-between font-headline font-bold text-sm tracking-widest uppercase transition-all hover:bg-primary-container active:scale-[0.98]"
                            style="">
                            <span class="" style="">RESET PASSWORD</span>
                            <span class="material-symbols-outlined transition-transform group-hover:translate-x-1"
                                data-icon="arrow_forward" style="">arrow_forward</span>
                        </button>
                    </div>
                </form>
                <!-- Footer Navigation -->
                <footer class="mt-16 pt-8 border-t border-surface-container">
                    <a class="inline-flex items-center gap-2 font-headline font-bold text-xs tracking-widest text-outline hover:text-primary uppercase transition-colors group"
                        href="/users/login" style="">
                        <span class="material-symbols-outlined text-sm" data-icon="arrow_back"
                            style="">arrow_back</span>
                        <span class="" style="">Back to Login</span>
                    </a>
                </footer>
            </div>
            <!-- Subtle Brand Anchor -->
            <div class="absolute bottom-12 right-12 hidden md:block">
                <p class="font-headline font-black text-primary/5 text-6xl select-none leading-none" style=""><br></p>
            </div>
        </section>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="/toast/toast.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>    
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const subtitleDuration = 1000; // 1s
            const delayBetweenLetters = 100; // 0.1s

            const allLetters = document.querySelectorAll('.letter');
            allLetters.forEach((span, index) => {
                span.style.animationDelay = `${subtitleDuration + ((index % 8) * delayBetweenLetters)}ms`;
            });
        });

        function showError(id, message) {
            const errorElement = document.getElementById(`${id}-error`);
            if (errorElement) {
                errorElement.textContent = message;
                errorElement.classList.remove('hidden');
                errorElement.style.display = 'block';
            }
        }

        function clearError(id) {
            const errorElement = document.getElementById(`${id}-error`);
            if (errorElement) {
                errorElement.textContent = '';
                errorElement.classList.add('hidden');
                errorElement.style.display = 'none';
            }
        }

        document.addEventListener("DOMContentLoaded", function () {

            const form = document.getElementById("resetForm");

            form.addEventListener("submit", function (e) {
    e.preventDefault();

    const password = document.getElementById("password").value;
    const cfmpassword = document.getElementById("cfmpassword").value;

    // Clear all errors first
    ['password', 'cfmpassword'].forEach(clearError);  // this will now work

    let isValid = true;

    if (password === "") {
        showError('password', 'Password is required');
        isValid = false;
    }

    // Renamed to passwordRules to avoid conflict with global `requirements`
    const passwordRules = {
        length: val => val.length >= 8,
        uppercase: val => /[A-Z]/.test(val),
        lowercase: val => /[a-z]/.test(val),
        number: val => /[0-9]/.test(val),
        special: val => /[^A-Za-z0-9]/.test(val)
    };

    const isStrong = Object.values(passwordRules).every(req => req(password));
    if (password !== "" && !isStrong) {
        showError('password', 'Please meet all password requirements');
        isValid = false;
    }

    if (cfmpassword === "") {
    showError('cfmpassword', 'Confirmation is required');
    isValid = false;
} else if (password !== "" && password !== cfmpassword) {
    showToast('cfmpassword', 'Passwords do not match');
    isValid = false;
}

    if (!isValid) return;

    submitForm(password);
});

        });

        async function submitForm(password) {
            const form = document.getElementById("resetForm");
            const submitBtn = form.querySelector('button[type="submit"]');
            const spanText = submitBtn.querySelector('span:first-child');
            const originalText = spanText.textContent;
            const email = form.querySelector('input[name="email"]').value;

            try {
                submitBtn.disabled = true;
                spanText.textContent = 'RESETTING...';

                const response = await axios.post('/users/setNew', {
                    email,
                    password
                });

                if (response.data.success || response.status === 200) {
                    showToast('success','Your password has been successfully reset.')
                    .then(() => {
                        window.location.href = '/users/login';
                    });
                } else {
                    throw new Error(response.data.message || 'Reset failed');
                }

            } catch (error) {
                showToast( error.response?.data?.message || error.message || "error",'Something went wrong. Please try again.');
            } finally {
                submitBtn.disabled = false;
                spanText.textContent = originalText;
            }
        }

        // Live Password Validation
        const passwordInput = document.getElementById('password');
        const requirementsContainer = document.getElementById('password-requirements');
        const requirements = {
            length: val => val.length >= 8,
            uppercase: val => /[A-Z]/.test(val),
            lowercase: val => /[a-z]/.test(val),
            number: val => /[0-9]/.test(val),
            special: val => /[^A-Za-z0-9]/.test(val)
        };

        passwordInput.addEventListener('focus', () => {
            requirementsContainer.classList.remove('hidden');
        });

        passwordInput.addEventListener('input', () => {
            const value = passwordInput.value;
            clearError('password');
            Object.keys(requirements).forEach(req => {
                const isValid = requirements[req](value);
                const element = requirementsContainer.querySelector(`[data-req="${req}"]`);
                const icon = element.querySelector('.material-symbols-outlined');

                if (isValid) {
                    element.classList.remove('text-outline');
                    element.classList.add('text-green-600');
                    icon.textContent = 'check_circle';
                } else {
                    element.classList.add('text-outline');
                    element.classList.remove('text-green-600');
                    icon.textContent = 'circle';
                }
            });
        });

        document.getElementById('cfmpassword').addEventListener('input', () => {
            clearError('cfmpassword');
        });

        function togglePassword() {

            const password = document.getElementById("password");

            if (password.type === "password") {
                password.type = "text";
            } else {
                password.type = "password";
            }

        }

        function toggle_cfmPassword() {

            const password = document.getElementById("cfmpassword");

            if (password.type === "password") {
                password.type = "text";
            } else {
                password.type = "password";
            }

        }
    </script>
</body>

</html>