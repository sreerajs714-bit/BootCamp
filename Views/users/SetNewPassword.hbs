<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Set New Password | BootCamp</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

    <!-- Toastify -->
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #000;
            overflow: hidden;
        }

        .glass {
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        @keyframes pulse-glow {
            0%, 100% { opacity: 0.75; }
            50% { opacity: 1; }
        }

        .animate-pulse-glow {
            animation: pulse-glow 5s infinite;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .animate-fadeIn {
            animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        /* Video Background */
        .video-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            z-index: -1;
        }

        .video-container::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.4);
        }

        video {
            min-width: 100%;
            min-height: 100%;
            object-fit: cover;
        }

        /* Custom Input focus */
        .custom-input:focus {
            border-color: rgba(147, 51, 234, 0.5);
            outline: none;
        }
        
        .overflow-y-auto::-webkit-scrollbar {
            display: none;
        }
        .overflow-y-auto {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        @keyframes success-pop {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); border-color: #10b981; }
            100% { transform: scale(1); }
        }

        .animate-success {
            animation: success-pop 0.5s ease-in-out forwards;
        }
    </style>
</head>

<body class="text-white min-h-screen flex items-center justify-center p-4">

    <!-- Video Background -->
    <div class="video-container" style="position:fixed; top:0; left:0; width:100%; height:100%; z-index:0;">
    <img src="/uploads/images/setnew.png" alt="" style="width:100%; height:100%; object-fit:cover;">
    </div>

    <!-- Main Container -->
    <div class="relative z-20 w-full max-w-md animate-fadeIn my-auto">
        <div class="p-8 rounded-2xl glass max-h-[90vh] overflow-y-auto">
            
            <!-- Logo/Header Area -->
            <div class="mb-8 text-center">
                <h2 class="text-3xl font-bold mb-2 relative group inline-block">
                    <span class="absolute -inset-1 bg-gradient-to-r from-purple-600/30 via-pink-500/30 to-blue-500/30 blur-xl opacity-75 group-hover:opacity-100 transition-all duration-500 animate-pulse-glow"></span>
                    <span class="relative inline-block text-3xl font-black tracking-tighter text-white uppercase">
                        BootCamp
                    </span>
                </h2>
                
                <div class="mt-4 flex flex-col items-center space-y-2">
                    <h3 class="text-xl font-bold tracking-tight text-white uppercase">SET NEW PASSWORD</h3>
                    <p class="text-white/60 text-sm max-w-[280px] mx-auto text-center">Establish a new high-performance credential for your account.</p>
                </div>
            </div>

            <!-- New Password Form -->
            <form id="set-password-form" class="space-y-6" action="/users/setNew" method="POST">
                
                <!-- Email hidden field -->
                <input type="hidden" name="email" value="{{email}}">

                <!-- Password Input -->
                <div class="group">
                    <div class="relative">
                        <div class="absolute left-3 top-1/2 -translate-y-1/2 text-white/40 group-focus-within:text-purple-400 transition-colors">
                            <span class="material-symbols-outlined text-[20px]">lock_reset</span>
                        </div>
                        <input type="password" id="password" name="password" placeholder="NEW PASSWORD" required
                            class="w-full pl-11 pr-12 py-4 bg-white/5 border border-white/10 rounded-xl text-white placeholder-white/20 custom-input transition-all duration-300 font-bold text-[13px] tracking-widest uppercase">
                        <button type="button" id="toggle-password"
                            class="absolute right-4 top-1/2 -translate-y-1/2 text-white/40 hover:text-white transition-colors">
                            <span class="material-symbols-outlined text-[20px]">visibility</span>
                        </button>
                    </div>
                    <p id="password-error" class="text-red-400 text-[10px] mt-2 hidden font-black uppercase tracking-[0.1em]"></p>
                    
                    <!-- Password Requirements Checklist -->
                    <div id="password-requirements" class="hidden mt-4 grid grid-cols-2 gap-2 text-[9px] font-black uppercase tracking-widest text-white/30">
                        <div class="flex items-center gap-2 requirement" data-req="length">
                            <span class="material-symbols-outlined text-[14px]">circle</span> 8+ Characters
                        </div>
                        <div class="flex items-center gap-2 requirement" data-req="uppercase">
                            <span class="material-symbols-outlined text-[14px]">circle</span> Uppercase
                        </div>
                        <div class="flex items-center gap-2 requirement" data-req="lowercase">
                            <span class="material-symbols-outlined text-[14px]">circle</span> Lowercase
                        </div>
                        <div class="flex items-center gap-2 requirement" data-req="number">
                            <span class="material-symbols-outlined text-[14px]">circle</span> One Number
                        </div>
                        <div class="flex items-center gap-2 requirement" data-req="special">
                            <span class="material-symbols-outlined text-[14px]">circle</span> Special Char
                        </div>
                    </div>
                </div>

                <!-- Confirm Password -->
                <div class="group">
                    <div class="relative">
                        <div class="absolute left-3 top-1/2 -translate-y-1/2 text-white/40 group-focus-within:text-purple-400 transition-colors">
                            <span class="material-symbols-outlined text-[20px]">shield</span>
                        </div>
                        <input type="password" id="cfmpassword" name="cfmpassword" placeholder="CONFIRM PASSWORD" required
                            class="w-full pl-11 pr-12 py-4 bg-white/5 border border-white/10 rounded-xl text-white placeholder-white/20 custom-input transition-all duration-300 font-bold text-[13px] tracking-widest uppercase">
                        <button type="button" id="toggle-cfmpassword"
                            class="absolute right-4 top-1/2 -translate-y-1/2 text-white/40 hover:text-white transition-colors">
                            <span class="material-symbols-outlined text-[20px]">visibility</span>
                        </button>
                    </div>
                    <p id="cfmpassword-error" class="text-red-400 text-[10px] mt-2 hidden font-black uppercase tracking-[0.1em]"></p>
                </div>

                <!-- Submit Button -->
                <div class="pt-2">
                    <button type="submit" id="submit-btn"
                        class="w-full py-4 bg-purple-600 hover:bg-purple-700 text-white font-black uppercase tracking-widest text-[11px] rounded-xl transition-all duration-300 transform hover:-translate-y-1 shadow-lg shadow-purple-500/20 hover:shadow-purple-500/40 flex items-center justify-between px-8 group">
                        <span id="btn-text">RESET PASSWORD</span>
                        <span class="material-symbols-outlined text-[18px] transition-transform group-hover:translate-x-1">arrow_forward</span>
                    </button>
                    
                    <div class="mt-8 flex justify-center">
                        <a href="/users/login" class="text-[10px] font-black uppercase tracking-[0.2em] text-white/40 hover:text-white transition-colors border-b border-transparent hover:border-white/20 pb-1">
                            Back to Login
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Page Footer -->
    <footer class="absolute bottom-6 left-0 right-0 text-center text-white/20 text-[10px] font-black uppercase tracking-[0.3em] z-20">
        © 2026 Boot Camp Protocol
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="/toast/toast.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Password Visibility Toggles
        function setupVisibility(btnId, inputId) {
            const btn = document.getElementById(btnId);
            const input = document.getElementById(inputId);
            btn.addEventListener('click', () => {
                const isPassword = input.type === 'password';
                input.type = isPassword ? 'text' : 'password';
                btn.querySelector('.material-symbols-outlined').textContent = isPassword ? 'visibility_off' : 'visibility';
            });
        }
        setupVisibility('toggle-password', 'password');
        setupVisibility('toggle-cfmpassword', 'cfmpassword');

        // Validation Helpers
        const passwordInput = document.getElementById('password');
        const cfmInput = document.getElementById('cfmpassword');
        const requirementsContainer = document.getElementById('password-requirements');
        const requirements = {
            length: val => val.length >= 8,
            uppercase: val => /[A-Z]/.test(val),
            lowercase: val => /[a-z]/.test(val),
            number: val => /[0-9]/.test(val),
            special: val => /[^A-Za-z0-9]/.test(val)
        };

        function showError(id, msg) {
            const el = document.getElementById(`${id}-error`);
            el.textContent = msg;
            el.classList.remove('hidden');
        }

        function clearError(id) {
            document.getElementById(`${id}-error`).classList.add('hidden');
        }

        // Live Password Requirements Checklist
        passwordInput.addEventListener('focus', () => {
            requirementsContainer.classList.remove('hidden');
        });

        passwordInput.addEventListener('input', () => {
            clearError('password');
            const value = passwordInput.value;
            Object.keys(requirements).forEach(req => {
                const isValid = requirements[req](value);
                const element = requirementsContainer.querySelector(`[data-req="${req}"]`);
                const icon = element.querySelector('.material-symbols-outlined');

                if (isValid) {
                    element.classList.remove('text-white/30');
                    element.classList.add('text-green-400');
                    icon.textContent = 'check_circle';
                } else {
                    element.classList.add('text-white/30');
                    element.classList.remove('text-green-400');
                    icon.textContent = 'circle';
                }
            });
        });

        cfmInput.addEventListener('input', () => clearError('cfmpassword'));

        // Form Logic
        const form = document.getElementById('set-password-form');
        const submitBtn = document.getElementById('submit-btn');
        const btnText = document.getElementById('btn-text');

        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const password = passwordInput.value;
            const cfmpassword = cfmInput.value;
            const email = form.querySelector('input[name="email"]').value;

            // Final Validation
            let isValid = true;
            const isStrong = Object.values(requirements).every(req => req(password));

            if (!password) { showError('password', 'Password is required'); isValid = false; }
            else if (!isStrong) { showError('password', 'Please meet all requirements'); isValid = false; }

            if (password !== cfmpassword) { showError('cfmpassword', 'Passwords do not match'); isValid = false; }

            if (!isValid) return;

            // Execution
            submitBtn.disabled = true;
            const originalText = btnText.textContent;
            btnText.textContent = 'UPDATING...';

            try {
                const response = await axios.post(form.action, { email, password });

                if (response.data.success || response.status === 200) {
                    submitBtn.classList.add('animate-success');
                    btnText.textContent = 'PASSWORD RESET';
                    showToast("success", "Your credentials have been updated.");
                    
                    setTimeout(() => {
                        window.location.href = "/users/login";
                    }, 2000);
                } else {
                    throw new Error(response.data.message || "Reset failed");
                }
            } catch (err) {
                submitBtn.disabled = false;
                btnText.textContent = originalText;
                const msg = err.response?.data?.message || err.message || "Network link failure";
                showToast("error", msg);
            }
        });

        // Toast Helper
        function showToast(type, msg) {
            Toastify({
                text: msg,
                duration: 3000,
                gravity: "top",
                position: "right",
                style: {
                    background: type === "success" ? "rgba(16, 185, 129, 0.9)" : "rgba(239, 68, 68, 0.9)",
                    backdropFilter: "blur(10px)",
                    borderRadius: "12px",
                    fontSize: "12px",
                    fontWeight: "900",
                    textTransform: "uppercase",
                    letterSpacing: "0.1em",
                    border: "1px solid rgba(255,255,255,0.1)"
                }
            }).showToast();
        }
    </script>
</body>

</html>
