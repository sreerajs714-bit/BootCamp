<!DOCTYPE html>
<html lang="en">
<head>
    <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile | BOOT CAMP</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;600;800;900&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,300,0,0" />
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        display: ['Outfit', 'sans-serif'],
                        serif: ['Playfair Display', 'serif'],
                    },
                    colors: {
                        brand: {
                            50: '#f9f9f9',
                            100: '#e7e7e7',
                            200: '#d1d1d1',
                            300: '#b0b0b0',
                            400: '#888888',
                            500: '#6d6d6d',
                            600: '#5d5d5d',
                            700: '#4f4f4f',
                            800: '#454545',
                            900: '#3d3d3d',
                            950: '#000000',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body { background-color: #fbfbfb; color: #000000; }
        .nav-link { position: relative; padding-bottom: 4px; transition: color 0.3s ease; }
        .nav-link::after { content: ''; position: absolute; width: 0; height: 2px; bottom: 0; left: 50%; background-color: #000000; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); transform: translateX(-50%); }
        .nav-link:hover::after { width: 100%; }
        .icon-btn { transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), color 0.2s ease; }
        .icon-btn:hover { transform: scale(1.15); color: #5d5d5d; }
        .sidebar-link { transition: all 0.2s ease; }
        .sidebar-link:hover { color: #000000; }
        .photo-wrapper:hover .photo-overlay { opacity: 1; }
        .photo-overlay { opacity: 0; transition: opacity 0.3s ease; }
    </style>
</head>
<body class="min-h-screen flex flex-col font-sans selection:bg-brand-950 selection:text-white">

    <!-- Navigation -->
   {{>navbar}}
   {{>breadCrumbs}}

    <!-- Main Content -->
    <main class="flex-grow max-w-7xl mx-auto w-full px-6  flex flex-col lg:block relative">

        <!-- Sidebar -->
        <aside class="w-full lg:w-48 lg:fixed lg:top-32 h-fit mb-10 lg:mb-0 pt-12">
            <h3 class="text-[10px] font-bold tracking-[0.15em] text-gray-400 uppercase mb-8">Account</h3>
            <nav class="flex flex-col space-y-6">
                <a href="/users/profile" class="sidebar-link flex items-center text-[13px] font-bold text-black tracking-widest uppercase">
                    <span class="material-symbols-outlined mr-4 text-[20px]">person</span>Profile
                </a>
                <a href="/users/address" class="sidebar-link flex items-center text-[13px] font-medium text-gray-400 tracking-widest uppercase hover:text-black">
                    <span class="material-symbols-outlined mr-4 text-[20px]">location_on</span>Address
                </a>
                <a href="/users/myOrders" class="sidebar-link flex items-center text-[13px] font-medium text-gray-400 tracking-widest uppercase hover:text-black">
                    <span class="material-symbols-outlined mr-4 text-[20px]">inventory_2</span>My Orders
                </a>
                <a href="#" class="sidebar-link flex items-center text-[13px] font-medium text-gray-400 tracking-widest uppercase hover:text-black">
                    <span class="material-symbols-outlined mr-4 text-[20px]">account_balance_wallet</span>Wallet
                </a>
            </nav>
        </aside>

        <!-- Right Content Area -->
        <div class="w-full lg:pl-[16rem] pt-32">

            <!-- Header Section -->
            <div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
                <div>
                    <h3 class="text-[10px] font-bold tracking-[0.2em] text-gray-400 uppercase mb-4">Account Overview</h3>
                    <h1 class="text-5xl font-serif text-black">My Profile</h1>
                </div>
                <div class="flex space-x-4">
                    <a href="/users/editProfile" class="px-6 py-3 bg-black text-white text-[11px] font-bold tracking-widest uppercase hover:bg-gray-800 transition-colors inline-block">
                        Edit Profile
                    </a>
                    <form action="/users/logout" method="post" id="logoutForm">
                        <button type="button" onclick="confirmLogout()"
                            class="px-6 py-3 bg-transparent border border-gray-300 text-black text-[11px] font-bold tracking-widest uppercase hover:border-black transition-colors">
                            Logout
                        </button>
                    </form>
                </div>
            </div>

            <!-- Profile Cards Section -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">

                <!-- Main Profile Card -->
                <div class="md:col-span-2 bg-[#f6f6f6] p-12 flex items-center gap-10">
                    <div class="relative flex-shrink-0 photo-wrapper cursor-pointer" onclick="document.getElementById('profilePhotoInput').click()">
                        <div class="w-40 h-40 overflow-hidden shadow-sm" id="photoContainer">
                            {{#if user.profilePhoto}}
                                <img id="profilePreview" src="{{user.profilePhoto}}" alt="Profile" class="w-full h-full object-cover grayscale">
                            {{else}}
                                <div id="profileInitial" class="w-full h-full bg-black flex items-center justify-center">
                                    <span class="text-white font-serif text-6xl font-light select-none">
                                        {{slice user.username 0 1}}
                                    </span>
                                </div>
                            {{/if}}
                        </div>
                        <div class="photo-overlay absolute inset-0 bg-black/50 flex flex-col items-center justify-center">
                            <span class="material-symbols-outlined text-white text-[28px]">photo_camera</span>
                            <span class="text-white text-[10px] font-bold tracking-widest uppercase mt-1">Change</span>
                        </div>
                        <input type="file" id="profilePhotoInput" accept="image/jpeg,image/jpg,image/png,image/webp" class="hidden">
                    </div>
                    <div>
                        <h2 class="text-4xl font-serif mb-3 text-black">{{user.username}}</h2>
                        {{#if isGoogleUser}}
                            <div class="flex items-center gap-2 mt-2">
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"></path>
                                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"></path>
                                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"></path>
                                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"></path>
                                </svg>
                                <span class="text-[11px] font-medium text-gray-500 tracking-wide">Signed in with Google</span>
                            </div>
                        {{/if}}
                        <p id="uploadStatus" class="text-[11px] tracking-wide mt-2 hidden"></p>
                    </div>
                </div>

                <!-- Right Widgets -->
                <div class="flex flex-col gap-6">

                    <!-- Password Management Widget -->
                    <div class="bg-[#f6f6f6] p-8 flex-grow flex flex-col justify-center border-l-[3px] border-black">
                        <h3 class="text-[10px] font-bold tracking-[0.15em] text-black uppercase mb-5">Password Management</h3>
                        <div class="flex items-end justify-between mb-3">
                            <span class="text-2xl font-serif">Password</span>
                            {{#if isGoogleUser}}
                                <!-- ✅ Disabled for Google users -->
                                <span class="text-[10px] font-bold tracking-[0.1em] text-gray-300 uppercase cursor-not-allowed mb-1"
                                      title="Managed by Google">Unavailable</span>
                            {{else}}
                                <button type="button" onclick="openModal('passwordModal')"
                                    class="text-[10px] font-bold tracking-[0.1em] text-black underline uppercase hover:text-gray-600 mb-1 cursor-pointer">
                                    Change
                                </button>
                            {{/if}}
                        </div>
                    </div>

                    <!-- Email Management -->
                    <div class="bg-black text-white p-8 flex-grow flex flex-col justify-center">
                        <h3 class="text-[10px] font-bold tracking-[0.15em] text-white uppercase mb-5">Email Management</h3>
                        <div class="flex items-center justify-between">
                            <span class="text-2xl font-serif">Email</span>
                            {{#if isGoogleUser}}
                                <!-- ✅ Disabled for Google users -->
                                <span class="text-[10px] font-bold tracking-[0.1em] text-gray-500 uppercase cursor-not-allowed mb-1"
                                      title="Managed by Google">Unavailable</span>
                            {{else}}
                                <button type="button" onclick="openModal('emailModal')"
                                    class="text-[10px] font-bold tracking-[0.1em] text-white underline uppercase hover:text-gray-300 mb-1 cursor-pointer">
                                    Change
                                </button>
                            {{/if}}
                        </div>
                    </div>

                </div>
            </div>

            <!-- Personal Details Section -->
            <div class="mt-8">
                <div class="flex items-center gap-8 mb-10">
                    <h2 class="text-3xl font-serif text-black">Personal Details</h2>
                    <div class="flex-grow h-px bg-gray-200"></div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
                    <div class="border-b border-gray-200 pb-5">
                        <h3 class="text-[10px] font-bold tracking-[0.15em] text-gray-400 uppercase mb-4">Full Name</h3>
                        <p class="text-[15px] font-medium text-black">{{user.username}}</p>
                    </div>
                    <div class="border-b border-gray-200 pb-5">
                        <h3 class="text-[10px] font-bold tracking-[0.15em] text-gray-400 uppercase mb-4">Email Address</h3>
                        <p class="text-[15px] font-medium text-black">{{user.email}}</p>
                    </div>
                    <div class="border-b border-gray-200 pb-5">
                        <h3 class="text-[10px] font-bold tracking-[0.15em] text-gray-400 uppercase mb-4">Phone Number</h3>
                        <p class="text-[15px] font-medium text-black">{{user.phoneNO}}</p>
                    </div>
                </div>
            </div>

        </div>
    </main>

    <!-- Modal Backdrop -->
    <div id="modalBackdrop" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[60] hidden opacity-0 transition-opacity duration-300" onclick="closeAllModals()"></div>

    <!-- Password Modal -->
    <div id="passwordModal" class="fixed top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[90%] max-w-md bg-white z-[70] hidden opacity-0 scale-95 transition-all duration-300 shadow-2xl">
        <div class="p-8">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-3xl font-serif text-black">Change Password</h2>
                <button type="button" onclick="closeModal('passwordModal')" class="text-gray-400 hover:text-black transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <p id="passwordError" class="text-[14px] text-red-500 text-center mb-3"></p>

            <form id="passwordForm" novalidate class="space-y-5">
                <div>
                    <label class="block text-[10px] font-bold tracking-[0.15em] text-gray-400 uppercase mb-2">Current Password</label>
                    <input id="currentPassword" type="password" name="currentPassword"
                        placeholder="Enter current password"
                        class="w-full border-b-2 border-gray-200 py-2 text-[15px] focus:outline-none focus:border-black transition-colors bg-transparent">
                </div>
                <div>
                    <label class="block text-[10px] font-bold tracking-[0.15em] text-gray-400 uppercase mb-2">New Password</label>
                    <input id="newPassword" type="password" name="newPassword"
                        placeholder="Enter new password"
                        class="w-full border-b-2 border-gray-200 py-2 text-[15px] focus:outline-none focus:border-black transition-colors bg-transparent">
                </div>
                <div>
                    <label class="block text-[10px] font-bold tracking-[0.15em] text-gray-400 uppercase mb-2">Confirm Password</label>
                    <input id="confirmPassword" type="password" name="confirmPassword"
                        placeholder="Confirm new password"
                        class="w-full border-b-2 border-gray-200 py-2 text-[15px] focus:outline-none focus:border-black transition-colors bg-transparent">
                </div>
                <button type="submit" class="w-full mt-6 px-6 py-4 bg-black text-white text-[11px] font-bold tracking-widest uppercase hover:bg-gray-800 transition-colors">
                    Update Password
                </button>
            </form>
        </div>
    </div>

    <!-- Email Modal -->
    <div id="emailModal" class="fixed top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[90%] max-w-md bg-white z-[70] hidden opacity-0 scale-95 transition-all duration-300 shadow-2xl">
        <div class="p-8">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-3xl font-serif text-black">Change Email</h2>
                <button type="button" onclick="closeModal('emailModal')" class="text-gray-400 hover:text-black transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <p id="emailError" class="text-[14px] text-red-500 text-center mb-3">{{message}}</p>
            <form action="/users/changeEmail" novalidate method="post" id="emailForm" class="space-y-5">
                <div>
                    <label class="block text-[10px] font-bold tracking-[0.15em] text-gray-400 uppercase mb-2">New Email Address</label>
                    <input type="email" name="newEmail" id="newEmailInput" class="w-full border-b-2 border-gray-200 py-2 text-[15px] focus:outline-none focus:border-black transition-colors bg-transparent">
                </div>
                <button type="submit" class="w-full mt-6 px-6 py-4 bg-black text-white text-[11px] font-bold tracking-widest uppercase hover:bg-gray-800 transition-colors">
                    Send OTP to Verify
                </button>
            </form>
        </div>
    </div>

    <!-- OTP Modal -->
    <div id="otpModal" class="fixed top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[90%] max-w-md bg-white z-[70] hidden opacity-0 scale-95 transition-all duration-300 shadow-2xl">
        <div class="p-8">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-3xl font-serif text-black">Verify Email</h2>
                <button type="button" onclick="closeModal('otpModal')" class="text-gray-400 hover:text-black transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <p class="text-[13px] text-gray-500 mb-6">Please enter the 6-digit OTP sent to your new email address.</p>
            <form id="otpVerifyForm" class="space-y-5">
                <input type="hidden" name="email" id="hiddenEmailInput">
                <div class="flex justify-between gap-2 mb-6">
                    <input type="text" maxlength="1" class="w-12 h-14 border-2 border-gray-200 text-center text-2xl font-serif focus:border-black focus:outline-none transition-colors otp-input">
                    <input type="text" maxlength="1" class="w-12 h-14 border-2 border-gray-200 text-center text-2xl font-serif focus:border-black focus:outline-none transition-colors otp-input">
                    <input type="text" maxlength="1" class="w-12 h-14 border-2 border-gray-200 text-center text-2xl font-serif focus:border-black focus:outline-none transition-colors otp-input">
                    <input type="text" maxlength="1" class="w-12 h-14 border-2 border-gray-200 text-center text-2xl font-serif focus:border-black focus:outline-none transition-colors otp-input">
                    <input type="text" maxlength="1" class="w-12 h-14 border-2 border-gray-200 text-center text-2xl font-serif focus:border-black focus:outline-none transition-colors otp-input">
                    <input type="text" maxlength="1" class="w-12 h-14 border-2 border-gray-200 text-center text-2xl font-serif focus:border-black focus:outline-none transition-colors otp-input">
                </div>
                <input type="hidden" name="otp" id="fullOtpInput">
                <button type="submit" class="w-full px-6 py-4 bg-black text-white text-[11px] font-bold tracking-widest uppercase hover:bg-gray-800 transition-colors">
                    Verify & Update
                </button>
                <div class="text-center mt-4 flex flex-col items-center gap-1">
                    <p id="otpTimerText" class="text-[11px] text-gray-400 tracking-wide">
                        Resend available in <span id="otpCountdown" class="font-bold text-black">60</span>s
                    </p>
                    <button type="button" id="resendOtpBtn" onclick="resendOtp()" disabled
                        class="text-[10px] font-bold tracking-[0.1em] uppercase transition-colors text-gray-300 cursor-not-allowed">
                        Resend OTP
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>

        const isGoogleUser = {{#if isGoogleUser}}true{{else}}false{{/if}};

        // MODAL LOGIC
        function openModal(modalId) {
            const modal = document.getElementById(modalId);
            const backdrop = document.getElementById('modalBackdrop');
            backdrop.classList.remove('hidden');
            setTimeout(() => backdrop.classList.remove('opacity-0'), 10);
            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.classList.remove('opacity-0', 'scale-95');
                modal.classList.add('opacity-100', 'scale-100');
            }, 10);
            const firstInput = modal.querySelector('input:not([type="hidden"])');
            if (firstInput) setTimeout(() => firstInput.focus(), 300);
            if (modalId === 'otpModal') startOtpTimer(60);
        }

        function closeModal(modalId) {
            const modal = document.getElementById(modalId);
            const backdrop = document.getElementById('modalBackdrop');
            if (modalId === 'otpModal' && otpTimerInterval) {
                clearInterval(otpTimerInterval);
                otpTimerInterval = null;
            }
            modal.classList.remove('opacity-100', 'scale-100');
            modal.classList.add('opacity-0', 'scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
                const openModals = document.querySelectorAll('[id$="Modal"]:not(.hidden)');
                if (openModals.length === 0) {
                    backdrop.classList.add('opacity-0');
                    setTimeout(() => backdrop.classList.add('hidden'), 300);
                }
            }, 300);
        }

        function closeAllModals() {
            closeModal('passwordModal');
            closeModal('emailModal');
            closeModal('otpModal');
        }

        function combineOtp() {
            const inputs = document.querySelectorAll('.otp-input');
            let otp = '';
            inputs.forEach(input => otp += input.value);
            document.getElementById('fullOtpInput').value = otp;
        }

        const otpInputs = document.querySelectorAll('.otp-input');
        otpInputs.forEach((input, index) => {
            input.addEventListener('input', function () {
                this.value = this.value.replace(/[^0-9]/g, '');
                if (this.value.length === 1 && index < otpInputs.length - 1) otpInputs[index + 1].focus();
            });
            input.addEventListener('keydown', function (e) {
                if (e.key === 'Backspace' && !this.value && index > 0) otpInputs[index - 1].focus();
            });
        });

        // PROFILE PHOTO UPLOAD
        document.getElementById('profilePhotoInput').addEventListener('change', async (e) => {
            const file = e.target.files[0];
            if (!file) return;
            const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp'];
            if (!allowedTypes.includes(file.type)) {
                Swal.fire({ icon: 'error', title: 'Invalid File', text: 'Only JPG, PNG, or WEBP images are allowed.' });
                return;
            }
            if (file.size > 2 * 1024 * 1024) {
                Swal.fire({ icon: 'error', title: 'File Too Large', text: 'Image must be under 2MB.' });
                return;
            }
            const reader = new FileReader();
            reader.onload = (ev) => {
                const container = document.getElementById('photoContainer');
                container.innerHTML = `<img id="profilePreview" src="${ev.target.result}" alt="Profile" class="w-full h-full object-cover grayscale">`;
            };
            reader.readAsDataURL(file);
            const statusEl = document.getElementById('uploadStatus');
            statusEl.textContent = 'Uploading...';
            statusEl.className = 'text-[11px] tracking-wide mt-2 text-gray-500';
            statusEl.classList.remove('hidden');
            const formData = new FormData();
            formData.append('profilePhoto', file);
            try {
                const res = await fetch('/users/uploadProfilePhoto', {
                    method: 'POST',
                    credentials: 'include',
                    body: formData
                });
                const data = await res.json();
                if (data.success) {
                    statusEl.textContent = 'Photo updated ✓';
                    statusEl.className = 'text-[11px] tracking-wide mt-2 text-green-600';
                    const container = document.getElementById('photoContainer');
                    container.innerHTML = `<img id="profilePreview" src="${data.profilePhoto}" alt="Profile" class="w-full h-full object-cover grayscale">`;
                    setTimeout(() => statusEl.classList.add('hidden'), 3000);
                } else {
                    statusEl.textContent = data.message || 'Upload failed';
                    statusEl.className = 'text-[11px] tracking-wide mt-2 text-red-500';
                }
            } catch (err) {
                statusEl.textContent = 'Upload failed. Try again.';
                statusEl.className = 'text-[11px] tracking-wide mt-2 text-red-500';
            }
        });

        // EMAIL FORM
        document.addEventListener("DOMContentLoaded", function () {
            document.getElementById("emailForm").addEventListener("submit", formValidate);
        });

        async function formValidate(e) {
            e.preventDefault();
            const emailInput = document.getElementById("newEmailInput");
            const errorText = document.getElementById("emailError");
            const Email = emailInput.value.trim();
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            errorText.textContent = "";
            if (Email === "") { errorText.textContent = "Email is required"; return; }
            if (!emailRegex.test(Email)) { errorText.textContent = "Enter a valid email address"; return; }
            try {
                const res = await fetch("/users/changeEmail", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    credentials: "include",
                    body: JSON.stringify({ newEmail: Email })
                });
                const data = await res.json();
                if (!data.success) { errorText.textContent = data.message; return; }
                errorText.className = "text-green-500 text-[14px] text-center mb-3";
                errorText.textContent = data.message;
                document.getElementById("hiddenEmailInput").value = Email;
                setTimeout(() => { closeModal("emailModal"); openModal("otpModal"); }, 2000);
            } catch (error) {
                errorText.textContent = "Something went wrong";
            }
        }

        // PASSWORD FORM
        document.getElementById("passwordForm").addEventListener("submit", validatePassword);

        async function validatePassword(e) {
            e.preventDefault();
            const currentPasswordEl = document.getElementById("currentPassword");
            const currentPassword = currentPasswordEl ? currentPasswordEl.value.trim() : null;
            const newPassword = document.getElementById("newPassword").value.trim();
            const confirmPassword = document.getElementById("confirmPassword").value.trim();
            const errorText = document.getElementById("passwordError");
            errorText.textContent = "";
            errorText.className = "text-[14px] text-red-500 text-center mb-3";
            if (!currentPassword) { errorText.textContent = "Current password is required"; return; }
            if (!newPassword) { errorText.textContent = "New password is required"; return; }
            if (newPassword.length < 4) { errorText.textContent = "Password must be at least 4 characters"; return; }
            if (!confirmPassword) { errorText.textContent = "Please confirm your password"; return; }
            if (newPassword !== confirmPassword) { errorText.textContent = "Passwords do not match"; return; }
            try {
                const res = await fetch("/users/changePassword", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    credentials: "include",
                    body: JSON.stringify({ currentPassword, newPassword, confirmPassword })
                });
                const data = await res.json();
                errorText.textContent = data.message;
                if (data.success) {
                    errorText.className = "text-[14px] text-green-500 text-center mb-3";
                    document.getElementById("passwordForm").reset();
                    setTimeout(() => closeModal("passwordModal"), 2000);
                } else {
                    errorText.className = "text-[14px] text-red-500 text-center mb-3";
                }
            } catch (error) {
                errorText.textContent = "Something went wrong";
            }
        }

        // OTP TIMER
        let otpTimerInterval = null;

        function startOtpTimer(seconds = 60) {
            if (otpTimerInterval) clearInterval(otpTimerInterval);
            const countdownEl = document.getElementById('otpCountdown');
            const timerTextEl = document.getElementById('otpTimerText');
            const resendBtn = document.getElementById('resendOtpBtn');
            let remaining = seconds;
            countdownEl.textContent = remaining;
            timerTextEl.style.display = 'block';
            resendBtn.disabled = true;
            resendBtn.className = 'text-[10px] font-bold tracking-[0.1em] uppercase transition-colors text-gray-300 cursor-not-allowed';
            otpTimerInterval = setInterval(() => {
                remaining--;
                countdownEl.textContent = remaining;
                if (remaining <= 0) {
                    clearInterval(otpTimerInterval);
                    otpTimerInterval = null;
                    timerTextEl.style.display = 'none';
                    resendBtn.disabled = false;
                    resendBtn.className = 'text-[10px] font-bold tracking-[0.1em] text-black underline uppercase hover:text-gray-600 cursor-pointer';
                }
            }, 1000);
        }

        async function resendOtp() {
            const email = document.getElementById('hiddenEmailInput').value;
            if (!email) return;
            const resendBtn = document.getElementById('resendOtpBtn');
            resendBtn.textContent = 'Sending…';
            resendBtn.disabled = true;
            try {
                const res = await fetch('/users/changeEmail', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ newEmail: email })
                });
                const data = await res.json();
                resendBtn.textContent = 'Resend OTP';
                if (data.success) startOtpTimer(60);
                else resendBtn.disabled = false;
            } catch (err) {
                resendBtn.textContent = 'Resend OTP';
                resendBtn.disabled = false;
            }
        }

        // OTP VERIFY FORM
        document.getElementById("otpVerifyForm").addEventListener("submit", verifyOtp);

        async function verifyOtp(e) {
            e.preventDefault();
            combineOtp();
            const email = document.getElementById("hiddenEmailInput").value;
            const otp = document.getElementById("fullOtpInput").value;
            try {
                const res = await fetch("/users/verifyChangeEmailotp", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    credentials: "include",
                    body: JSON.stringify({ email, otp })
                });
                const data = await res.json();
                if (!data.success) {
                    Swal.fire({ icon: "error", title: "Error", text: data.message });
                    return;
                }
                Swal.fire({ icon: "success", title: "Success", text: data.message, timer: 2000, showConfirmButton: false });
                setTimeout(() => { window.location.href = "/users/profile"; }, 2000);
            } catch (error) {
                Swal.fire({ icon: "error", title: "Error", text: "Something went wrong" });
            }
        }

        // BACK BUTTON GUARD
        window.addEventListener("pageshow", (e) => {
            if (e.persisted || performance.getEntriesByType("navigation")[0]?.type === "back_forward") {
                window.location.reload();
            }
        });

        // LOGOUT MODAL
        function confirmLogout() {
            Swal.fire({
                title: 'Leaving so soon?',
                text: 'Are you sure you want to logout?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#000000',
                cancelButtonColor: '#e5e7eb',
                confirmButtonText: 'YES, LOGOUT',
                cancelButtonText: 'CANCEL',
                customClass: {
                    cancelButton: '!text-black',
                    title: 'font-serif',
                    popup: 'font-sans'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('logoutForm').submit();
                }
            });
        }

    </script>
</body>
</html>
