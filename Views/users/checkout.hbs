                </form>
            </div>

            <div class="px-8 py-6 border-t border-gray-100 flex-shrink-0">
                <button onclick="submitNewAddress()" id="submit-addr-btn"
                    class="w-full bg-[#1a1a1a] hover:bg-black text-white rounded-xl py-4 text-[12px] font-black uppercase tracking-[0.2em] transition-all shadow-xl shadow-black/10">
                    Save Address
                </button>
            </div>
        </div>
    </div>

    <!-- Available Coupons Modal -->
    <div id="coupon-modal-backdrop" class="modal-backdrop">
        <div class="coupon-modal-content">
            <div class="p-8 border-b border-gray-100 flex items-center justify-between">
                <div>
                    <h3 class="text-[18px] font-black uppercase tracking-tight">Available Coupons</h3>
                    <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mt-1">Select a code to apply</p>
                </div>
                <button onclick="closeCouponModal()" class="w-10 h-10 flex items-center justify-center text-gray-300 hover:text-black transition-colors">
                    <span class="material-symbols-outlined text-[24px]">close</span>
                </button>
            </div>
            
            <div id="coupon-list-container" class="max-h-[400px] overflow-y-auto">
                <!-- Skeleton Loader -->
                <div id="coupon-skeleton" class="p-8 space-y-4">
                    <div class="h-16 bg-gray-50 animate-pulse rounded-2xl"></div>
                    <div class="h-16 bg-gray-50 animate-pulse rounded-2xl"></div>
                    <div class="h-16 bg-gray-50 animate-pulse rounded-2xl"></div>
                </div>
                <!-- Real items will be injected here -->
                <div id="coupon-items-list" class="hidden"></div>
                
                <!-- Empty State -->
                <div id="coupon-empty" class="hidden p-12 text-center">
                    <span class="material-symbols-outlined text-[40px] text-gray-200 mb-2">confirmation_number</span>
                    <p class="text-[12px] font-bold text-gray-400 uppercase tracking-widest">No available coupons found</p>
                </div>
            </div>
            
            <div class="p-8 bg-gray-50/50">
                <p class="text-[9px] text-gray-400 font-bold uppercase tracking-widest leading-relaxed text-center">Coupons cannot be combined with other offers. Terms and conditions apply.</p>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="/toast/toast.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script>
        // ─── State ─────────────────────────────────────────────────
        let selectedAddressId = '{{defaultAddress._id}}';
        let selectedPaymentMethod = {{#if codUnavailable}}'razorpay'{{else}}'cod'{{/if}};
        // Auto-select razorpay if COD unavailable
        window.addEventListener('DOMContentLoaded', () => {
        {{#if codUnavailable}}
        document.getElementById('pay-cod').classList.remove('selected');
        document.getElementById('pay-razorpay').classList.add('selected');
        {{/if}}
        });
        let appliedCouponCode = '{{#if appliedCoupon}}{{appliedCoupon}}{{/if}}';
        let currentTotal = {{ total }};
        let currentCouponDiscount = {{#if couponDiscount }}{{ couponDiscount }} {{else }} 0{{/if }};

        // ─── Payment Selection ─────────────────────────────────────
        function selectPayment(method) {
            selectedPaymentMethod = method;
            document.querySelectorAll('.payment-card').forEach(card => card.classList.remove('selected'));
            document.getElementById(`pay-${method}`).classList.add('selected');
        }

        // ─── Address Modal ─────────────────────────────────────────
        function openAddressModal() {
            document.getElementById('addr-modal-backdrop').classList.add('open');
            document.body.style.overflow = 'hidden';
        }

        function closeAddressModal() {
            document.getElementById('addr-modal-backdrop').classList.remove('open');
            document.body.style.overflow = '';
        }

        // Close on backdrop click
        document.getElementById('addr-modal-backdrop').addEventListener('click', function (e) {
            if (e.target === this) closeAddressModal();
        });

        // ─── Select Address ────────────────────────────────────────
        function selectAddress(id, fullName, phoneNO, line1, line2, city, state, pincode, type) {
            selectedAddressId = id;

            // Update modal highlight
            document.querySelectorAll('.addr-card').forEach(c => c.classList.remove('selected'));
            const el = document.getElementById(`addr-${id}`);
            if (el) el.classList.add('selected');

            // Update display on page
            document.getElementById('disp-name').textContent = fullName;
            document.getElementById('disp-phone').textContent = phoneNO;
            const addrLine = [line1, line2 || null, city, `${state} — ${pincode}`].filter(Boolean).join(', ');
            document.getElementById('disp-addr').innerHTML =
                `${line1}${line2 ? ', ' + line2 : ''}<br><span class="text-[#bb8a4a] font-semibold">${city}</span><br>${state} — ${pincode}`;

            setTimeout(closeAddressModal, 300);
        }

        // ─── Add New Address Modal ───
        function openAddAddressModal() {
            document.getElementById('add-addr-modal-backdrop').classList.add('open');
            document.body.style.overflow = 'hidden';
        }

        function closeAddAddressModal() {
            document.getElementById('add-addr-modal-backdrop').classList.remove('open');
            document.body.style.overflow = '';
            // Reset form and errors
            document.getElementById('add-address-form').reset();
            document.querySelectorAll('.add-addr-input').forEach(input => {
                input.classList.remove('border-red-500');
            });
            document.querySelectorAll('[id^="err-"]').forEach(p => {
                p.classList.add('hidden');
            });
        }

        // Close on backdrop click
        document.getElementById('add-addr-modal-backdrop').addEventListener('click', function (e) {
            if (e.target === this) closeAddAddressModal();
        });

        // Real-time validation
        document.querySelectorAll('.add-addr-input').forEach(input => {
            input.addEventListener('input', function () {
                const fieldId = this.id.replace('add-', '');
                const errorEl = document.getElementById(`err-${fieldId}`);
                if (errorEl) {
                    errorEl.classList.add('hidden');
                    this.classList.remove('border-red-500');
                }
            });
        });

        async function submitNewAddress() {
            const fullName = document.getElementById('add-fullName').value.trim();
            const phone = document.getElementById('add-phone').value.trim();
            const line1 = document.getElementById('add-line1').value.trim();
            const line2 = document.getElementById('add-line2').value.trim();
            const city = document.getElementById('add-city').value.trim();
            const state = document.getElementById('add-state').value;
            const pincode = document.getElementById('add-pincode').value.trim();
            const type = document.querySelector('input[name="addressType"]:checked').value;

            let isValid = true;

            function showError(field, msg) {
                const errEl = document.getElementById(`err-${field}`);
                const inputEl = document.getElementById(`add-${field}`);
                if (errEl) {
                    errEl.textContent = msg;
                    errEl.classList.remove('hidden');
                }
                if (inputEl) {
                    inputEl.classList.add('border-red-500');
                }
                isValid = false;
            }

            if (!fullName) showError('fullName', 'Full name is required');
            if (!phone) {
                showError('phone', 'Phone number is required');
            } else if (!/^\d{10}$/.test(phone)) {
                showError('phone', 'Enter a valid 10-digit phone number');
            }
            if (!line1) showError('line1', 'Address line 1 is required');
            if (!city) showError('city', 'City is required');
            if (!state) showError('state', 'Please select a state');
            if (!pincode) {
                showError('pincode', 'Pincode is required');
            } else if (!/^\d{6}$/.test(pincode)) {
                showError('pincode', 'Enter a valid 6-digit pincode');
            }

            if (!isValid) return;

            const btn = document.getElementById('submit-addr-btn');
            btn.disabled = true;
            btn.textContent = 'Saving...';

            try {
                const res = await axios.post('/users/address', {
                    fullName, phoneNO: phone, addressLine1: line1, addressLine2: line2, city, state, pincode, addressType: type
                }, { withCredentials: true });

                if (res.data.success) {
                    showToast('success', 'Address added successfully!');
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    showToast('error', res.data.message || 'Failed to add address');
                }
            } catch (err) {
                showToast('error', err.response?.data?.message || 'Something went wrong');
            } finally {
                btn.disabled = false;
                btn.textContent = 'Save Address';
            }
        }

       function handleCouponAction() {
    if (appliedCouponCode) {
        removeCoupon();
    } else {
        applyCoupon();
    }
}

function updateCouponBtn() {
    const btn = document.getElementById('coupon-action-btn');
    if (appliedCouponCode) {
        btn.textContent = 'Remove';
        btn.style.background = '#dc2626';  // red for remove
    } else {
        btn.textContent = 'Apply';
        btn.style.background = '#1a1a1a';  // default black
    }
}

async function applyCoupon() {
    // Block if a coupon is already applied
    if (appliedCouponCode) {
        showToast('error', 'Remove the current coupon before applying a new one');
        return;
    }

    const code = document.getElementById('coupon-input').value.trim().toUpperCase();
    if (!code) {
        showToast('error', 'Please enter a coupon code');
        return;
    }

    const btn = document.getElementById('coupon-action-btn');
    btn.textContent = '...';
    btn.disabled = true;

    try {
        const res = await axios.post('/users/applyCoupon', { couponCode: code }, { withCredentials: true });

        if (res.data.success) {
            appliedCouponCode = code;
            const discount = res.data.discount || 0;
            const newTotal = res.data.newTotal;

            document.getElementById('coupon-row').style.display = 'flex';
            document.getElementById('disp-coupon').textContent = `-₹${discount.toLocaleString('en-IN')}`;

            currentTotal = newTotal;
            document.getElementById('disp-total').textContent = `₹ ${newTotal.toLocaleString('en-IN')}`;
            document.getElementById('btn-total').textContent = newTotal.toLocaleString('en-IN');

            updateCouponBtn();
            showToast('success', res.data.message || 'Coupon applied!');
        } else {
            showToast('error', res.data.message || 'Invalid coupon');
            updateCouponBtn();
        }
    } catch (err) {
        showToast('error', err.response?.data?.message || 'Failed to apply coupon');
        updateCouponBtn();
    } finally {
        btn.disabled = false;
    }
}

async function removeCoupon() {
    const btn = document.getElementById('coupon-action-btn');
    btn.textContent = '...';
    btn.disabled = true;

    try {
        const res = await axios.post('/users/removeCoupon', {}, { withCredentials: true });

        if (res.data.success) {
            appliedCouponCode = '';
            document.getElementById('coupon-input').value = '';
            document.getElementById('coupon-row').style.display = 'none';
            document.getElementById('disp-coupon').textContent = '';

            const newTotal = res.data.newTotal;
            currentTotal = newTotal;
            document.getElementById('disp-total').textContent = `₹ ${newTotal.toLocaleString('en-IN')}`;
            document.getElementById('btn-total').textContent = newTotal.toLocaleString('en-IN');

            updateCouponBtn();
            showToast('success', 'Coupon removed');
        } else {
            showToast('error', res.data.message || 'Failed to remove coupon');
            updateCouponBtn();
        }
    } catch (err) {
        showToast('error', err.response?.data?.message || 'Failed to remove coupon');
        updateCouponBtn();
    } finally {
        btn.disabled = false;
    }
}

        // ─── Coupon Modal ──────────────────────────────────────────
        async function openCouponModal() {
            const modal = document.getElementById('coupon-modal-backdrop');
            const skeleton = document.getElementById('coupon-skeleton');
            const itemsList = document.getElementById('coupon-items-list');
            const emptyState = document.getElementById('coupon-empty');
            
            modal.style.display = 'flex';
            setTimeout(() => modal.classList.add('open'), 10);
            document.body.style.overflow = 'hidden';

            // Show skeleton, hide others
            skeleton.classList.remove('hidden');
            itemsList.classList.add('hidden');
            emptyState.classList.add('hidden');

            try {
                // Fetch available coupons
                const res = await axios.get('/users/coupons', { withCredentials: true });
                console.log('Coupons response:', res.data);
                
                if (res.data.success && res.data.coupons && res.data.coupons.length > 0) {
                    renderCoupons(res.data.coupons);
                    skeleton.classList.add('hidden');
                    itemsList.classList.remove('hidden');
                } else {
                    skeleton.classList.add('hidden');
                    emptyState.classList.remove('hidden');
                }
            } catch (err) {
                console.error("Fetch coupons error:", err);
                skeleton.classList.add('hidden');
                emptyState.classList.remove('hidden');
                showToast('error', 'Failed to load coupons');
            }
        }

        function closeCouponModal() {
            const modal = document.getElementById('coupon-modal-backdrop');
            modal.classList.remove('open');
            setTimeout(() => modal.style.display = 'none', 300);
            document.body.style.overflow = '';
        }

        function renderCoupons(coupons) {
    const container = document.getElementById('coupon-items-list');
    container.innerHTML = coupons.map(c => {
        const discountLabel = c.discountType === 'percentage'
            ? `${c.discountValue}% OFF`
            : `₹${c.discountValue} OFF`;

        const expiry = c.expiryDate
            ? new Date(c.expiryDate).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' })
            : null;

        const isApplied = appliedCouponCode === c.code;

        return `
        <div class="coupon-list-item p-6 flex items-center justify-between gap-4 ${isApplied ? 'bg-green-50' : ''}">
            <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 mb-1.5 flex-wrap">
                    <span class="coupon-code-pill">${c.code}</span>
                    <span class="text-[14px] font-black text-gray-900">${discountLabel}</span>
                    ${isApplied ? `<span class="text-[9px] font-black uppercase tracking-widest bg-green-100 text-green-700 px-2 py-0.5 rounded-full">Applied</span>` : ''}
                </div>
                <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">
                    ${c.minOrder ? `Min Order: ₹${c.minOrder}` : 'No minimum order'}
                    ${c.maxDiscount ? ` • Max Discount: ₹${c.maxDiscount}` : ''}
                    ${expiry ? ` • Expires: ${expiry}` : ''}
                </p>
                ${c.description ? `<p class="text-[11px] text-gray-500 mt-1">${c.description}</p>` : ''}
            </div>
            <button onclick="selectCoupon('${c.code}')"
                class="apply-btn-sm flex-shrink-0 ${isApplied ? 'opacity-50 cursor-not-allowed' : ''}"
                ${isApplied ? 'disabled' : ''}>
                ${isApplied ? 'Applied' : 'Apply'}
            </button>
        </div>`;
    }).join('');
}

        function selectCoupon(code) {
            document.getElementById('coupon-input').value = code;
            closeCouponModal();
            applyCoupon();
        }

        // Close on backdrop click
        document.getElementById('coupon-modal-backdrop').addEventListener('click', function (e) {
            if (e.target === this) closeCouponModal();
        });

        // ─── Place Order ──────────────────────────────────────────
        async function placeOrder() {

            console.log('placeOrder called');  // add this first
            console.log('selectedAddressId:', selectedAddressId);
            console.log('selectedPaymentMethod:', selectedPaymentMethod);
            console.log('orderData about to send:', {
                addressId: selectedAddressId,
                paymentMethod: selectedPaymentMethod,
                couponCode: appliedCouponCode || null,
            });

            if (!selectedAddressId) {
                showToast('error', 'Please select a delivery address');
                return;
            }

            const orderData = {
                addressId: selectedAddressId,
                paymentMethod: selectedPaymentMethod,
                couponCode: appliedCouponCode || null,
            };

            // Handle Razorpay separately
            if (selectedPaymentMethod === 'razorpay') {
                await initiateRazorpay(orderData);
                return;
            }

            try {
                const btn = document.querySelector('.order-btn');
                btn.disabled = true;
                btn.textContent = 'Placing Order…';

                const res = await axios.post('/users/orderSuccess', orderData, { withCredentials: true });

                if (res.data.success) {
                    console.log('redirectUrl:', res.data.redirectUrl);
                    showToast('success', 'Order placed successfully!');
                    setTimeout(() => {
                        window.location.href = res.data.redirectUrl || '/users/orderSuccess';
                    }, 1000);
                } else {
                    showToast('error', res.data.message || 'Failed to place order');
                    btn.disabled = false;
                    btn.innerHTML = `Complete Order — ₹<span id="btn-total">${currentTotal.toLocaleString('en-IN')}</span>`;
                }
            } catch (err) {
                console.log('Full error:', err);
                console.log('Response data:', err.response?.data);
                console.log('Status:', err.response?.status);
                showToast('error', err.response?.data?.message || 'Something went wrong');
                const btn = document.querySelector('.order-btn');
                btn.disabled = false;
                btn.innerHTML = `Complete Order — ₹<span id="btn-total">${currentTotal.toLocaleString('en-IN')}</span>`;
            }
        }

        // ─── Razorpay ─────────────────────────────────────────────
        async function initiateRazorpay(orderData) {
            try {
                const res = await axios.post('/users/razorpayOrder', orderData, { withCredentials: true });
                if (!res.data.success) {
                    showToast('error', res.data.message || 'Payment initiation failed');
                    return;
                }

                const options = {
                    key: res.data.razorpayKey,
                    amount: res.data.amount,
                    currency: 'INR',
                    name: 'BOOT CAMP',
                    description: 'Order Payment',
                    order_id: res.data.razorpayOrderId,
                    handler: async function (response) {
                        const verifyRes = await axios.post('/users/verifyRazorpay', {
                            ...orderData,
                            orderId: res.data.orderId,
                            razorpay_payment_id: response.razorpay_payment_id,
                            razorpay_order_id: response.razorpay_order_id,
                            razorpay_signature: response.razorpay_signature,
                        }, { withCredentials: true });

                        if (verifyRes.data.success) {
                            showToast('success', 'Payment successful! Order placed.');
                            setTimeout(() => {
                                window.location.href = verifyRes.data.redirectUrl || '/users/orders';
                            }, 1000);
                        } else {

                            window.location.href = `/users/paymentFailed?orderId=${res.data.orderId}`;
                        }
                    },
                    prefill: {
                        name: '{{user.username}}',
                        email: '{{user.email}}',
                    },
                    theme: { color: '#1a1a1a' },
                    modal: {
                        ondismiss: function () {
                            // User closed Razorpay — redirect to failure page
                            window.location.href = `/users/paymentFailed?orderId=${res.data.orderId}`;
                        }
                    }
                };

                const rzp = new Razorpay(options);

                // Handle payment failure from Razorpay itself
                rzp.on('payment.failed', function (response) {
                    window.location.href = `/users/paymentFailed?orderId=${res.data.orderId}`;
                });

                rzp.open();

            } catch (err) {
                showToast('error', err.response?.data?.message || 'Payment failed');
            }
        }

        // ─── Back Button Guard ────────────────────────────────────
        window.addEventListener('pageshow', (e) => {
            if (e.persisted || performance.getEntriesByType('navigation')[0]?.type === 'back_forward') {
                window.location.reload();
            }
        });

        updateCouponBtn();
    </script>

</body>

</html>