<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WISHLIST - BOOT CAMP</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <!-- Material Symbols -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #ffffff;
            color: #000000;
        }

        /* Material Icons filled trick */
        .icon-fill { font-variation-settings: 'FILL' 1; }

        .wishlist-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .wishlist-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.1);
        }
    </style>
</head>

<body class="antialiased selection:bg-black selection:text-white flex flex-col min-h-screen">

    <!-- Navbar -->
    {{>navbar}}

    <!-- Main Content -->
    <main class="flex-1 w-full max-w-[1500px] mx-auto px-6 py-40 lg:py-40 lg:px-12">
        <div class="max-w-[1250px] mx-auto">
            
            <h1 class="text-[32px] md:text-[40px] font-black uppercase tracking-tighter mb-4 text-center">Your Wishlist</h1>
            <p class="text-gray-500 text-sm font-medium text-center mb-16">Save your favorite items here for later.</p>

            <!-- Header Row -->
            <div class="flex justify-between items-center mb-8 pb-4 border-b border-gray-100">
                <span class="text-[12px] font-bold uppercase tracking-[0.2em]">3 ITEMS SAVED</span>
            </div>
            
            <!-- Items Grid -->
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 xl:gap-8">
                
                <!-- Card 1 (Out of Stock Example, matching provided image) -->
                <div class="wishlist-card relative rounded-[16px] overflow-hidden group">
                    <div class="aspect-[3/4] bg-[#f4f4f5] relative">
                        <!-- Image Carousel -->
                        <div class="carousel-container absolute inset-0 w-full h-full transition-transform duration-700 group-hover:scale-105 z-0">
                            <img src="https://images.unsplash.com/photo-1596755094514-f87e32f6b717?q=80&w=800&auto=format&fit=crop" class="carousel-img absolute inset-0 w-full h-full object-cover mix-blend-multiply opacity-100 transition-opacity duration-300" alt="Oxford Shirt">
                            <img src="https://images.unsplash.com/photo-1620799140408-edc6dcb6d633?q=80&w=800&auto=format&fit=crop" class="carousel-img absolute inset-0 w-full h-full object-cover mix-blend-multiply opacity-0 transition-opacity duration-300" alt="Oxford Shirt Alt 1">
                            <img src="https://images.unsplash.com/photo-1588359348347-9bc6cbea68cb?q=80&w=800&auto=format&fit=crop" class="carousel-img absolute inset-0 w-full h-full object-cover mix-blend-multiply opacity-0 transition-opacity duration-300" alt="Oxford Shirt Alt 2">
                        </div>
                        
                        <!-- Top Right Remove button -->
                        <button class="absolute top-4 right-4 w-[34px] h-[34px] bg-white/70 backdrop-blur-md rounded-full flex items-center justify-center text-gray-800 hover:bg-white hover:shadow-md transition-all z-20">
                            <span class="material-symbols-outlined text-[16px]">close</span>
                        </button>

                        <!-- Bottom Gradient Overlay -->
                        <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-gray-900/80 via-gray-900/40 to-transparent pointer-events-none z-0"></div>
                        
                        <!-- Bottom Content Area -->
                        <div class="absolute bottom-0 left-0 right-0 p-5 flex flex-col justify-end z-10">
                            <!-- Out of stock badge floating right -->
                            <div class="absolute right-0 bottom-[75px] bg-[#f26363] text-white text-[9px] font-black uppercase tracking-[0.1em] px-2.5 py-1 rounded-l shadow-sm flex items-center">
                                OUT OF STOCK
                            </div>
                            
                            <!-- Product Info -->
                            <div class="flex justify-between items-end mb-4 pr-1 gap-2">
                                <h3 class="text-white text-[12px] font-bold uppercase tracking-widest leading-tight">RELAXED FIT<br>OXFORD SHIRT</h3>
                                <span class="text-white text-[13px] font-black">£19.99</span>
                            </div>
                            
                            <!-- Action Button -->
                            <button class="w-full border border-white/40 bg-gray-500/30 backdrop-blur-sm text-white/90 hover:text-white hover:bg-white/20 text-[11px] font-bold uppercase tracking-[0.2em] py-3.5 rounded-lg transition-all text-center">
                                OUT OF STOCK
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Card 2 (In Stock Example) -->
                <div class="wishlist-card relative rounded-[16px] overflow-hidden group">
                    <div class="aspect-[3/4] bg-[#f4f4f5] relative">
                        <div class="carousel-container absolute inset-0 w-full h-full transition-transform duration-700 group-hover:scale-105 z-0">
                            <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?q=80&w=800&auto=format&fit=crop" class="carousel-img absolute inset-0 w-full h-full object-cover mix-blend-multiply opacity-100 transition-opacity duration-300" alt="Mercurial Elite">
                            <img src="https://images.unsplash.com/photo-1608231387042-66d1773070a5?q=80&w=800&auto=format&fit=crop" class="carousel-img absolute inset-0 w-full h-full object-cover mix-blend-multiply opacity-0 transition-opacity duration-300" alt="Mercurial Elite Alt 1">
                            <img src="https://images.unsplash.com/photo-1551107696-a4b0c5a0d9a2?q=80&w=800&auto=format&fit=crop" class="carousel-img absolute inset-0 w-full h-full object-cover mix-blend-multiply opacity-0 transition-opacity duration-300" alt="Mercurial Elite Alt 2">
                        </div>
                        
                        <button class="absolute top-4 right-4 w-[34px] h-[34px] bg-white/70 backdrop-blur-md rounded-full flex items-center justify-center text-gray-800 hover:bg-white hover:shadow-md transition-all z-20">
                            <span class="material-symbols-outlined text-[16px]">close</span>
                        </button>

                        <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-gray-900/80 via-gray-900/40 to-transparent pointer-events-none z-0"></div>
                        
                        <div class="absolute bottom-0 left-0 right-0 p-5 flex flex-col justify-end z-10">
                            <div class="flex justify-between items-end mb-4 pr-1 gap-2">
                                <h3 class="text-white text-[12px] font-bold uppercase tracking-widest leading-tight">MERCURIAL<br>ELITE</h3>
                                <span class="text-white text-[13px] font-black">$249.00</span>
                            </div>
                            
                            <button class="w-full bg-white text-black hover:bg-gray-100 text-[11px] font-bold uppercase tracking-[0.2em] py-3.5 border border-white rounded-lg transition-all text-center shadow-lg">
                                MOVE TO BAG
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Card 3 (Sale Example) -->
                <div class="wishlist-card relative rounded-[16px] overflow-hidden group">
                    <div class="aspect-[3/4] bg-[#f4f4f5] relative">
                        <div class="carousel-container absolute inset-0 w-full h-full transition-transform duration-700 group-hover:scale-105 z-0">
                            <img src="https://images.unsplash.com/photo-1551107696-a4b0c5a0d9a2?q=80&w=800&auto=format&fit=crop" class="carousel-img absolute inset-0 w-full h-full object-cover mix-blend-multiply opacity-100 transition-opacity duration-300" alt="Trainer">
                            <img src="https://images.unsplash.com/photo-1605348532723-67c12f70f209?q=80&w=800&auto=format&fit=crop" class="carousel-img absolute inset-0 w-full h-full object-cover mix-blend-multiply opacity-0 transition-opacity duration-300" alt="Trainer Alt 1">
                            <img src="https://images.unsplash.com/photo-1549298916-b41d501d3772?q=80&w=800&auto=format&fit=crop" class="carousel-img absolute inset-0 w-full h-full object-cover mix-blend-multiply opacity-0 transition-opacity duration-300" alt="Trainer Alt 2">
                        </div>
                        
                        <button class="absolute top-4 right-4 w-[34px] h-[34px] bg-white/70 backdrop-blur-md rounded-full flex items-center justify-center text-gray-800 hover:bg-white hover:shadow-md transition-all z-20">
                            <span class="material-symbols-outlined text-[16px]">close</span>
                        </button>

                        <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-gray-900/80 via-gray-900/40 to-transparent pointer-events-none z-0"></div>
                        
                        <div class="absolute bottom-0 left-0 right-0 p-5 flex flex-col justify-end z-10">
                            <div class="absolute right-0 bottom-[75px] bg-black text-white text-[9px] font-black uppercase tracking-[0.1em] px-2.5 py-1 rounded-l shadow-sm flex items-center">
                                -20% SALE
                            </div>
                            
                            <div class="flex justify-between items-end mb-4 pr-1 gap-2">
                                <h3 class="text-white text-[12px] font-bold uppercase tracking-widest leading-tight">RAPIDO<br>TRAINER</h3>
                                <div class="flex flex-col items-end">
                                    <span class="text-white/60 text-[10px] font-bold line-through">$110.00</span>
                                    <span class="text-white text-[13px] font-black text-[#f26363]">$88.00</span>
                                </div>
                            </div>
                            
                            <button class="w-full bg-white text-black hover:bg-gray-100 text-[11px] font-bold uppercase tracking-[0.2em] py-3.5 border border-white rounded-lg transition-all text-center shadow-lg">
                                MOVE TO BAG
                            </button>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <!-- Footer -->
    {{>footer}}
    <!-- Product Carousel logic -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const cards = document.querySelectorAll('.wishlist-card');

            cards.forEach(card => {
                const images = card.querySelectorAll('.carousel-img');
                if (images.length <= 1) return;

                let intervalId;
                let currentIndex = 0;

                card.addEventListener('mouseenter', () => {
                    intervalId = setInterval(() => {
                        images[currentIndex].classList.remove('opacity-100');
                        images[currentIndex].classList.add('opacity-0');
                        currentIndex = (currentIndex + 1) % images.length;
                        images[currentIndex].classList.remove('opacity-0');
                        images[currentIndex].classList.add('opacity-100');
                    }, 1000);
                });

                card.addEventListener('mouseleave', () => {
                    clearInterval(intervalId);
                    images.forEach((img, idx) => {
                        if (idx === 0) {
                            img.classList.remove('opacity-0');
                            img.classList.add('opacity-100');
                        } else {
                            img.classList.remove('opacity-100');
                            img.classList.add('opacity-0');
                        }
                    });
                    currentIndex = 0;
                });
            });
        });
    </script>
</body>
</html>
