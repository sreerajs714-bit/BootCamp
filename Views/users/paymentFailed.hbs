<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Payment Unsuccessful | BOOT CAMP</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20,400,0,0" />
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            cream: '#f7f4ef',
                            dark: '#111111',
                            red: '#e11d48',
                            'red-light': '#fff1f2',
                            gray: '#6b7280',
                            'gray-light': '#f9fafb',
                        }
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Playfair Display', 'serif'],
                        display: ['Outfit', 'sans-serif'],
                    }
                }
            }
        }
    </script>

    <style>
        body {
            background-color: #fcfcfc; /* Very light, almost white as per image */
        }
        
        .fade-up {
            opacity: 0;
            transform: translateY(20px);
            animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        @keyframes fadeUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .delay-1 { animation-delay: 0.1s; }
        .delay-2 { animation-delay: 0.2s; }
        .delay-3 { animation-delay: 0.3s; }
        .delay-4 { animation-delay: 0.4s; }

        .btn-black {
            background-color: #000000;
            color: #ffffff;
            transition: all 0.3s ease;
        }
        .btn-black:hover {
            background-color: #333333;
            transform: translateY(-1px);
        }

        .btn-outline {
            border: 1px solid #e5e7eb;
            background-color: #ffffff;
            color: #000000;
            transition: all 0.3s ease;
        }
        .btn-outline:hover {
            background-color: #f9fafb;
            border-color: #d1d5db;
        }
    </style>
</head>
<body class="font-sans text-brand-dark min-h-screen flex items-center justify-center p-6 selection:bg-brand-red/10">

    <div class="max-w-xl w-full text-center flex flex-col items-center">
        
        <!-- Warning Icon Box -->
        <div class="fade-up w-16 h-16 bg-white border border-gray-100 rounded-xl shadow-sm flex items-center justify-center mb-10">
            <span class="material-symbols-outlined text-brand-red text-3xl font-light">warning</span>
        </div>

        <!-- Header -->
        <div class="fade-up delay-1 mb-8">
            <h1 class="font-serif text-4xl md:text-5xl mb-6 italic text-gray-900">Payment Unsuccessful</h1>
            <p class="text-gray-400 text-[10px] font-bold uppercase tracking-[0.2em] leading-relaxed">
                WE COULDN'T PROCESS YOUR TRANSACTION FOR ORDER <br>
                <span id="order-id-display" class="text-gray-900">#ORD-000000000</span>
            </p>
        </div>

        <!-- Info Box -->
        <div class="fade-up delay-2 w-full bg-gray-50/80 rounded-2xl p-6 mb-8 border border-gray-100">
            <p class="text-[11px] text-gray-500 leading-relaxed font-medium">
                <span class="text-black font-bold">Rest assured:</span> If any amount was debited, it will be automatically refunded by your bank within 5-7 business days.
            </p>
        </div>

        <!-- Countdown Timer -->
        <div id="timer-box" class="fade-up delay-3 w-full bg-brand-red-light rounded-2xl py-4 mb-4 border border-brand-red/5 flex items-center justify-center gap-2 group transition-all duration-500">
            <span class="material-symbols-outlined text-brand-red text-lg group-hover:scale-110 transition-transform">schedule</span>
            <span class="text-[11px] font-black text-brand-red uppercase tracking-[0.15em]">
                RETRY EXPIRES IN <span id="countdown-timer">5:00</span>
            </span>
        </div>

        <!-- Actions -->
        <div class="fade-up delay-4 w-full space-y-4">
            <button id="retry-payment-btn" class="w-full btn-black py-4.5 py-5 rounded-2xl text-[11px] font-black uppercase tracking-[0.2em] shadow-lg shadow-black/10">
                Retry Payment
            </button>
            <button id="view-order-btn" class="w-full btn-outline py-4.5 py-5 rounded-2xl text-[11px] font-black uppercase tracking-[0.2em]">
                View Order
            </button>
        </div>

        <!-- Footer -->
        <div class="fade-up delay-4 mt-20">
            <p class="text-gray-400 text-[9px] font-bold uppercase tracking-[0.2em]">
                NEED HELP? CONTACT OUR CONCIERGE AT <a href="mailto:SUPPORT@BOOTCAMP.COM" class="text-gray-900 hover:underline">SUPPORT@BOOTCAMP.COM</a>
            </p>
        </div>

    </div>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', () => {
    const orderId = '{{order._id}}';
    const timerDisplay = document.getElementById('countdown-timer');
    const timerBox = document.getElementById('timer-box');
    const retryBtn = document.getElementById('retry-payment-btn');

    document.getElementById('order-id-display').textContent = `#${orderId.slice(-6).toUpperCase()}`;

    // ✅ Use backend expiry time — never resets on reload
    const expiresAt = new Date('{{order.paymentExpiresAt}}').getTime();

    function getTimeLeft() {
        return Math.max(0, Math.floor((expiresAt - Date.now()) / 1000));
    }

    function handleExpiry() {
        clearInterval(timerInterval);
        timerDisplay.textContent = 'EXPIRED';
        timerBox.style.opacity = '0.5';
        retryBtn.disabled = true;
        retryBtn.style.opacity = '0.5';
        retryBtn.style.cursor = 'not-allowed';
    }

    function updateTimer() {
        const timeLeft = getTimeLeft();
        const minutes = Math.floor(timeLeft / 60);
        const seconds = timeLeft % 60;
        timerDisplay.textContent = `${minutes}:${seconds < 10 ? '0' : ''}${seconds}`;
        if (timeLeft <= 0) handleExpiry();
    }

    // If already expired when page loads, disable immediately
    if (getTimeLeft() <= 0) {
        handleExpiry();
    } else {
        updateTimer();
        var timerInterval = setInterval(updateTimer, 1000);
    }

    // ── Retry Payment ─────────────────────────────────────────────
    retryBtn.addEventListener('click', async () => {
        if (getTimeLeft() <= 0) {
            handleExpiry();
            return;
        }

        try {
            retryBtn.textContent = 'Processing...';
            retryBtn.disabled = true;

            const response = await axios.post('/users/retryPayment', { orderId });

            if (response.data.success) {
                const options = {
                    key: response.data.razorpayKey,
                    amount: response.data.amount,
                    currency: 'INR',
                    name: 'BOOT CAMP',
                    description: 'Order Payment',
                    order_id: response.data.razorpayOrderId,
                    handler: async function (res) {
                        try {
                            const verifyRes = await axios.post('/users/verifyRazorpay', {
                                orderId: response.data.orderId,
                                razorpay_payment_id: res.razorpay_payment_id,
                                razorpay_order_id: res.razorpay_order_id,
                                razorpay_signature: res.razorpay_signature,
                            });
                            if (verifyRes.data.success) {
                                window.location.href = verifyRes.data.redirectUrl;
                            } else {
                                alert(verifyRes.data.message || 'Payment verification failed');
                                retryBtn.textContent = 'Retry Payment';
                                retryBtn.disabled = false;
                            }
                        } catch (err) {
                            console.error('Verify failed:', err);
                            retryBtn.textContent = 'Retry Payment';
                            retryBtn.disabled = false;
                        }
                    },
                    modal: {
                        ondismiss: function () {
                            retryBtn.textContent = 'Retry Payment';
                            retryBtn.disabled = false;
                        }
                    }
                };

                const rzp = new Razorpay(options);
                rzp.on('payment.failed', function () {
                    retryBtn.textContent = 'Retry Payment';
                    retryBtn.disabled = false;
                });
                rzp.open();

            } else {
                alert(response.data.message || 'Unable to retry payment');
                retryBtn.textContent = 'Retry Payment';
                retryBtn.disabled = false;
            }
        } catch (error) {
            console.error('Retry failed:', error);
            retryBtn.textContent = 'Retry Payment';
            retryBtn.disabled = false;
        }
    });

    // ── View Order ────────────────────────────────────────────────
    document.getElementById('view-order-btn').addEventListener('click', () => {
        window.location.href = `/users/orderDetail/${orderId}`;
    });
});
</script>
</body>
</html>
