<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Return Product | BOOT CAMP</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;600;800;900&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
        rel="stylesheet">
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,300,0,0" />
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        display: ['Outfit', 'sans-serif'],
                        serif: ['Playfair Display', 'serif'],
                    },
                    colors: {
                        brand: {
                            50: '#f9f9f9',
                            100: '#e7e7e7',
                            200: '#d1d1d1',
                            300: '#b0b0b0',
                            400: '#888888',
                            500: '#6d6d6d',
                            600: '#5d5d5d',
                            700: '#4f4f4f',
                            800: '#454545',
                            900: '#3d3d3d',
                            950: '#000000',
                        }
                    }
                }
            }
        }
    </script>

    <style>
        body {
            background-color: #ffffff;
            color: #000000;
        }

        .step-circle {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            font-weight: 800;
            background: #fbfbfb;
            border: 1px solid #f3f3f3;
            color: #1a1a1a;
        }

        .premium-card {
            background: #ffffff;
            border-radius: 32px;
            border: 1px solid #f3f3f3;
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.02);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .input-pill {
            background: #fbfbfb;
            border: 1px solid #f3f3f3;
            border-radius: 12px;
            padding: 16px 20px;
            font-size: 13px;
            width: 100%;
            transition: all 0.3s ease;
        }

        .input-pill:focus {
            background: #ffffff;
            border-color: #000000;
            outline: none;
            box-shadow: 0 0 0 4px rgba(0, 0, 0, 0.02);
        }

        .upload-zone {
            border: 2px dashed #f3f3f3;
            border-radius: 24px;
            background: #fbfbfb;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .upload-zone:hover {
            border-color: #000000;
            background: #ffffff;
        }

        .image-preview {
            position: relative;
            width: 100px;
            height: 100px;
            border-radius: 16px;
            overflow: hidden;
            background: #fbfbfb;
            border: 1px solid #f3f3f3;
        }

        .remove-img {
            position: absolute;
            top: 4px;
            right: 4px;
            background: rgba(0, 0, 0, 0.6);
            color: white;
            border-radius: 50%;
            width: 20px;
            height: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            cursor: pointer;
            backdrop-filter: blur(4px);
            z-index: 10;
        }

        .btn-submit {
            background: #1a1a1a;
            color: #ffffff;
            padding: 18px 32px;
            border-radius: 16px;
            font-size: 12px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            transition: all 0.4s ease;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .btn-submit:disabled {
            background: #f3f3f3;
            color: #b0b0b0;
            cursor: not-allowed;
        }

        .btn-submit:not(:disabled):hover {
            background: #000000;
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        }
    </style>
</head>

<body class="min-h-screen py-20 px-6 font-sans">
    <div class="max-w-3xl mx-auto">
        <!-- Header -->
        <div class="text-center mb-16">
            <h1 class="text-[52px] font-serif leading-tight mb-2">Return Product</h1>
            <p class="text-[10px] font-black uppercase tracking-[0.3em] text-gray-400">
                Initiating return for order <span class="text-black">#{{order._id}}</span>
            </p>
        </div>

        <form id="return-form" onsubmit="handleFormSubmit(event)" class="space-y-6">
            <!-- Step 1: Items to Return -->
            <section class="premium-card p-10">
                <div class="flex items-center gap-4 mb-8">
                    <div class="step-circle">1</div>
                    <h2 class="text-[11px] font-black uppercase tracking-widest text-gray-400">Items to Return</h2>
                </div>

                {{#if isFullReturn}}
                {{#each allItems}}
                <div class="flex items-center gap-6 bg-gray-50/50 p-4 rounded-2xl border border-gray-50 mb-3">
                    <div class="w-16 h-20 bg-white rounded-xl overflow-hidden flex-shrink-0 border border-gray-100 p-1">
                        <!-- FIX: raw populated product has variants[0].images[0] as object with .url -->
                        <img src="{{this.product.variants.[0].images.[0].url}}"
                            onerror="this.src='{{this.product.variants.[0].images.[0]}}'"
                            alt="{{this.product.productName}}" class="w-full h-full object-contain">
                    </div>
                    <div class="flex-grow">
                        <h3 class="text-[14px] font-black uppercase tracking-tight mb-1">
                            {{this.product.productName}}
                        </h3>
                        <!-- FIX: was missing size in full return -->
                        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">
                            {{item.size}} | QTY: {{this.quantity}}
                        </p>
                    </div>
                    <div class="text-right">
                        <p class="text-[14px] font-black">₹{{this.price}}</p>
                        <p class="text-[9px] font-bold text-gray-300 uppercase tracking-widest">Refund Value</p>
                    </div>
                </div>
                {{/each}}

                {{else}}
                <!-- FIX: was using {{this.product}} — should be {{item.product}} -->
                <div class="flex items-center gap-6 bg-gray-50/50 p-4 rounded-2xl border border-gray-50">
                    <div class="w-16 h-20 bg-white rounded-xl overflow-hidden flex-shrink-0 border border-gray-100 p-1">
                        <img src="{{item.product.variants.[0].images.[0].url}}"
                            onerror="this.src='{{item.product.variants.[0].images.[0]}}'"
                            alt="{{item.product.productName}}" class="w-full h-full object-contain">
                    </div>
                    <div class="flex-grow">
                        <h3 class="text-[14px] font-black uppercase tracking-tight mb-1">
                            {{item.product.productName}}
                        </h3>
                        <!-- FIX: was missing size in single return -->
                        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">
                            {{item.size}} | QTY: {{item.quantity}}
                        </p>
                    </div>
                    <div class="text-right">
                        <p class="text-[14px] font-black">₹{{item.price}}</p>
                        <p class="text-[9px] font-bold text-gray-300 uppercase tracking-widest">Refund Value</p>
                    </div>
                </div>
                {{/if}}
            </section>

            <!-- Step 2: Reason for Return -->
            <section class="premium-card p-10">
                <div class="flex items-center gap-4 mb-10">
                    <div class="step-circle">2</div>
                    <h2 class="text-[11px] font-black uppercase tracking-widest text-gray-400">Reason for Return</h2>
                </div>

                <!-- Select Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                    <div>
                        <label class="block text-[9px] font-black uppercase tracking-widest text-gray-400 mb-3 ml-1">Why
                            are you returning this? <span class="text-red-500">*</span></label>
                        <select id="return-reason" class="input-pill" onchange="validateField('return-reason')">
                            <option value="">Select a reason</option>
                            <option value="Changed my mind">Changed my mind</option>
                            <option value="Wrong size">Wrong size</option>
                            <option value="Not as described">Not as described</option>
                            <option value="Defective product">Defective product</option>
                            <option value="Quality issues">Quality issues</option>
                        </select>
                        <p id="reason-error" class="text-[9px] font-bold text-red-500 uppercase tracking-widest mt-2 ml-1 hidden">Please select a reason for return</p>
                    </div>
                    <div>
                        <label
                            class="block text-[9px] font-black uppercase tracking-widest text-gray-400 mb-3 ml-1">Condition
                            of Item? <span class="text-red-500">*</span></label>
                        <select id="item-condition" class="input-pill" onchange="validateField('item-condition')">
                            <option value="">Select condition</option>
                            <option value="Unopened / Original Packaging">Unopened / Original Packaging</option>
                            <option value="Opened but Unused">Opened but Unused</option>
                            <option value="Minor signs of use">Minor signs of use</option>
                            <option value="Damaged / Faulty">Damaged / Faulty</option>
                        </select>
                        <p id="condition-error" class="text-[9px] font-bold text-red-500 uppercase tracking-widest mt-2 ml-1 hidden">Please select the item condition</p>
                    </div>
                </div>

                <!-- Comments -->
                <div class="mb-10">
                    <div class="flex justify-between items-center mb-3 ml-1">
                        <label class="text-[9px] font-black uppercase tracking-widest text-gray-400">Additional Comments
                            <span class="text-red-500">*</span></label>
                        <span class="text-[9px] font-bold text-gray-300 uppercase tracking-widest">(Min. 30
                            characters)</span>
                    </div>
                    <textarea id="return-comments" class="input-pill min-h-[140px] resize-none" placeholder="Please describe the issue in detail..." oninput="updateCharCount(); validateField('return-comments')"></textarea>
                    <p id="comments-error" class="text-[9px] font-bold text-red-500 uppercase tracking-widest mt-2 ml-1 hidden">Comments must be at least 30 characters long</p>
                    <div class="text-right mt-2">
                        <span id="char-count" class="text-[9px] font-bold text-gray-300 uppercase tracking-widest">0 / 500</span>
                    </div>
                </div>

                <!-- Image Upload -->
                <div>
                    <label class="block text-[9px] font-black uppercase tracking-widest text-gray-400 mb-4 ml-1">Upload Photos <span class="text-gray-300 text-[8px] font-bold">(OPTIONAL)</span></label>

                    <!-- Drop Zone -->
                    <div id="upload-zone"
                        class="upload-zone h-[180px] flex flex-col items-center justify-center relative mb-6"
                        onclick="document.getElementById('file-input').click()">
                        <span class="material-symbols-outlined text-gray-300 text-3xl mb-3">cloud_upload</span>
                        <p class="text-[13px] font-bold">Upload photos</p>
                        <p class="text-[10px] text-gray-400 uppercase tracking-widest mt-1">Or drag and drop here</p>
                        <input type="file" id="file-input" class="hidden" multiple accept="image/jpeg,image/png,image/webp"
                                onchange="handleFileSelect(event)">
                    </div>

                    <p class="text-center text-[10px] text-gray-300 italic mb-6 leading-relaxed">
                        Helpful for damaged or incorrect items. JPG, PNG, WEBP • Max 3 images • 5MB each
                    </p>

                    <!-- Preview Grid -->
                    <div id="preview-grid" class="flex flex-wrap gap-4 justify-center">
                        <!-- Previews added here by JS -->
                    </div>
                </div>
            </section>

            <!-- Step 3: Refund Destination -->
            <section class="premium-card p-10">
                <div class="flex items-center gap-4 mb-10">
                    <div class="step-circle">3</div>
                    <h2 class="text-[11px] font-black uppercase tracking-widest text-gray-400">Refund Destination</h2>
                </div>

                <label
                    class="flex items-center gap-6 p-6 bg-gray-50/50 rounded-2xl border border-gray-50 cursor-pointer hover:bg-gray-50 transition-all">
                    <input type="radio" name="refund-dest" value="wallet" checked class="w-4 h-4 accent-black">
                    <div
                        class="w-12 h-12 bg-black rounded-xl border border-gray-100 flex items-center justify-center flex-shrink-0">
                        <span class="material-symbols-outlined text-white text-xl">wallet</span>
                    </div>
                    <div class="flex-grow">
                        <h4 class="text-[13px] font-black uppercase tracking-tight">BOOTCAMP Wallet — Instant Refund</h4>
                        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Instant credit
                            after pickup completion</p>
                    </div>
                    <div class="bg-white px-3 py-1 rounded-full border border-gray-100">
                        <span class="text-[9px] font-black uppercase tracking-widest text-gray-400">Instant</span>
                    </div>
                </label>

                <p class="text-center text-[10px] text-gray-300 font-bold uppercase tracking-widest mt-8">
                    All refunds are processed to your BOOTCAMP Wallet regardless of original payment method.
                </p>
            </section>

            <!-- Actions -->
            <div class="flex items-center justify-between pt-8 pb-20">
                <a href="/users/orderDetail/{{order._id}}"
                    class="text-[10px] font-black uppercase tracking-widest text-gray-400 hover:text-black transition-all border-b border-transparent hover:border-black">
                    Cancel Request
                </a>
                <button type="submit" id="submit-btn" class="btn-submit">
                    Submit Full Return
                    <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
                </button>
            </div>
            <input type="hidden" id="item-id-value" value="{{#if isFullReturn}}ALL{{else}}{{item._id}}{{/if}}">
        </form>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="/toast/toast.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let uploadedFiles = [];
        const MAX_FILES = 3;

        function updateCharCount() {
            const textarea = document.getElementById('return-comments');
            const countSpan = document.getElementById('char-count');
            const count = textarea.value.length;
            countSpan.innerText = `${count} / 500`;

            if (count > 500) {
                textarea.value = textarea.value.substring(0, 500);
                countSpan.innerText = `500 / 500`;
            }
        }
function handleFileSelect(event) {
    const files = Array.from(event.target.files);

    // ✅ Check file types
    const allowedTypes = ['image/jpeg', 'image/png', 'image/webp'];
    const invalidFiles = files.filter(f => !allowedTypes.includes(f.type));
    if (invalidFiles.length > 0) {
        showToast("error", "Only JPG, PNG, and WEBP images are allowed.");
        event.target.value = '';
        return;
    }

    if (uploadedFiles.length + files.length > MAX_FILES) {
        showToast("error", `You can only upload a maximum of ${MAX_FILES} images.`);
        return;
    }

    files.forEach(file => {
        if (file.size > 5 * 1024 * 1024) {
            showToast("error", `${file.name} exceeds 5MB limit.`);
            return;
        }

        const reader = new FileReader();
        reader.onload = (e) => {
            const id = Date.now() + Math.random();
            uploadedFiles.push({ id, file, url: e.target.result });
            renderPreviews();
            updateUploadZoneVisibility();
        };
        reader.readAsDataURL(file);
    });

    event.target.value = '';
}

        function removeFile(id) {
            uploadedFiles = uploadedFiles.filter(item => item.id !== id);
            renderPreviews();
            updateUploadZoneVisibility();
        }

        function renderPreviews() {
            const grid = document.getElementById('preview-grid');
            grid.innerHTML = '';

            uploadedFiles.forEach(item => {
                const div = document.createElement('div');
                div.className = 'image-preview';
                div.innerHTML = `
                    <img src="${item.url}" class="w-full h-full object-cover">
                    <div class="remove-img" onclick="removeFile(${item.id})">
                        <span class="material-symbols-outlined text-[14px]">close</span>
                    </div>
                `;
                grid.appendChild(div);
            });
        }

        function updateUploadZoneVisibility() {
            const zone = document.getElementById('upload-zone');
            if (uploadedFiles.length >= MAX_FILES) {
                zone.classList.add('opacity-50', 'pointer-events-none');
            } else {
                zone.classList.remove('opacity-50', 'pointer-events-none');
            }
        }

        function validateField(fieldId) {
            const field = document.getElementById(fieldId);
            const errorElement = document.getElementById(fieldId.replace('return-', '').replace('item-', '') + '-error');
            let isValid = true;

            if (fieldId === 'return-reason' || fieldId === 'item-condition') {
                isValid = field.value !== "";
            } else if (fieldId === 'return-comments') {
                isValid = field.value.length >= 30;
            }

            if (isValid) {
                errorElement.classList.add('hidden');
                field.classList.remove('border-red-500');
            } else {
                errorElement.classList.remove('hidden');
                field.classList.add('border-red-500');
            }
            return isValid;
        }

        function validateForm() {
            const isReasonValid = validateField('return-reason');
            const isConditionValid = validateField('item-condition');
            const isCommentsValid = validateField('return-comments');
            
            return isReasonValid && isConditionValid && isCommentsValid;
        }

        async function handleFormSubmit(event) {
            event.preventDefault();

            if (!validateForm()) {
                showToast("error","Please fix the errors in the form.");
                return;
            }

            const submitBtn = document.getElementById('submit-btn');
            const originalContent = submitBtn.innerHTML;

            try {
                submitBtn.disabled = true;
                submitBtn.innerHTML = `Processing... <span class="material-symbols-outlined animate-spin text-[20px]">sync</span>`;

               const formData = new FormData();
               formData.append('itemId', document.getElementById('item-id-value').value);
               formData.append('orderId', '{{order._id}}');
               formData.append('reason', document.getElementById('return-reason').value);
               formData.append('condition', document.getElementById('item-condition').value);
               formData.append('comments', document.getElementById('return-comments').value);

                uploadedFiles.forEach(item => {
                    formData.append('images', item.file);
                });

                // Note: Actual endpoint may vary based on user backend
                const response = await axios.post('/users/orderDetail/return-request', formData, {
                    headers: { 'Content-Type': 'multipart/form-data' }
                });

                if (response.data.success) {
                    showToast("success","Return request submitted successfully!");
                    setTimeout(() => {
                        window.location.href = `/users/orderDetail/{{order._id}}`;
                    }, 2000);
                } else {
                    throw new Error(response.data.message || "Failed to submit request");
                }

            } catch (error) {
                console.error("Submit error:", error);
                showToast("error",error.message || "An error occurred. Please try again.");
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalContent;
            }
        }

        // Initialize drag and drop
        const uploadZone = document.getElementById('upload-zone');
        uploadZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            uploadZone.classList.add('border-black', 'bg-white');
        });

        uploadZone.addEventListener('dragleave', (e) => {
            e.preventDefault();
            uploadZone.classList.remove('border-black', 'bg-white');
        });

        uploadZone.addEventListener('drop', (e) => {
            e.preventDefault();
            uploadZone.classList.remove('border-black', 'bg-white');

            const files = Array.from(e.dataTransfer.files);
            const eventMock = { target: { files } };
            handleFileSelect(eventMock);
        });
    </script>
</body>

</html>