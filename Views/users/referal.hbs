<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Refer & Earn | BOOT CAMP</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;600;800;900&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
        rel="stylesheet">
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,300,0,0" />
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        display: ['Outfit', 'sans-serif'],
                        serif: ['Playfair Display', 'serif'],
                    },
                    colors: {
                        brand: {
                            50: '#f9f9f9',
                            100: '#e7e7e7',
                            200: '#d1d1d1',
                            300: '#b0b0b0',
                            400: '#888888',
                            500: '#6d6d6d',
                            600: '#5d5d5d',
                            700: '#4f4f4f',
                            800: '#454545',
                            900: '#3d3d3d',
                            950: '#000000',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #fbfbfb;
            color: #000000;
        }

        .sidebar-link {
            transition: all 0.2s ease;
        }

        .sidebar-link:hover {
            color: #000000;
        }

        .referral-card {
            background: linear-gradient(135deg, #0f1113 0%, #1a1c1e 100%);
            position: relative;
            overflow: hidden;
        }

        .referral-card::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 50%;
            height: 100%;
            background: radial-gradient(circle at 70% 50%, rgba(212, 175, 55, 0.1) 0%, transparent 70%);
            pointer-events: none;
        }

        .referral-card::after {
            content: '';
            position: absolute;
            top: 50%;
            right: 10%;
            width: 300px;
            height: 300px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 50%;
            transform: translateY(-50%);
            pointer-events: none;
        }

        .referral-card-inner-ring {
            position: absolute;
            top: 50%;
            right: 15%;
            width: 200px;
            height: 200px;
            border: 1px solid rgba(255, 255, 255, 0.03);
            border-radius: 50%;
            transform: translateY(-50%);
            pointer-events: none;
        }

        .referral-code-box {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
        }

        .copy-btn {
            background: #ffffff;
            color: #000000;
            transition: all 0.3s ease;
        }

        .copy-btn:hover {
            background: #f0f0f0;
            transform: translateY(-1px);
        }

        .stat-card {
            background: #ffffff;
            transition: all 0.3s ease;
        }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.05);
        }
    </style>
</head>

<body class="min-h-screen flex flex-col font-sans selection:bg-brand-950 selection:text-white">

    <!-- Navigation -->
    {{>navbar}}
    {{>breadCrumbs}}

    <!-- Main Content -->
    <main class="flex-grow max-w-7xl mx-auto w-full px-6 flex flex-col lg:block relative">

        <!-- Sidebar -->
        <aside class="w-full lg:w-48 lg:fixed lg:top-32 h-fit mb-10 lg:mb-0 pt-12">
            <h3 class="text-[10px] font-bold tracking-[0.15em] text-gray-400 uppercase mb-8">Account</h3>
            <nav class="flex flex-col space-y-6">
                <a href="/users/profile"
                    class="sidebar-link flex items-center text-[13px] font-medium text-gray-400 tracking-widest uppercase hover:text-black">
                    <span class="material-symbols-outlined mr-4 text-[20px]">person</span>Profile
                </a>
                <a href="/users/address"
                    class="sidebar-link flex items-center text-[13px] font-medium text-gray-400 tracking-widest uppercase hover:text-black">
                    <span class="material-symbols-outlined mr-4 text-[20px]">location_on</span>Address
                </a>
                <a href="/users/myOrders"
                    class="sidebar-link flex items-center text-[13px] font-medium text-gray-400 tracking-widest uppercase hover:text-black">
                    <span class="material-symbols-outlined mr-4 text-[20px]">inventory_2</span>My Orders
                </a>
                <a href="/users/wallet"
                    class="sidebar-link flex items-center text-[13px] font-medium text-gray-400 tracking-widest uppercase hover:text-black">
                    <span class="material-symbols-outlined mr-4 text-[20px]">account_balance_wallet</span>Wallet
                </a>
                <a href="/users/referral"
                    class="sidebar-link flex items-center text-[13px] font-bold text-black tracking-widest uppercase">
                    <span class="material-symbols-outlined mr-4 text-[20px]">share</span>Refer & Earn
                </a>
            </nav>
        </aside>

        <!-- Right Content Area -->
        <div class="w-full lg:pl-[16rem]  pb-20">

            <!-- Premium Header Section (Top Center) -->
            <div class="flex flex-col items-center text-center mb-16">
                <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-gray-100 mb-6">
                    <span class="material-symbols-outlined text-[14px]">stars</span>
                    <span class="text-[9px] font-black tracking-[0.2em] text-black uppercase">BootCamp Rewards</span>
                </div>
                <h1 class="text-5xl font-black text-black mb-4 tracking-tighter">Refer & Earn</h1>
                <p class="text-[13px] text-gray-500 font-medium max-w-md leading-relaxed">
                    Share your referral code with friends and enjoy exclusive rewards when they join and complete their first purchase.
                </p>
            </div>

            <!-- Main Referral Card (Minimal Version) -->
            <div class="referral-card w-full rounded-[48px] p-10 md:p-14 mb-12 flex flex-col md:flex-row items-center justify-between shadow-2xl shadow-black/10 overflow-hidden">
                <div class="referral-card-inner-ring"></div>
                
                <div class="relative z-10 w-full flex flex-col md:flex-row items-center justify-between gap-12">
                    <!-- Text Content -->
                    <div class="max-w-sm text-center md:text-left">
                        <h2 class="text-white text-4xl font-serif mb-4 leading-tight">
                            Invite Friends.<br>
                            <span class="text-white/60 italic">Earn Rewards.</span>
                        </h2>
                        <p class="text-gray-500 text-[12px] leading-relaxed mb-0">
                            When your friend signs up using your referral code and completes their first order, you'll receive ₹100 in your wallet and your friend will receive ₹50.
                        </p>
                    </div>

                    <!-- Code Box (More Minimal) -->
                    <div class="referral-code-box w-full md:w-auto min-w-[320px] rounded-[32px] p-6 flex items-center justify-between gap-6">
                        <div>
                            <span class="text-[8px] font-black tracking-[0.2em] text-gray-500 uppercase mb-1.5 block">Unique Signature</span>
                            <span class="text-white text-xl font-mono font-bold tracking-[0.1em] uppercase" id="referralCode">{{user.referralCode}}</span>
                        </div>
                        <button onclick="copyToClipboard('{{user.referralCode}}')" class="copy-btn px-6 py-3.5 rounded-2xl text-[10px] font-black uppercase tracking-widest flex items-center gap-2">
                            <span class="material-symbols-outlined text-[16px]">content_copy</span>
                            <span>Copy</span>
                        </button>
                    </div>

                    <!-- Compact Social Links -->
                    <div class="flex items-center gap-6">
                        <button onclick="window.open('#')" class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center text-white/40 hover:text-white hover:border-white/30 transition-all">
                            <span class="material-symbols-outlined text-[20px]">chat</span>
                        </button>
                        <button onclick="copyToClipboard('http://localhost:5001/users/signup?ref={{user.referralCode}}')" class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center text-white/40 hover:text-white hover:border-white/30 transition-all">
                            <span class="material-symbols-outlined text-[20px]">link</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Stats Grid -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Total Referrals -->
                <div class="stat-card p-10 rounded-[32px] border border-gray-100 flex flex-col items-start gap-6">
                    <div class="w-12 h-12 rounded-2xl bg-gray-50 flex items-center justify-center">
                        <span class="material-symbols-outlined text-gray-400">group</span>
                    </div>
                    <div>
                        <h3 class="text-[10px] font-bold tracking-[0.2em] text-gray-400 uppercase mb-3">Total Referrals</h3>
                        <p class="text-5xl font-serif text-black">{{stats.totalReferrals}}</p>
                    </div>
                </div>

                <!-- Total Earned -->
                <div class="stat-card p-10 rounded-[32px] border border-gray-100 flex flex-col items-start gap-6">
                    <div class="w-12 h-12 rounded-2xl bg-gray-50 flex items-center justify-center">
                        <span class="material-symbols-outlined text-gray-400">stars</span>
                    </div>
                    <div>
                        <h3 class="text-[10px] font-bold tracking-[0.2em] text-gray-400 uppercase mb-3">Total Earned</h3>
                        <p class="text-5xl font-serif text-black">₹{{stats.totalEarned}}</p>
                    </div>
                </div>

                <!-- Wallet Balance -->
                <div class="stat-card p-10 rounded-[32px] border border-gray-100 flex flex-col items-start gap-6">
                    <div class="w-12 h-12 rounded-2xl bg-gray-50 flex items-center justify-center">
                        <span class="material-symbols-outlined text-gray-400">account_balance_wallet</span>
                    </div>
                    <div>
                        <h3 class="text-[10px] font-bold tracking-[0.2em] text-gray-400 uppercase mb-3">Wallet Balance</h3>
                        <p class="text-5xl font-serif text-black">₹{{user.walletBalance}}</p>
                    </div>
                </div>
            </div>

        </div>
    </main>

    <script src="/toast/toast.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <script>
        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).then(() => {
                showToast("success","Copied To Clipboard");
        });
    }
    </script>
</body>

</html>
