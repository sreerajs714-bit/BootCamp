<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Wallet | BOOT CAMP</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;600;800;900&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
        rel="stylesheet">
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,300,0,0" />
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
        <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        display: ['Outfit', 'sans-serif'],
                        serif: ['Playfair Display', 'serif'],
                    },
                    colors: {
                        brand: {
                            950: '#000000',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #fbfbfb;
            color: #000000;
        }

        .sidebar-link {
            transition: all 0.2s ease;
        }

        .sidebar-link:hover {
            color: #000000;
        }

        /* Premium Wallet Card */
        .wallet-card {
            background: linear-gradient(135deg, #1a1a1a 0%, #000000 100%);
            position: relative;
            overflow: hidden;
        }

        .wallet-card::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 300px;
            height: 300px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 50%;
            pointer-events: none;
        }

        /* Modal Glassmorphism */
        .modal-glass {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(0, 0, 0, 0.05);
        }

        @keyframes modal-in {
            from {
                opacity: 0;
                transform: translate(-50%, -45%) scale(0.95);
            }

            to {
                opacity: 1;
                transform: translate(-50%, -50%) scale(1);
            }
        }

        .animate-modal-in {
            animation: modal-in 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        /* Transaction Table Styles */
        .tr-row {
            transition: background 0.2s ease;
        }

        .tr-row:hover {
            background: #f9f9f9;
        }
    </style>
</head>

<body class="min-h-screen flex flex-col font-sans selection:bg-brand-950 selection:text-white">

    <!-- Navigation (Assuming standard layout) -->
    {{>navbar}}
    {{>breadCrumbs}}

    <main class="flex-grow max-w-7xl mx-auto w-full px-6 flex flex-col lg:block relative ">

        <!-- Sidebar -->
        <aside class="w-full lg:w-48 lg:fixed lg:top-32 h-fit mb-10 lg:mb-0 pt-12">
            <h3 class="text-[10px] font-bold tracking-[0.15em] text-gray-400 uppercase mb-8">Account</h3>
            <nav class="flex flex-col space-y-6">
                <a href="/users/profile"
                    class="sidebar-link flex items-center text-[13px] font-medium text-gray-400 tracking-widest uppercase hover:text-black">
                    <span class="material-symbols-outlined mr-4 text-[20px]">person</span>Profile
                </a>
                <a href="/users/address"
                    class="sidebar-link flex items-center text-[13px] font-medium text-gray-400 tracking-widest uppercase hover:text-black">
                    <span class="material-symbols-outlined mr-4 text-[20px]">location_on</span>Address
                </a>
                <a href="/users/myOrders"
                    class="sidebar-link flex items-center text-[13px] font-medium text-gray-400 tracking-widest uppercase hover:text-black">
                    <span class="material-symbols-outlined mr-4 text-[20px]">inventory_2</span>My Orders
                </a>
                <a href="/users/wallet"
                    class="sidebar-link flex items-center text-[13px] font-bold text-black tracking-widest uppercase">
                    <span class="material-symbols-outlined mr-4 text-[20px]">account_balance_wallet</span>Wallet
                </a>
                <a href="/users/referal"
                    class="sidebar-link flex items-center text-[13px] font-medium text-gray-400 tracking-widest uppercase hover:text-black">
                    <span class="material-symbols-outlined mr-4 text-[20px]">share</span>Refer & Earn
                </a>
            </nav>
        </aside>

        <!-- Right Content Area -->
        <div class="w-full lg:pl-[16rem]">

            <!-- Header Section -->
            <div class="mb-16">
                <h1 class="text-5xl font-serif text-black mb-4 tracking-tight">My Wallet</h1>
                <div class="flex items-center gap-4">
                    <div class="h-px w-12 bg-black"></div>
                    <p class="text-[10px] font-black text-gray-400 uppercase tracking-[0.3em]">Institutional Financial Protocol</p>
                </div>
            </div>

            <!-- Top Section: Wallet Card -->
            <div class="mb-16">
                <div
                    class="wallet-card w-full max-w-[480px] aspect-[1.7/1] rounded-[36px] p-12 text-white flex flex-col justify-between shadow-2xl shadow-black/30 relative group transition-all duration-500 hover:scale-[1.01]">
                    <div class="absolute top-0 right-0 p-10 opacity-10 group-hover:opacity-25 transition-opacity">
                        <span class="material-symbols-outlined text-8xl">account_balance_wallet</span>
                    </div>

                    <div>
                        <p class="text-[10px] font-black tracking-[0.25em] opacity-50 uppercase mb-6">Available Balance
                        </p>
                        <div class="flex items-start gap-2">
                            <span class="text-4xl font-serif mt-3 opacity-80">₹</span>
                            <span class="text-6xl font-serif tracking-tighter" id="walletBalance">{{wallet.balance}}</span>
                        </div>
                    </div>

                    <div class="flex items-end justify-between relative z-10">
                        <div>
                            <p class="text-[9px] font-black tracking-[0.25em] opacity-40 uppercase mb-1">Authenticated Holder</p>
                            <p class="text-2xl font-serif tracking-wide">{{user.username}}</p>
                        </div>
                        <button onclick="openModal('addFundModal')"
                            class="bg-white text-black px-10 py-5 rounded-2xl text-[11px] font-black uppercase tracking-widest hover:bg-gray-100 transition-all flex items-center gap-3 shadow-xl shadow-black/20">
                            <span class="material-symbols-outlined text-[18px]">add_circle</span>
                            Add Funds
                        </button>
                    </div>
                </div>
            </div>

            <!-- Middle Section: Recent Transactions -->
            <div class="mb-16">
                <div class="flex items-end justify-between mb-10 border-b border-gray-100 pb-8">
                    <div>
                        <h2 class="text-2xl font-serif text-black mb-2">Recent Transactions</h2>
                        <p class="text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]">Transaction Ledger History</p>
                    </div>
                    <div class="text-right">
                        <p class="text-[10px] font-black text-black uppercase tracking-widest mb-1">Total Entries</p>
                        <span class="text-2xl font-serif text-gray-300">{{wallet.transactions.length}}</span>
                    </div>
                </div>

                <div class="bg-white border border-gray-100 rounded-[32px] overflow-hidden shadow-sm">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-gray-50/50">
                                <th class="px-10 py-7 text-[10px] font-black tracking-[0.25em] text-gray-400 uppercase">Date & Time</th>
                                <th class="px-10 py-7 text-[10px] font-black tracking-[0.25em] text-gray-400 uppercase">Transaction ID</th>
                                <th class="px-10 py-7 text-[10px] font-black tracking-[0.25em] text-gray-400 uppercase">Order ID</th>
                                <th class="px-10 py-7 text-[10px] font-black tracking-[0.25em] text-gray-400 uppercase">Status</th>
                                <th class="px-10 py-7 text-[10px] font-black tracking-[0.25em] text-gray-400 uppercase text-right">Amount</th>
                            </tr>
                        </thead>
                        <tbody id="transactionList">
                            {{#if wallet.transactions.length}}
                            {{#each wallet.transactions}}
                            <tr class="tr-row border-b border-gray-50 last:border-0 hover:bg-gray-50/50 transition-colors">
                                <td class="px-10 py-7">
                                    <p class="text-[13px] font-black text-black mb-1">{{formatDate this.date}}</p>
                                    <p class="text-[11px] text-gray-400 font-medium uppercase tracking-[0.1em]">{{formatTime this.date}}</p>
                                </td>
                                <td class="px-10 py-7">
                                    <p class="text-[12px] font-mono font-bold text-gray-600">#{{slice this.transactionId -10}}</p>
                                    <p class="text-[10px] text-gray-300 font-black uppercase tracking-widest mt-1">{{this.description}}</p>
                                </td>
                                <td class="px-10 py-7">
                                    {{#if this.orderId}}
                                        <p class="text-[12px] font-mono font-bold text-black opacity-60">ORD-{{slice this.orderId -6}}</p>
                                    {{else}}
                                        <p class="text-[10px] font-black text-gray-300 uppercase tracking-widest">N/A</p>
                                    {{/if}}
                                </td>
                                <td class="px-10 py-7">
                                    <span class="px-4 py-2 rounded-xl text-[9px] font-black uppercase tracking-widest {{#if (eq this.type 'credit')}}bg-green-50 text-green-600{{else}}bg-red-50 text-red-600{{/if}}">
                                        {{this.type}}
                                    </span>
                                </td>
                                <td class="px-10 py-7 text-right">
                                    <p class="text-[17px] font-black {{#if (eq this.type 'credit')}}text-green-600{{else}}text-black{{/if}}">
                                        {{#if (eq this.type 'credit')}}+{{else}}-{{/if}}₹{{this.amount}}
                                    </p>
                                </td>
                            </tr>
                            {{/each}}
                            {{else}}
                            <tr>
                                <td colspan="5" class="px-10 py-28 text-center">
                                    <div class="flex flex-col items-center">
                                        <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mb-6">
                                            <span class="material-symbols-outlined text-gray-200 text-4xl">account_balance_wallet</span>
                                        </div>
                                        <h3 class="text-2xl font-serif text-black mb-3">No Transactions Yet</h3>
                                        <p class="text-[13px] font-medium text-gray-400 max-w-[340px] leading-relaxed">Financial ledger is currently vacant. Your history will manifest upon your first transaction.</p>
                                    </div>
                                </td>
                            </tr>
                            {{/if}}
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Bottom Section: Quick Tip -->
            <div
                class="max-w-md bg-[#f9f9f9] border border-gray-100 rounded-[28px] p-10 relative overflow-hidden group">
                <div
                    class="absolute -right-4 -bottom-4 opacity-[0.03] group-hover:opacity-[0.06] transition-opacity duration-700">
                    <span class="material-symbols-outlined text-9xl">lightbulb</span>
                </div>
                <h4
                    class="text-[10px] font-black tracking-[0.2em] text-gray-400 uppercase mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined text-[16px] text-black">info</span>
                    Protocol Tip
                </h4>
                <p class="text-[13px] font-medium text-gray-500 leading-relaxed relative z-10">
                    Utilize your wallet balance for instantaneous checkouts and seamless return procedures. Credits are
                    synchronized immediately upon confirmation.
                </p>
            </div>

        </div>
    </main>

    <!-- Add Fund Modal -->
    <div id="modalBackdrop"
        class="fixed inset-0 bg-black/60 backdrop-blur-md z-[60] hidden opacity-0 transition-opacity duration-500"
        onclick="closeModal('addFundModal')"></div>

    <div id="addFundModal"
        class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[90%] max-w-md bg-white z-[70] hidden opacity-0 transition-all duration-300 p-10 rounded-[32px] shadow-2xl">
        <div class="flex justify-between items-center mb-8">
            <div>
                <h3 class="text-[9px] font-black tracking-[0.2em] text-gray-400 uppercase mb-1">Total Assets</h3>
                <h2 class="text-3xl font-serif text-black">Add Funds</h2>
            </div>
            <button onclick="closeModal('addFundModal')"
                class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-gray-100 transition-colors">
                <span class="material-symbols-outlined text-black">close</span>
            </button>
        </div>

        <form id="addFundForm" class="space-y-6">
            <div class="space-y-2">
                <label class="text-[10px] font-black tracking-widest text-gray-400 uppercase px-1">Amount to Add
                    (₹)</label>
                <div class="relative">
                    <span class="absolute left-5 top-1/2 -translate-y-1/2 text-xl font-serif text-gray-400">₹</span>
                    <input type="text" id="fundAmount" name="amount" placeholder="0.00" min="1" max="50000"
                        class="w-full pl-12 pr-5 py-4 bg-gray-50 border-2 border-transparent focus:border-black rounded-2xl text-[18px] font-medium transition-all outline-none">
                        <p id="amountError" class="text-red-500 text-[11px] font-bold tracking-wide mt-2 px-1 hidden"></p>
                </div>
            </div>

            <div class="flex gap-3 mb-4">
                <button type="button" onclick="setAmount(500)"
                    class="flex-1 py-3 border border-gray-200 rounded-xl text-[11px] font-bold hover:border-black transition-all">+
                    ₹500</button>
                <button type="button" onclick="setAmount(1000)"
                    class="flex-1 py-3 border border-gray-200 rounded-xl text-[11px] font-bold hover:border-black transition-all">+
                    ₹1000</button>
                <button type="button" onclick="setAmount(2000)"
                    class="flex-1 py-3 border border-gray-200 rounded-xl text-[11px] font-bold hover:border-black transition-all">+
                    ₹2000</button>
            </div>

            <button type="submit"
                class="w-full py-5 bg-black text-white font-black uppercase tracking-widest text-[11px] rounded-2xl hover:bg-gray-800 transition-all shadow-xl shadow-black/10 flex items-center justify-center gap-2 group">
                <span>Proceed to Pay</span>
                <span
                    class="material-symbols-outlined text-[18px] group-hover:translate-x-1 transition-transform">arrow_forward</span>
            </button>
        </form>
    </div>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>


    <script src="/toast/toast.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>

    function openModal(id) {
        const modal = document.getElementById(id);
        const backdrop = document.getElementById('modalBackdrop');
        backdrop.classList.remove('hidden');
        setTimeout(() => backdrop.classList.remove('opacity-0'), 10);
        modal.classList.remove('hidden');
        modal.classList.add('animate-modal-in');
        setTimeout(() => modal.classList.remove('opacity-0'), 10);
    }

    function closeModal(id) {
        const modal = document.getElementById(id);
        const backdrop = document.getElementById('modalBackdrop');
        modal.classList.add('opacity-0');
        modal.classList.remove('animate-modal-in');
        backdrop.classList.add('opacity-0');
        setTimeout(() => {
            modal.classList.add('hidden');
            backdrop.classList.add('hidden');
        }, 300);
    }

    function setAmount(amt) {
        document.getElementById('fundAmount').value = amt;
    }

const fundAmountInput = document.getElementById('fundAmount');
const amountError = document.getElementById('amountError');

// Clear error on input change
fundAmountInput.addEventListener('input', () => {
    amountError.classList.add('hidden');
    amountError.textContent = '';
    fundAmountInput.classList.remove('border-red-400');
    fundAmountInput.classList.add('border-transparent');
});

function showAmountError(msg) {
    amountError.textContent = msg;
    amountError.classList.remove('hidden');
    fundAmountInput.classList.remove('border-transparent');
    fundAmountInput.classList.add('border-red-400');
}

document.getElementById('addFundForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const amount = parseFloat(fundAmountInput.value);

    // Validation
    if (!fundAmountInput.value.trim()) {
        showAmountError('Please enter an amount.');
        return;
    }
    if (isNaN(amount) || amount <= 0) {
        showAmountError('Enter a valid amount greater than ₹0.');
        return;
    }
    if (amount < 1) {
        showAmountError('Minimum amount is ₹1.');
        return;
    }
    if (amount > 50000) {
        showAmountError('Maximum amount is ₹50,000 per transaction.');
        return;
    }

        try {
            // Step 1: Create order on backend
            const orderRes = await axios.post('/users/wallet/addFund', { amount });

            if (!orderRes.data.success) {
                showToast( "error", orderRes.data.message || "FAILED TO CREATE ORDER");
                return;
            }

            const { orderId, amount: orderAmount, currency, keyId } = orderRes.data;

            // Step 2: Open Razorpay checkout
            const options = {
                key: keyId,
                amount: orderAmount,
                currency: currency,
                name: 'BOOT CAMP',
                description: 'Wallet Top-up',
                order_id: orderId,
                handler: async function (response) {
                    // Step 3: Verify payment on backend
                    try {
                        const verifyRes = await axios.post('/users/wallet/verify', {
                            razorpay_order_id: response.razorpay_order_id,
                            razorpay_payment_id: response.razorpay_payment_id,
                            razorpay_signature: response.razorpay_signature,
                            amount:orderAmount,
                        });

                        if (verifyRes.data.success) {
                            showToast("success","Fund Added Successfully")
                            document.getElementById('walletBalance').textContent = verifyRes.data.newBalance;
                            closeModal('addFundModal');
                            setTimeout(() => window.location.reload(), 1500);
                        }
                    } catch (err) {
                        showToast("error","Payment Verification Failed")
                    }
                },
                prefill: {
                    name: '{{user.username}}',
                    email: '{{user.email}}',
                },
                theme: { color: '#000000' },
                modal: {
                    ondismiss: function () {
                        showToast( "error","Payment Cancelled")
                    }
                }
            };

            const rzp = new Razorpay(options);
            rzp.open();

        } catch (err) {
            console.error('Payment error:', err);
            showToast("error",err.response?.data?.message || "Something Went Wrong")
        }
    });
</script>
</body>

</html>