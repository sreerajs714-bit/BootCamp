<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Order Confirmed – {{storeName}}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    /* ── Reset & Base ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:          #ffff;
      --bg-card:     #ffff;
      --fg:          #2c2a25;
      --fg-muted:    #7a7570;
      --accent:      #4a7c59;
      --accent-light:#e6f0ea;
      --accent-mid:  #b8d4c2;
      --border:      #d8d2c9;
      --shadow:      rgba(44,42,37,.08);
      --radius-lg:   18px;
      --radius-sm:   8px;
    }

    body {
      background: var(--bg);
      color: var(--fg);
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 40px 16px 60px;
    }

    /* ── Success Icon ── */
    .success-icon {
      width: 72px; height: 72px;
      border-radius: 50%;
      border: 3px solid var(--accent);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 20px;
      animation: popIn .5s cubic-bezier(.34,1.56,.64,1) both;
    }
    .success-icon svg { width: 34px; height: 34px; }

    @keyframes popIn {
      from { transform: scale(.6); opacity: 0; }
      to   { transform: scale(1);  opacity: 1; }
    }

    /* ── Header Copy ── */
    .header { text-align: center; margin-bottom: 32px; animation: fadeUp .5s .1s both; }
    .header h1 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(1.8rem, 4vw, 2.4rem);
      line-height: 1.15;
      color: var(--fg);
    }
    .header h1 em { font-style: italic; }
    .header p { margin-top: 8px; font-size: .88rem; color: var(--fg-muted); line-height: 1.6; }

    /* ── Order Confirmed Badge ── */
    .badge {
      display: inline-flex; align-items: center; gap: 6px;
      background: var(--accent-light);
      border: 1px solid var(--accent-mid);
      color: var(--accent);
      font-size: .72rem; font-weight: 600; letter-spacing: .06em; text-transform: uppercase;
      padding: 5px 14px; border-radius: 999px;
      margin-top: 14px;
    }
    .badge::before { content:''; width:6px; height:6px; background:var(--accent); border-radius:50%; }

    /* ── Card ── */
    .card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      width: 100%; max-width: 480px;
      padding: 24px;
      box-shadow: 0 8px 32px var(--shadow);
      animation: fadeUp .5s .2s both;

      /* 3-D perspective for parallax */
      perspective: 900px;
    }

    @keyframes fadeUp {
      from { opacity:0; transform:translateY(18px); }
      to   { opacity:1; transform:translateY(0); }
    }

    /* ── Parallax inner wrapper ── */
    .card-inner {
      transition: transform .25s cubic-bezier(.23,1,.32,1);
      transform-style: preserve-3d;
      border-radius: calc(var(--radius-lg) - 4px);
    }

    /* ── Order Meta Row ── */
    .order-meta {
      display: flex; justify-content: space-between; align-items: flex-start;
      margin-bottom: 20px;
    }
    .order-meta .label {
      font-size: .65rem; font-weight: 600; letter-spacing: .07em;
      text-transform: uppercase; color: var(--fg-muted); margin-bottom: 4px;
    }
    .order-meta .order-id {
      font-size: .95rem; font-weight: 700; color: var(--fg);
    }
    .order-meta .est-delivery { text-align: right; }
    .order-meta .est-date {
      font-size: .88rem; font-weight: 500; color: var(--fg);
    }

    /* ── Progress Tracker ── */
    .tracker { margin-bottom: 22px; }
    .tracker-steps {
      display: flex; align-items: center; position: relative;
    }
    .tracker-step {
      display: flex; flex-direction: column; align-items: center;
      flex: 1; position: relative; z-index: 1;
    }
    .step-dot {
      width: 14px; height: 14px; border-radius: 50%;
      background: var(--border);
      border: 2px solid var(--border);
      transition: background .3s, border-color .3s;
      position: relative;
    }
    .step-dot.done   { background: var(--accent); border-color: var(--accent); }
    .step-dot.active { background: #fff; border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-mid); }

    .tracker-line {
      position: absolute; top: 7px; left: 0; right: 0;
      height: 2px; background: var(--border); z-index: 0;
    }
    .tracker-line-fill {
      height: 100%; background: var(--accent);
      transition: width .6s ease;
    }
    .step-label {
      font-size: .62rem; font-weight: 500; margin-top: 6px;
      color: var(--fg-muted); text-align: center;
      text-transform: uppercase; letter-spacing: .05em;
    }
    .step-label.active { color: var(--accent); font-weight: 700; }

    /* ── Line Items ── */
    .line-items { border-top: 1px solid var(--border); padding-top: 18px; }
    .line-item {
      display: flex; align-items: center; gap: 14px; margin-bottom: 14px;
    }
    .item-img {
      width: 52px; height: 52px; border-radius: var(--radius-sm);
      object-fit: cover; background: var(--border); flex-shrink: 0;
    }
    .item-info { flex: 1; }
    .item-name { font-size: .88rem; font-weight: 500; color: var(--fg); }
    .item-sub  { font-size: .76rem; color: var(--fg-muted); margin-top: 2px; }
    .item-price { font-size: .9rem; font-weight: 600; color: var(--fg); white-space: nowrap; }

    /* ── Totals ── */
    .totals { border-top: 1px solid var(--border); padding-top: 14px; margin-top: 6px; }
    .totals-row {
      display: flex; justify-content: space-between;
      font-size: .82rem; color: var(--fg-muted); margin-bottom: 6px;
    }
    .totals-row.grand {
      font-size: 1rem; font-weight: 700; color: var(--fg);
      margin-top: 8px; padding-top: 10px; border-top: 1px solid var(--border);
    }
    .totals-row .payment-method {
      font-size: .72rem; color: var(--fg-muted); text-align: right;
    }

    /* ── Delivery Truck Parallax Layer ── */
    .truck-layer {
      display: flex; justify-content: center; margin-bottom: 16px;
      transform: translateZ(30px);
    }
    .truck-layer img {
      height: 64px; object-fit: contain;
      filter: drop-shadow(0 6px 12px rgba(74,124,89,.25));
      transition: transform .3s;
    }

    /* ── CTA Buttons ── */
    .cta-row {
      display: flex; gap: 10px; margin-top: 28px; animation: fadeUp .5s .35s both;
      width: 100%; max-width: 480px;
    }
    .btn {
      flex: 1; padding: 13px 20px; border-radius: 999px;
      font-family: 'DM Sans', sans-serif; font-size: .84rem; font-weight: 600;
      cursor: pointer; border: none; transition: transform .15s, box-shadow .15s;
      letter-spacing: .02em;
    }
    .btn:hover { transform: translateY(-1px); box-shadow: 0 4px 16px var(--shadow); }
    .btn:active { transform: translateY(0); }
    .btn-primary { background: var(--fg); color: #fff; }
    .btn-outline { background: transparent; border: 1.5px solid var(--border); color: var(--fg); }

    /* ── Responsive ── */
    @media (max-width: 400px) {
      .order-meta .est-delivery { display: none; }
      .step-label { font-size: .56rem; }
    }
  </style>
</head>
<body>

  <!-- Success Icon -->
  <div class="success-icon">
    <svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="20 6 9 17 4 12"/>
    </svg>
  </div>

  <!-- Header -->
  <div class="header">
    <h1>Thank you <em>for ordering.</em></h1>
    <p>
      Your order has been placed and we're preparing it with care.<br/>
      A confirmation has been sent to your email.
    </p>
    <span class="badge">Order Confirmed</span>
  </div>

  <!-- Card -->
  <div class="card" id="parallax-card">
    <div class="card-inner" id="parallax-inner">

      <!-- Order Meta -->
      <div class="order-meta">
        <div>
          <div class="label">Order Number</div>
          <div class="order-id">#{{order.orderNumber}}</div>
        </div>
        <div class="est-delivery">
          <div class="label">Est. Delivery</div>
          <div class="est-date">{{order.deliveryStart}} – {{order.deliveryEnd}}</div>
        </div>
      </div>

      <!-- Progress Tracker -->
      {{#with order.tracking}}
      <div class="tracker">
        <div style="position:relative;">
          <!-- Background line -->
          <div class="tracker-line">
            <div class="tracker-line-fill" style="width: {{progressPercent}}%;"></div>
          </div>
          <div class="tracker-steps">
            <div class="tracker-step">
              <div class="step-dot {{#if (gte currentStep 0)}}done{{/if}}"></div>
              <div class="step-label {{#if (eq currentStep 0)}}active{{/if}}">Confirmed</div>
            </div>
            <div class="tracker-step">
              <div class="step-dot {{#if (gte currentStep 1)}}done{{else if (eq currentStep 1)}}active{{/if}}"></div>
              <div class="step-label {{#if (eq currentStep 1)}}active{{/if}}">Processing</div>
            </div>
            <div class="tracker-step">
              <div class="step-dot {{#if (gte currentStep 2)}}done{{else if (eq currentStep 2)}}active{{/if}}"></div>
              <div class="step-label {{#if (eq currentStep 2)}}active{{/if}}">Shipped</div>
            </div>
            <div class="tracker-step">
              <div class="step-dot {{#if (eq currentStep 3)}}active{{else if (gte currentStep 3)}}done{{/if}}"></div>
              <div class="step-label {{#if (eq currentStep 3)}}active{{/if}}">Delivered</div>
            </div>
          </div>
        </div>
      </div>
      {{/with}}

      <!-- Line Items -->
      <div class="line-items">
        {{#each order.items}}
        <div class="line-item">
          <img
            class="item-img"
            src="{{this.imageUrl}}"
            alt="{{this.name}}"
            onerror="this.src='https://placehold.co/52x52/e8e3dc/7a7570?text='"
          />
          <div class="item-info">
            <div class="item-name">{{this.name}}</div>
            <div class="item-sub">{{this.variant}}</div>
          </div>
          <div class="item-price">{{this.price}}</div>
        </div>
        {{/each}}
      </div>

      <!-- Totals -->
      <div class="totals">
        <div class="totals-row">
          <span>Subtotal</span>
          <span>{{order.subtotal}}</span>
        </div>
        <div class="totals-row">
          <span>Shipping</span>
          <span>{{order.shippingCost}}</span>
        </div>
       {{#if order.offerDiscount}}
<div class="totals-row">
  <span>Offer Discount</span>
  <span style="color:var(--accent);">–{{order.offerDiscount}}</span>
</div>
{{/if}}

{{#if order.couponDiscount}}
<div class="totals-row">
  {{#if order.couponCode}}
    <span>Coupon ({{order.couponCode}})</span>
  {{else}}
    <span>Coupon Discount</span>
  {{/if}}
  <span style="color:var(--accent);">–{{order.couponDiscount}}</span>
</div>
{{/if}}

{{#if order.totalDiscount}}
<div class="totals-row" style="font-weight:600; color:var(--accent);">
  <span>Total Savings</span>
  <span>–{{order.totalDiscount}}</span>
</div>
{{/if}}
        <div class="totals-row grand">
          <span>Total Paid</span>
          <div style="text-align:right;">
            <div>{{order.total}}</div>
            <div class="payment-method">{{order.paymentMethod}}</div>
          </div>
        </div>
      </div>

    </div><!-- /card-inner -->
  </div><!-- /card -->

  <!-- CTA Buttons -->
  <div class="cta-row">
    <a href="{{continueShoppingUrl}}" style="text-decoration:none;flex:1;">
      <button class="btn btn-primary" style="width:100%;">Continue Shopping →</button>
    </a>
    <a href="{{myOrdersUrl}}" style="text-decoration:none;flex:1;">
      <button class="btn btn-outline" style="width:100%;">View My Orders</button>
    </a>
  </div>

  <!-- Parallax Script -->
  <script>
    const card   = document.getElementById('parallax-card');
    const inner  = document.getElementById('parallax-inner');
    const truck  = document.getElementById('truck-layer');

    card.addEventListener('mousemove', (e) => {
      const rect  = card.getBoundingClientRect();
      const xPct  = (e.clientX - rect.left)  / rect.width  - 0.5; // -0.5 → 0.5
      const yPct  = (e.clientY - rect.top)   / rect.height - 0.5;

      const rotX  =  yPct * -18;   // tilt up/down
      const rotY  =  xPct *  18;   // tilt left/right

      inner.style.transform =
        `rotateX(${rotX}deg) rotateY(${rotY}deg)`;

      if (truck) {
        truck.style.transform =
          `translateZ(30px) translateY(${yPct * -20}px) translateX(${xPct * -10}px)`;
      }
    });

    card.addEventListener('mouseleave', () => {
      inner.style.transform = 'rotateX(0deg) rotateY(0deg)';
      if (truck) truck.style.transform = 'translateZ(30px)';
    });
  </script>

</body>
</html>
